    },
    {
      "type": "star_review",
      "name": "Star Review",
      "settings": [
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "default": "Great Product!"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Review text",
          "default": "<p>This is a review of the product with detailed feedback.</p>"
        }
      ]
    },
    {
      "type": "customer_reviews",
