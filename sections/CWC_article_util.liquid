        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show star rating",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2025-01-10"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "content",
      "name": "Content",
      "settings": [
        {
          "type": "richtext",
          "id": "content_1",
