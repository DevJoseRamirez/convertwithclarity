{% style %}
  #CWC_banner_image-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_banner_image.css' | asset_url | stylesheet_tag }}

<section id="CWC_banner_image-{{ section.id }}" class="CWC_banner_image CWC_banner_image-{{ section.id }}">
  <div class="CWC_banner-inner">
    {% if section.settings.desktop_image != blank %}
      <a href="{{ section.settings.link }}" class="desktop-banner">
        <img
          src="{{ section.settings.desktop_image | image_url }}"
          alt="{{ section.settings.alt_text | escape }}"
          class="banner-image"
          loading="eager"
          priority="high"
        >
      </a>
    {% endif %}

    {% if section.settings.mobile_image != blank %}
      <a href="{{ section.settings.link }}" class="mobile-banner">
        <img
          src="{{ section.settings.mobile_image | image_url }}"
          alt="{{ section.settings.alt_text | escape }}"
          class="banner-image"
          loading="eager"
          priority="high"
        >
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Banner Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image (optional)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner link (optional)"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt text",
      "default": "Promotional banner"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Banner Image",
      "category": "Custom"
    }
  ]
}
{% endschema %}
