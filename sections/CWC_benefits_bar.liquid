{% style %}
  #CWC_benefits_bar-{{ section.id }} {
    --section-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#000000' }};
    --icon-color: {{ section.settings.icon_color | default: '#000000' }};
    --padding-top: {{ section.settings.padding_top | default: 12 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 12 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.75 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.75 }}px;
    --autoplay-speed: {{ section.settings.autoplay_speed | default: 3 }}s;
  }
{% endstyle %}

{{ 'CWC_benefits_bar.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_benefits_bar-{{ section.id }}"
  class="cwc-benefits-bar"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
>
  <div class="cwc-benefits-bar__container">
    <div class="cwc-benefits-bar__desktop">
      {% for block in section.blocks %}
        {% if block.type == 'item' %}
          <div class="cwc-benefits-bar__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <img
                src="{{ block.settings.icon | image_url: width: 48 }}"
                alt="{{ block.settings.text | default: 'Benefit icon' }}"
                width="24"
                height="24"
                class="cwc-benefits-bar__icon"
                loading="lazy"
              >
            {% endif %}
            {% if block.settings.text != blank %}
              <span class="cwc-benefits-bar__text">{{ block.settings.text }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="cwc-benefits-bar__mobile">
      {% comment %} Previous Button {% endcomment %}
      {% if section.settings.show_arrows %}
        <button class="cwc-benefits-bar__nav cwc-benefits-bar__nav--prev" aria-label="Previous benefit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
      {% endif %}

      {% comment %} Carousel Track {% endcomment %}
      <div class="cwc-benefits-bar__carousel">
        <div class="cwc-benefits-bar__track">
          {% for block in section.blocks %}
            {% if block.type == 'item' %}
              <div
                class="cwc-benefits-bar__slide {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.icon != blank %}
                  <img
                    src="{{ block.settings.icon | image_url: width: 48 }}"
                    alt="{{ block.settings.text | default: 'Benefit icon' }}"
                    width="24"
                    height="24"
                    class="cwc-benefits-bar__icon"
                    loading="lazy"
                  >
                {% endif %}
                {% if block.settings.text != blank %}
                  <span class="cwc-benefits-bar__text">{{ block.settings.text }}</span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
          {% comment %} duplicate {% endcomment %}
          {% for block in section.blocks %}
            {% if block.type == 'item' %}
              <div
                class="cwc-benefits-bar__slide {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.icon != blank %}
                  <img
                    src="{{ block.settings.icon | image_url: width: 48 }}"
                    alt="{{ block.settings.text | default: 'Benefit icon' }}"
                    width="24"
                    height="24"
                    class="cwc-benefits-bar__icon"
                    loading="lazy"
                  >
                {% endif %}
                {% if block.settings.text != blank %}
                  <span class="cwc-benefits-bar__text">{{ block.settings.text }}</span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
          {% comment %} duplicate {% endcomment %}
        </div>
      </div>

      {% comment %} Next Button {% endcomment %}
      {% if section.settings.show_arrows %}
        <button class="cwc-benefits-bar__nav cwc-benefits-bar__nav--next" aria-label="Next benefit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</section>

{{ 'CWC_benefits_bar.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Benefits Bar",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Mobile Carousel"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Auto-Cycle (Mobile)",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Cycle Speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "default": 3,
      "info": "Time between auto-cycling slides"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Navigation Arrows (Mobile)",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Benefit Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Benefit One"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Bar",
      "category": "Custom",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "Free Shipping"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "365 Day Guarantee"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "All Natural"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Made in USA"
          }
        }
      ]
    }
  ]
}
{% endschema %}
