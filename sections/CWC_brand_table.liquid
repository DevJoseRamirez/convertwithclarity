{% style %}
  #CWC_brand_table-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#F9FAFB' }};
    --text-color: {{ section.settings.text_color | default: '#1F2937' }};
    --highlight-color: {{ section.settings.highlight_color | default: '#64CCC9' }};
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.6 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.6 }}px;
  }
{% endstyle %}

{{ 'CWC_brand_table.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_brand_table-{{ section.id }}"
  class="cwc-brand-table"
>
  <div class="cwc-brand-table__container">
    {% if section.settings.section_title != blank %}
      <div class="cwc-brand-table__section-title rte">
        {{ section.settings.section_title }}
      </div>
    {% endif %}

    {% if section.settings.section_subtitle != blank %}
      <div class="cwc-brand-table__section-subtitle rte">
        {{ section.settings.section_subtitle }}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="cwc-brand-table__wrapper">
        <table class="cwc-brand-table__table cwc-brand-table__table--{{ section.settings.num_columns }}">
          <thead>
            <tr>
              <th class="cwc-brand-table__header-cell">
                {% if section.settings.header_col_1 != blank %}
                  {{ section.settings.header_col_1 }}
                {% else %}
                  Feature
                {% endif %}
              </th>
              <th class="cwc-brand-table__header-cell cwc-brand-table__header-cell--highlight">
                {% if section.settings.header_col_2 != blank %}
                  {{ section.settings.header_col_2 }}
                {% else %}
                  Brand 1
                {% endif %}
              </th>
              {% if section.settings.num_columns >= '3' %}
                <th class="cwc-brand-table__header-cell">
                  {% if section.settings.header_col_3 != blank %}
                    {{ section.settings.header_col_3 }}
                  {% else %}
                    Brand 2
                  {% endif %}
                </th>
              {% endif %}
              {% if section.settings.num_columns == '4' %}
                <th class="cwc-brand-table__header-cell">
                  {% if section.settings.header_col_4 != blank %}
                    {{ section.settings.header_col_4 }}
                  {% else %}
                    Brand 3
                  {% endif %}
                </th>
              {% endif %}
            </tr>
          </thead>
          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'row' %}
                <tr class="cwc-brand-table__row" {{ block.shopify_attributes }}>
                  <td class="cwc-brand-table__cell cwc-brand-table__cell--feature">
                    <div class="cwc-brand-table__cell-content">
                      {% if block.settings.cell_1_icon != blank %}
                        <img
                          class="cwc-brand-table__feature-icon"
                          src="{{ block.settings.cell_1_icon | image_url: width: 48 }}"
                          alt="{{ block.settings.cell_1 | strip_html }}"
                          loading="lazy"
                          width="24"
                          height="24"
                        >
                      {% endif %}
                      <div class="cwc-brand-table__cell-text rte">
                        {{ block.settings.cell_1 }}
                      </div>
                    </div>
                  </td>
                  <td class="cwc-brand-table__cell cwc-brand-table__cell--highlight">
                    <div class="cwc-brand-table__cell-content">
                      {% render 'CWC_icon-check_fill', fill_color: section.settings.highlight_color %}
                      <div class="cwc-brand-table__cell-text rte">
                        {{ block.settings.cell_2 }}
                      </div>
                    </div>
                  </td>
                  {% if section.settings.num_columns >= '3' %}
                    <td class="cwc-brand-table__cell">
                      <div class="cwc-brand-table__cell-content">
                        <div class="cwc-brand-table__cell-text rte">
                          {{ block.settings.cell_3 }}
                        </div>
                      </div>
                    </td>
                  {% endif %}
                  {% if section.settings.num_columns == '4' %}
                    <td class="cwc-brand-table__cell">
                      <div class="cwc-brand-table__cell-content">
                        <div class="cwc-brand-table__cell-text rte">
                          {{ block.settings.cell_4 }}
                        </div>
                      </div>
                    </td>
                  {% endif %}
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}

    {% if section.settings.note != blank %}
      <div class="cwc-brand-table__note">
        {{ section.settings.note }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Brand Table",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h2>Why Ollie Beats the Competition</h2>"
    },
    {
      "type": "richtext",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "<p>Most brands use 1-5% hydroxyapatite. Ollie uses 10%—the clinically effective dose. Plus, our rod-shaped particles absorb better than competitors' spherical particles.</p>"
    },
    {
      "type": "header",
      "content": "Table Settings"
    },
    {
      "type": "select",
      "id": "num_columns",
      "label": "Number of Columns",
      "options": [
        {
          "value": "2",
          "label": "2 Columns"
        },
        {
          "value": "3",
          "label": "3 Columns"
        },
        {
          "value": "4",
          "label": "4 Columns"
        }
      ],
      "default": "3",
      "info": "Total columns including the feature column"
    },
    {
      "type": "text",
      "id": "header_col_1",
      "label": "Column 1 Header (Feature)",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "header_col_2",
      "label": "Column 2 Header (Your Brand)",
      "default": "Ollie",
      "info": "This column will be highlighted"
    },
    {
      "type": "text",
      "id": "header_col_3",
      "label": "Column 3 Header",
      "default": "Other Brands"
    },
    {
      "type": "text",
      "id": "header_col_4",
      "label": "Column 4 Header",
      "default": "Risewell"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1F2937"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#64CCC9",
      "info": "Used for your brand column"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Table Note",
      "default": "Ollie delivers the strongest allowed hydroxyapatite dose at almost 40% lower cost.",
      "info": "Optional note displayed below the table"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Table Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "cell_1_icon",
          "label": "Feature Icon",
          "info": "Optional icon for the feature (recommended: 24x24px or larger square image)"
        },
        {
          "type": "richtext",
          "id": "cell_1",
          "label": "Feature Name",
          "default": "<p>Feature Name</p>"
        },
        {
          "type": "richtext",
          "id": "cell_2",
          "label": "Your Brand Value",
          "default": "<p><strong>Value 1</strong></p>",
          "info": "This column will be highlighted"
        },
        {
          "type": "richtext",
          "id": "cell_3",
          "label": "Competitor Value",
          "default": "<p>Value 2</p>"
        },
        {
          "type": "richtext",
          "id": "cell_4",
          "label": "Competitor Value",
          "default": "<p>Value 3</p>"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Brand Table",
      "category": "Custom",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "cell_1": "<p>% Nano-Hydroxyapatite</p>",
            "cell_2": "<p><strong>10% (Clinically Effective)</strong></p>",
            "cell_3": "<p>1–5% (Sub-Clinically)</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "cell_1": "<p>Sensitivity Relief</p>",
            "cell_2": "<p><strong>Addresses the root cause</strong></p>",
            "cell_3": "<p>Numbs pain temporarily</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "cell_1": "<p>Enamel Support</p>",
            "cell_2": "<p><strong>Refills weak spots & smooths enamel</strong></p>",
            "cell_3": "<p>Partial / surface-only</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "cell_1": "<p>Price</p>",
            "cell_2": "<p><strong>Affordable (~40% less)</strong></p>",
            "cell_3": "<p>Expensive</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
