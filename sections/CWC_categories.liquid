{% style %}
  #CWC_categories-{{ section.id }} {
    --section-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#000000' }};
    --highlight-color: {{ section.settings.bold_color | default: '#00766F' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 60 | times: 0.6 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 60 | times: 0.6 }}px;
  }
{% endstyle %}

{{ 'CWC_categories.css' | asset_url | stylesheet_tag }}

<section id="CWC_categories-{{ section.id }}" class="cwc-categories">
  <div class="cwc-categories__container">
    {% comment %} Section Header {% endcomment %}
    {% if section.settings.heading != blank %}
      <div class="cwc-categories__heading rte">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="cwc-categories__subtext rte">
        {{ section.settings.subtext }}
      </div>
    {% endif %}
    
    {% comment %} Categories Grid {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="cwc-categories__grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'category' %}
              <div class="cwc-categories__card" {{ block.shopify_attributes }}>
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="cwc-categories__card-link">
                {% endif %}

                <div class="cwc-categories__card-image">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 400 }}"
                      alt="{{ block.settings.title | default: 'Category' | strip_html | escape }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                      fetchpriority="low"
                    >
                  {% else %}
                    <div class="cwc-categories__placeholder">
                      <span>Add image</span>
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.title != blank %}
                  <div class="cwc-categories__card-title rte">
                    {{ block.settings.title }}
                  </div>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="cwc-categories__card-text rte">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% if block.settings.link != blank %}
                  </a>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Categories",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Section Heading",
      "default": "<h2>Shop Our <strong>Best Sellers</strong></h2>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Section Subtext",
      "default": "<p>explore our product categories</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Bold/Highlight Color",
      "default": "#00766F"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<p>Category Title</p>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description (Optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Categories",
      "category": "Custom",
      "blocks": [
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        }
      ]
    }
  ]
}
{% endschema %}
