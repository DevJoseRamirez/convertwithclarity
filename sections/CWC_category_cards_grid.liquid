{%- style -%}
  #cwc_category_cards_grid-{{ section.id }} {
  background: {{ section.settings.background_color }};
  color: {{ section.settings.text_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{{ 'cwc_category_cards_grid.css' | asset_url | stylesheet_tag }}

<div
  id="cwc_category_cards_grid-{{ section.id }}"
  class="cwc_category_cards_grid cwc_category_cards_grid-{{ section.id }}"
>
  <div class="cwc_category_cards_grid-wrapper">
    <div class="cwc_category_cards_grid-inner">
      {% if section.settings.heading != blank %}
        <h2 class="cwc_category_cards_grid-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      <div class="cwc_category_cards_grid-grid">
        {% for block in section.blocks %}
          <div class="cwc_category_cards_grid-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.label | escape }}"
                loading="lazy"
              >
            {% else %}
              <img src="{{ 'placeholder.png' | asset_url }}" alt="Placeholder image">
            {% endif %}
            {% if block.settings.label != blank %}
              <div class="cwc_category_cards_grid-label">{{ block.settings.label }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Cards Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "HOW CAN WE ENRICH YOUR DAY?"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label Text",
          "default": "Category Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards Grid",
      "category": "Custom",
      "blocks": [
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" }
      ]
    }
  ]
}
{% endschema %}
