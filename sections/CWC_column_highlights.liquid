{% style %}
  #CWC_column_highlights-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --title-color: {{ section.settings.title_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  --columns-desktop: {{ section.settings.columns_desktop }};
  --columns-mobile: {{ section.settings.columns_mobile }};
  }
{% endstyle %}

{{ 'CWC_column_highlights.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_column_highlights-{{ section.id }}"
  class="CWC_column_highlights CWC_column_highlights-{{ section.id }}{% if section.settings.enable_mobile_swipe %} is-scrollable{% endif %}"
>
  <div class="CWC_column_highlights-wrapper">
    {% if section.settings.title != blank %}
      <h2 class="CWC_column_highlights-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="CWC_column_highlights-grid text-{{ section.settings.text_align }}">
      {% for block in section.blocks %}
        <div class="CWC_column_highlights-card" {{ block.shopify_attributes }}>
          {% unless section.settings.no_images %}
            <div class="highlight-image">
              {% if block.settings.image %}
                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.title | escape }}">
              {% else %}
                <img src="{{ 'placeholder.png' | asset_url }}" alt="Placeholder image">
              {% endif %}
            </div>
          {% endunless %}

          {% if block.settings.title != blank %}
            <h3 class="highlight-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="highlight-text">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Column Highlights",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "checkbox",
      "id": "no_images",
      "label": "No Images In Columns",
      "default": false
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns per row (desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns per row (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_swipe",
      "label": "Enable swipe on mobile",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Short explanation or benefit description goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Column Highlights",
      "category": "Custom",
      "blocks": [{ "type": "highlight" }, { "type": "highlight" }, { "type": "highlight" }]
    }
  ]
}
{% endschema %}
