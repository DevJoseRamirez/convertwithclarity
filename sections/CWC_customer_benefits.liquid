{% comment %}
  Section: CWC_Customer Benefits
  Displays product or ritual benefits in a flexible‐column grid. Merchant can choose
  number of columns per row.
{% endcomment %}

{% style %}
  #cwc_customer_benefits-{{ section.id }} {
  background: {{ section.settings.background_color }};
  color: {{ section.settings.text_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  /* new: pass chosen column count into a CSS variable */
  --columns-per-row: {{ section.settings.columns_per_row }};
  }
{% endstyle %}

{{ 'CWC_customer_benefits.css' | asset_url | stylesheet_tag }}

<div id="cwc_customer_benefits-{{ section.id }}" class="cwc_customer_benefits">
  <div class="cwc_customer_benefits-wrapper">
    <div class="cwc_customer_benefits-inner">
      {% if section.settings.heading != blank %}
        <h2 class="cwc_customer_benefits-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="cwc_customer_benefits-subtext">{{ section.settings.subtext }}</p>
      {% endif %}

      <div class="cwc_customer_benefits-grid">
        {% for block in section.blocks %}
          <div class="cwc_customer_benefit-block" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="" loading="lazy">
            {% endif %}
            <div class="cwc_customer_benefit-title">{{ block.settings.title }}</div>
            <div class="cwc_customer_benefit-text">{{ block.settings.text }}</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Fog to Flow – In 1 Daily Ritual"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Most people feel tired, foggy, and off balance. ENRICHD helps you reset, naturally."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "columns_per_row",
      "label": "Columns per row",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns (default)" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "Clean Energy"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Benefit Description",
          "default": "Functional mushrooms support calm, steady energy all day."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Customer Benefits",
      "category": "Custom",
      "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }]
    }
  ]
}
{% endschema %}
