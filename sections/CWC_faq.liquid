{% style %}
  #cwc_faq-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#F7F5EC' }};
    --eyebrow-color: {{ section.settings.eyebrow_color | default: '#3F8060' }};
    --heading-color: {{ section.settings.heading_color | default: '#0C3B2C' }};
    --highlight-color: {{ section.settings.bold_color | default: '#3F8060' }};
    --subtext-color: {{ section.settings.subtext_color | default: '#343434' }};
    --item-bg: {{ section.settings.item_bg | default: '#FFFFFF' }};
    --item-border: {{ section.settings.item_border | default: '#E1E0D2' }};
    --item-border-hover: {{ section.settings.item_border_hover | default: '#C9C8B6' }};
    --item-radius: {{ section.settings.item_radius | default: 14 }}px;
    --item-padding-x: {{ section.settings.item_padding_x | default: 24 }}px;
    --item-padding-y: {{ section.settings.item_padding_y | default: 20 }}px;
    --item-question-color: {{ section.settings.item_question_color | default: '#0C3B2C' }};
    --item-answer-color: {{ section.settings.item_answer_color | default: '#343434' }};
    --item-chevron-color: {{ section.settings.item_chevron_color | default: '#3F8060' }};
    --item-answer-divider: {{ section.settings.item_answer_divider | default: '#EAE8DA' }};
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 80 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 80 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_faq.css' | asset_url | stylesheet_tag }}

{% comment %}
  IMAGE BACKGOURND
  - at the same level as the main content container
   - so just below the first sectoin here
{% endcomment %}
<section
  id="cwc_faq-{{ section.id }}"
  class="cwc_faq"
  data-section-id="{{ section.id }}"
>
  {% if section.settings.bg_image %}
    <div class="cwc_faq-overlay">
      {% comment %} <div class="cwc_stats-row-spotlight cwc-top_center">head center</div> {% endcomment %}
      {% comment %} <div class="cwc_stats-row-spotlight cwc-top_center-white">head center</div> {% endcomment %}

      <div class="cwc_faq-overlay-img">
        {{
          section.settings.bg_image
          | image_url: width: 600
          | image_tag:
            class: 'cwc_faq_texture-bg',
            widths: widths,
            height: logo_height,
            width: logo_width,
            alt: logo_alt,
            sizes: sizes,
            preload: true
        }}
      </div>
    </div>
  {% endif %}
  <div class="cwc_faq__container">
    {%- comment -%} ===== Centered Header ===== {%- endcomment -%}
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subtext != blank %}
      <div class="cwc_faq__header">
        {% if section.settings.eyebrow != blank %}
          <span class="cwc_faq__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="cwc_faq__heading cwc-rte">{{ section.settings.heading }}</div>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <div class="cwc_faq__subtext cwc-rte">{{ section.settings.subtext }}</div>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} ===== FAQ Items ===== {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="cwc_faq__items">
        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            {%- assign panel_id = 'cwc_faq-panel-' | append: section.id | append: '-' | append: block.id -%}
            {%- assign btn_id = 'cwc_faq-btn-' | append: section.id | append: '-' | append: block.id -%}

            <div class="cwc_faq__item" {{ block.shopify_attributes }}>
              <h3 class="cwc_faq__item-heading">
                <button
                  type="button"
                  class="cwc_faq__question"
                  id="{{ btn_id }}"
                  aria-expanded="false"
                  aria-controls="{{ panel_id }}"
                >
                  <span class="cwc_faq__question-text">
                    {{ block.settings.question }}
                  </span>
                  <span class="cwc_faq__chevron" aria-hidden="true">
                    <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" focusable="false">
                      <path d="M3.5 5.75 8 10.25l4.5-4.5" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              </h3>

              <div
                id="{{ panel_id }}"
                class="cwc_faq__answer"
                role="region"
                aria-labelledby="{{ btn_id }}"
                hidden
              >
                <div class="cwc_faq__answer-inner cwc-rte">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{{ 'CWC_faq.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC FAQ",
  "settings": [
    {
      "type": "header",
