{% style %}
    #CWC_faq_utility-{{ section.id }} {
    --section-bg: {{ section.settings.background_color }};
    --faq-bg: {{ section.settings.faq_bg_color }};
    --faq-text: {{ section.settings.faq_text_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
    }


    .header__icons .icon svg {
      width: 2rem;
      height: 2rem;
  }
{% endstyle %}

{{ 'CWC_faq_utility.css' | asset_url | stylesheet_tag }}

<section id="CWC_faq_utility-{{ section.id }}" class="CWC_faq_utility">
  <div class="CWC_faq_utility-wrapper">
    {% if section.settings.featured_image != blank and section.settings.show_image %}
      {%- comment -%} Layout with featured image - two columns {%- endcomment -%}
      <div class="CWC_faq_utility-columns">
        <!-- Image Column -->
        <div class="CWC_faq_utility-image">
          <img
            src="{{ section.settings.featured_image | image_url }}"
            alt="{{ section.settings.featured_image.alt | default: 'FAQ Featured Image' }}"
            width="{{ section.settings.featured_image.width }}"
            height="{{ section.settings.featured_image.height }}"
            loading="lazy"
          >
        </div>

        <!-- Content Column -->
        <div class="CWC_faq_utility-content">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                {% if block.settings.text != blank %}
                  <div
                    style="
                      --title_color: {{ block.settings.title_color }};
                      --bold_color: {{ block.settings.bold_color }};
                    "
                    class="CWC_faq_utility-title"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              {% when 'subtext' %}
                {% if block.settings.text != blank %}
                  <div
                    style="--text_color: {{ block.settings.text_color }};"
                    class="CWC_faq_utility-subtext"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              {% when 'faq' %}
                <div class="CWC_faq_utility-item" {{ block.shopify_attributes }}>
                  <button class="faq-question" aria-expanded="false">
                    {{ block.settings.question }}
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    {{ block.settings.answer }}
                  </div>
                </div>

              {% when 'button' %}
                {% if block.settings.button_text != blank %}
                  <div class="CWC_faq_utility-button-wrap" {{ block.shopify_attributes }}>
                    <a
                      href="{{ block.settings.button_link }}"
                      class="CWC_faq_utility-button"
                      style="
                        --button_text_color: {{ block.settings.button_text_color }};
                        --button_bg_color: {{ block.settings.button_bg_color }};
                      "
                    >
                      {{ block.settings.button_text }}
                    </a>
                    {% if block.settings.button_note != blank %}
                      <div class="CWC_faq_utility-button-note">
                        {{ block.settings.button_note }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
      </div>

    {% else %}
      {%- comment -%} Layout without image - full width single column {%- endcomment -%}
      {%- comment -%} Layout without image - full width single column {%- endcomment -%}
      {%- comment -%} Layout without image - full width single column {%- endcomment -%}
      {%- comment -%} Layout without image - full width single column {%- endcomment -%}
      {%- comment -%} Layout without image - full width single column {%- endcomment -%}
      <div class="CWC_faq_utility-full">
        <div class="CWC_faq_utility-header">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                {% if block.settings.text != blank %}
                  <div
                    style="
                      --title_color: {{ block.settings.title_color }};
                      --bold_color: {{ block.settings.bold_color }};
                    "
                    class="CWC_faq_utility-title"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </div>
                {% endif %}

              {% when 'subtext' %}
                {% if block.settings.text != blank %}
                  <div
                    style="--text_color: {{ block.settings.text_color }};"
                    class="CWC_faq_utility-subtext"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.text }}
                  </div>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>

        <div class="CWC_faq_utility-items">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'faq' %}
                <div class="CWC_faq_utility-item" {{ block.shopify_attributes }}>
                  <button class="faq-question" aria-expanded="false">
                    {{ block.settings.question }}
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    {{ block.settings.answer }}
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>

        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'button' %}
              {% if block.settings.button_text != blank %}
                <div class="CWC_faq_utility-button-wrap" {{ block.shopify_attributes }}>
                  <a
                    href="{{ block.settings.button_link }}"
                    class="CWC_faq_utility-button"
                    style="
                      --button_text_color: {{ block.settings.button_text_color }};
                      --button_bg_color: {{ block.settings.button_bg_color }};
                    "
                  >
                    {{ block.settings.button_text }}
                  </a>
                  {% if block.settings.button_note != blank %}
                    <div class="CWC_faq_utility-button-note">
                      {% render 'CWC_icon-shield', fill: block.settings.button_bg_color %}
                      {{ block.settings.button_note }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{{ 'CWC_faq_utility.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC FAQ Utility",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured Image (Optional)",
      "info": "If added, creates a two-column layout. If left blank, FAQ spans full width."
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show Image",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "faq_bg_color",
      "label": "FAQ Item Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "faq_text_color",
      "label": "FAQ Item Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Title Text",
          "default": "<h3>Got Questions? <strong>We've Got Answers</strong></h3>"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#111111"
        },
        {
          "type": "color",
          "id": "bold_color",
          "label": "Bold Color",
          "default": "#D95F8E"
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Subtext",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Subtext Content",
          "default": "<p>Questions? Find that answer here OR read more on our FAQ's page.</p>"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#111111"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What's inside each scoop?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Each scoop contains premium ingredients carefully selected for maximum effectiveness and taste.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "CTA Button",
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#6DBF55"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "button_note",
          "label": "Button Note Text",
          "default": "120-Day Money-Back Guarantee"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "FAQ Utility",
      "category": "Custom",
      "blocks": [
        { "type": "title" },
        { "type": "subtext" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
