{% style %}
  #CWC_faqs-{{ section.id }} {
  --section-bg: {{ section.settings.bg_color }};
  --text-color: {{ section.settings.text_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  --faq-bg: {{ section.settings.faq_bg_color | default: '#ffffff' }};
  }
{% endstyle %}

{{ 'CWC_faqs.css' | asset_url | stylesheet_tag }}

<section id="CWC_faqs-{{ section.id }}" class="cwc-faqs">
  <div class="cwc-faqs__wrapper">
    {% if section.settings.heading != blank %}
      <div class="cwc-faqs__heading rte">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="cwc-faqs__text rte">
        {{ section.settings.text }}
      </div>
    {% endif %}

    <div class="cwc-faqs__items">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'faq' %}
            <div class="faq-item" {{ block.shopify_attributes }}>
              <button class="faq-question rte ">
                {{ block.settings.title }}
                <span class="toggle-icon">+</span>
              </button>
              <div class="faq-answer rte">
                {{ block.settings.text }}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'button' %}
          <div class="cwc-faqs__button" {{ block.shopify_attributes }}>
            {% render 'CWC_button', product: product, section_id: section.id, block: block %}
          </div>

        {% when 'guarantee_text' %}
          <div class="cwc-faqs__testimonials__note" {{ block.shopify_attributes }}>
            {% render 'CWC_guarantee_text', product: product, section_id: section.id, block: block %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{{ 'CWC_faqs.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC FAQs",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1d1d1d"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2><strong>Frequently Asked Questions</strong></h2>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Everything you need to know about Ollie and hydroxyapatite</p>"
    },
    {
      "type": "color",
      "id": "faq_bg_color",
      "label": "FAQ block background color",
      "default": "#FAF9F6"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "label": "Question",
          "default": "<p>What is your return policy?</p>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Answer",
          "default": "<p>We offer a 30-day return policy on all items.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#125657"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQs",
      "category": "Custom",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
