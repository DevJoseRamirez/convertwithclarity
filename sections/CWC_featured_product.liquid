{% style %}
  #CWC_featured_product-{{ section.id }} {
    --section-bg: {{ section.settings.background_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_featured_product.css' | asset_url | stylesheet_tag }}
{{ 'CWC_swiper-bundle.min.css' | asset_url | stylesheet_tag }}

{% if section.settings.product != blank %}
  {% assign product = section.settings.product %}
{% endif %}

<div id="cwc-featured-product--anchor"></div>
<section
  id="CWC_featured_product-{{ section.id }}"
  class="cwc-featured-product"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-variants="{{ product.variants | json | escape }}"
  data-selling-plans="{{ product.selling_plan_groups | json | escape }}"
  data-savings-display="{{ section.settings.savings_display_type }}"
>
  <div class="cwc-featured-product__wrapper">
    <div class="cwc-featured-product__grid">
      <!-- Left Column -->
      <div class="cwc-featured-product__left">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'product_image' %}
              <div class="cwc-featured-product__image" {{ block.shopify_attributes }}>
                {% render 'CWC_product_image', product: product, section_id: section.id, block: block %}
              </div>

            {% when 'image_carousel' %}
              <div class="cwc-featured-product__image_carousel" {{ block.shopify_attributes }}>
                {% render 'CWC_product_image_carousel', product: product, section_id: section.id, block: block %}
              </div>

            {% when 'faq' %}
              <div class="cwc-featured-product__faq desktop__only" {{ block.shopify_attributes }}>
                {% render 'CWC_faq_blocks', product: product, section_id: section.id, block: block %}
              </div>

            {% when 'review' %}
              <div class="cwc-featured-product__review desktop__only rte" {{ block.shopify_attributes }}>
                {% render 'CWC_block__review', product: product, section_id: section.id, block: block %}
              </div>
              {% comment %}
              {% endcomment %}
          {% endcase %}
        {% endfor %}
      </div>

      <!-- Right Column -->
      <div class="cwc-featured-product__right">
        {% assign product = section.settings.product %}
        {% if product %}
          <form
            action="/cart/add"
            method="post"
            enctype="multipart/form-data"
            class="cwc-featured-product__form"
            id="product-form-{{ section.id }}"
          >
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
              class="variant-id-input"
            >
            <input
              type="hidden"
              value=""
              name="selling_plan"
              class="selling-plan-input"
            >

            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'rating' %}
                  <div class="cwc-featured-product__rating" {{ block.shopify_attributes }}>
                    {% render 'CWC_prod_rating', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'vendor' %}
                  <div class="cwc-featured-product__vendor rte" {{ block.shopify_attributes }}>
                    {% if block.settings.vendor != blank %}
                      {{ block.settings.vendor }}
                    {% else %}
                      {{ product.vendor }}
                    {% endif %}
                  </div>

                {% when 'title' %}
                  <div class="cwc-featured-product__title rte" {{ block.shopify_attributes }}>
                    {% if block.settings.title != blank %}
                      {{ block.settings.title }}
                    {% elsif product.title != blank %}
                      {{ product.title }}
                    {% endif %}
                  </div>

                {% when 'desc' %}
                  <div class="cwc-featured-product__desc rte" {{ block.shopify_attributes }}>
                    {% if block.settings.desc != blank %}
                      {{ block.settings.desc }}
                    {% else %}
                      {{ product.description }}
                    {% endif %}
                  </div>

                {% when 'text' %}
                  <div class="cwc-featured-product__text rte" {{ block.shopify_attributes }}>
                    {{ block.settings.content }}
                  </div>

                {% when 'benefits' %}
                  <div class="cwc-featured-product__benefits" {{ block.shopify_attributes }}>
                    {% render 'CWC_benefits', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'price_display' %}
                  <div
                    class="
                      cwc-featured-product__price
                      {% if product.compare_at_price and product.compare_at_price > product.price %}show_save{% endif %}
                    "
                    {{ block.shopify_attributes }}
                  >
                    {% render 'CWC_price_display', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'product_options_size' %}
                  {% if product.variants.size > 1 %}
                    <div class="cwc-featured-product__options_size" {{ block.shopify_attributes }}>
                      {% render 'CWC_product_options_size', product: product, section_id: section.id, block: block %}
                    </div>
                  {% endif %}

                {% when 'product_options_type' %}
                  {% if product.variants.size > 1 %}
                    {% capture block_styles %}
                      --optionType-bg1: {{ '#06cbcd' | color_modify: 'alpha', 0.10 }};
                      --optionType-bg2: {{ '#e5433d' | color_modify: 'alpha', 0.10 }};
                      {% endcapture %}
                    <div class="cwc-featured-product__options_type" {{ block.shopify_attributes }}>
                      {% render 'CWC_product_options_type',
                        product: product,
                        section_id: section.id,
                        block: block,
                        block_styles: block_styles
                      %}

                      {% comment %}
                        background: {{ '#e5433d' | color_modify: 'alpha', 0.13 }};
                      {% endcomment %}
                    </div>
                  {% endif %}

                {% when 'subscription_toggle' %}
                  {% if product.selling_plan_groups.size > 0 %}
                    <div class="cwc-featured-product__subscription" {{ block.shopify_attributes }}>
                      {% render 'CWC_product_selling_plans', product: product, section_id: section.id, block: block %}
                    </div>
                  {% endif %}

                {% when 'delivery_estimate' %}
                  <div class="cwc-featured-product__delivery" {{ block.shopify_attributes }}>
                    {% render 'CWC_delivery_estimate', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'add_to_cart' %}
                  <div class="cwc-featured-product__add_to_cart" {{ block.shopify_attributes }}>
                    {% render 'CWC_add_to_cart', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'guarantee_text' %}
                  <div class="cwc-featured-product__guarantee_text" {{ block.shopify_attributes }}>
                    {% render 'CWC_guarantee_text', product: product, section_id: section.id, block: block %}
                  </div>

                {% when 'faq' %}
                  <div class="cwc-featured-product__faq mobile__only" {{ block.shopify_attributes }}>
                    {% render 'CWC_faq_blocks', product: product, section_id: section.id, block: block %}
                  </div>
              {% endcase %}
            {% endfor %}
          </form>

          {{ 'CWC_featured_product.js' | asset_url | script_tag }}
          {{ 'CWC_featured_product__add_to_cart.js' | asset_url | script_tag }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

