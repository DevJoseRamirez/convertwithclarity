{% style %}
  #cwc_final-cta-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#0a0a0a' }};
    --text-color: {{ section.settings.text_color | default: '#ffffff' }};
    --highlight-color: {{ section.settings.bold_color | default: '#14a800' }};
    --subtext-color: {{ section.settings.subtext_color | default: '#b8b8b8' }};
    --button-bg: {{ section.settings.button_bg | default: '#14a800' }};
    --button-text: {{ section.settings.button_text | default: '#ffffff' }};
    --scarcity-bg: {{ section.settings.scarcity_bg | default: '#1a1a1a' }};
    --scarcity-text-color: {{ section.settings.scarcity_text_color | default: '#ffffff' }};
    --scarcity-dot-color: {{ section.settings.scarcity_dot_color | default: '#14a800' }};
    --padding-top: {{ section.settings.padding_top | default: 120 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 120  | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 80 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_final_cta.css' | asset_url | stylesheet_tag }}

<section id="cwc_final-cta-{{ section.id }}" class="cwc_final-cta">
  <div class="cwc_final-cta-spotlight cwc-left">top left</div>
  <div class="cwc_final-cta-spotlight cwc-right">bottom right</div>

  <div class="cwc_final-cta__container">
    <div class="cwc_final-cta__inner">
      {% if section.settings.eyebrow != blank %}
        <div class="cwc_final-cta__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}

      {% if section.settings.scarcity_text != blank %}
        <div class="cwc_final-cta__scarcity">
          <span class="cwc_final-cta__scarcity-dot" aria-hidden="true">
            <span class="cwc_final-cta__scarcity-dot-pulse"></span>
            <span class="cwc_final-cta__scarcity-dot-core"></span>
          </span>
          <span class="cwc_final-cta__scarcity-text">{{ section.settings.scarcity_text }}</span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="cwc_final-cta__content-heading rte">
          {{ section.settings.heading }}
        </div>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <div class="cwc_final-cta__content-subtext rte">
          {{ section.settings.subtext }}
        </div>
      {% endif %}

      {% if section.settings.bullet_text != blank %}
        <div class="cwc_final-cta__content-bullet_content rte">
          <div class="cwc_final-cta__content-bullet_content-title rte">
            {{ section.settings.bullet_title }}
          </div>
          <div class="cwc_final-cta__content-bullet_content-bullets rte">
            {{ section.settings.bullet_text }}
          </div>
        </div>
      {% endif %}
      {% if section.settings.ps_text != blank %}
        <div class="cwc_final-cta__ps-text">
          {{ section.settings.ps_text }}
        </div>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="cwc_final-cta__button"
          {% if section.settings.cta_new_tab %}
            target="_blank" rel="noopener"
          {% endif %}
        >
          <span class="cwc_final-cta__button-label">{{ section.settings.cta_label }}</span>
          <svg class="cwc_final-cta__button-arrow" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Final CTA",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "info": "Leave blank to hide.",
      "default": "06 / Let's Talk"
    },
    {
      "type": "text",
      "id": "scarcity_text",
      "label": "Scarcity Line",
      "info": "Optional. Shows above the heading with a pulsing dot. Leave blank to hide. Only use if true.",
      "default": "Currently taking on 2 new clients this month"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap any words you want accented in <strong> tags.",
      "default": "<p>Ready to see what your store is <strong>actually capable of?</strong></p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Send me a message on Upwork. I'll take a look at your store, tell you straight whether I think I can help, and what I'd focus on first. No fluff, no upsell — just a real answer.</p>"
    },
    {
      "type": "richtext",
      "id": "bullet_title",
      "label": "Bullet Title"
    },
    {
      "type": "richtext",
      "id": "bullet_text",
      "label": "Bullet text"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Message Me on Upwork"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open in new tab",
      "default": true
    },
    {
      "type": "richtext",
      "id": "ps_text",
      "label": "PS Text",
      "default": "<p>I keep my client roster small on purpose — I'd rather move the number for a few brands than be average for many. If you're serious about fixing your conversion, now's the time to reach out.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Heading Highlight Color",
      "default": "#14a800"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#b8b8b8"
    },
    {
      "type": "header",
      "content": "Button Colors"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#14a800"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Scarcity Pill Colors"
    },
    {
      "type": "color",
      "id": "scarcity_bg",
      "label": "Pill Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "scarcity_text_color",
      "label": "Pill Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "scarcity_dot_color",
      "label": "Pill Dot Color",
      "default": "#14a800"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "CWC Final CTA",
      "category": "CWC Custom"
    }
  ]
}
{% endschema %}
