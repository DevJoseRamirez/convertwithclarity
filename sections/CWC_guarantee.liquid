{% style %}
  #cwc_guarantee-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: 'transparent' }};
    --inner-bg: {{ section.settings.inner_bg | default: '#0A0A0A' }};
    --inner-radius: {{ section.settings.inner_radius | default: 24 }}px;
    --inner-padding-y: {{ section.settings.inner_padding_y | default: 80 }}px;
    --inner-max-width: {{ section.settings.inner_max_width | default: 1200 }}px;
    --text-color: {{ section.settings.text_color | default: '#FFFFFF' }};
    --highlight-color: {{ section.settings.bold_color | default: '#FEC42D' }};
    --subtext-color: {{ section.settings.subtext_color | default: '#D8D8D8' }};
    --check-color: {{ section.settings.check_color | default: '#FEC42D' }};
    --card-bg: {{ section.settings.card_bg | default: '#8080801a' }};
    --card-title-color: {{ section.settings.card_title_color | default: '#FFFFFF' }};
    --card-bullet-color: {{ section.settings.card_bullet_color | default: '#D8D8D8' }};
    --spotlight-color: {{ section.settings.spotlight_color | default: '#FEC42D' }};
    --spotlight-opacity: {{ section.settings.spotlight_opacity | default: 35 | divided_by: 100.0 }};
    --cta-bg: {{ section.settings.cta_bg | default: '#E53935' }};
    --cta-bg-hover: {{ section.settings.cta_bg_hover | default: '#C62828' }};
    --cta-text: {{ section.settings.cta_text | default: '#FFFFFF' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 60 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 60 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_guarantee.css' | asset_url | stylesheet_tag }}

<section id="cwc_guarantee-{{ section.id }}" class="cwc_guarantee">
  <div class="cwc_guarantee__container">
    <div class="cwc_guarantee__inner">
      {% if section.settings.show_spotlights %}
        <div class="cwc_guarantee__spotlight cwc_guarantee__spotlight--top-left" aria-hidden="true">c</div>
        <div class="cwc_guarantee__spotlight cwc_guarantee__spotlight--bottom-right" aria-hidden="true">d</div>
      {% endif %}

      <div class="cwc_guarantee__content">
        {% if section.settings.eyebrow != blank %}
          <div class="cwc_guarantee__eyebrow">{{ section.settings.eyebrow }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="cwc_guarantee__content-heading rte">
            {{ section.settings.heading }}
          </div>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <div class="cwc_guarantee__content-subtext rte">
            {{ section.settings.subtext }}
          </div>
        {% endif %}

        {% if section.settings.bullet_title != blank %}
          <div class="cwc_guarantee__bullet-card">
            <div class="cwc_guarantee__bullet-card-title">
              {{ section.settings.bullet_title }}
            </div>

            {% if section.settings.bullets != blank %}
              <div class="cwc_guarantee__bullet-card-bullets rte">
                {{ section.settings.bullets }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.show_cta and section.settings.cta_label != blank %}
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="cwc_guarantee__cta"
            {% if section.settings.cta_new_tab %}
              target="_blank" rel="noopener"
            {% endif %}
          >
            <span class="cwc_guarantee__cta-label">{{ section.settings.cta_label }}</span>
            <svg class="cwc_guarantee__cta-arrow" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
     
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Guarantee",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "info": "Optional. Leave blank to hide."
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap accent words in <strong> tags.",
      "default": "<p>Our 60-Day <strong>Satisfaction Guarantee</strong></p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "info": "Renders italic below the heading.",
      "default": "<p>We are so confident in your success that we offer a 60-day money-back satisfaction guarantee. Simply put: either you love it, or we refund your money.</p>"
    },
    {
      "type": "header",
      "content": "Bullet Card"
    },
    {
      "type": "text",
      "id": "bullet_title",
      "label": "Bullet card title",
      "default": "Here's how it works:"
    },
    {
      "type": "richtext",
      "id": "bullets",
      "label": "Bullets",
      "info": "Each list item gets a ✓ prefix automatically.",
      "default": "<ul><li>Commit to following our step-by-step system and taking consistent action</li><li>If, within 60 days, you're not satisfied and believe the program hasn't delivered the value we promise, request a full refund</li><li>Our guarantee removes any risk for you — your success is our success</li></ul>"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Book Your Free Strategy Call Now - Limited Spots Available"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "CTA Background",
      "default": "#E53935"
    },
    {
      "type": "color",
      "id": "cta_bg_hover",
      "label": "CTA Background (hover)",
      "default": "#C62828"
    },
    {
      "type": "color",
      "id": "cta_text",
      "label": "CTA Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "inner_radius",
      "label": "Inner box corner radius",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "inner_padding_y",
      "label": "Inner box vertical padding",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "inner_max_width",
      "label": "Inner box max width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Spotlights"
    },
    {
      "type": "checkbox",
      "id": "show_spotlights",
      "label": "Show corner spotlights",
      "default": true
    },
    {
      "type": "color",
      "id": "spotlight_color",
      "label": "Spotlight Color",
      "default": "#FEC42D"
    },
    {
      "type": "range",
      "id": "spotlight_opacity",
      "label": "Spotlight Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Outer Section Background",
      "info": "Color around the rounded inner box. Match your page background.",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "inner_bg",
      "label": "Inner Box Background",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Heading Highlight Color",
      "default": "#FEC42D"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#D8D8D8"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Checkmark (✓) Color",
      "default": "#FEC42D"
    },
    {
      "type": "header",
      "content": "Bullet Card Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background (frosted)",
      "info": "Use a low-alpha color (e.g. rgba) for the glass effect.",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bullet_color",
      "label": "Card Bullet Text Color",
      "default": "#D8D8D8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "CWC Guarantee",
      "category": "CWC Custom"
    }
  ]
}
{% endschema %}
