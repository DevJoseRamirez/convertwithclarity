{% style %}
  #CWC_hero-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --horizontal-alignment: {{ section.settings.horizontal_alignment }};
  --vertical-offset: {{ section.settings.vertical_offset }}rem;
  --section-text-color: {{ section.settings.text_color }};
  }
{% endstyle %}

{{ 'CWC_hero.css' | asset_url | stylesheet_tag }}

<section id="CWC_hero-{{ section.id }}" class="CWC_hero CWC_hero-{{ section.id }}">
  <div class="CWC_hero-image">
    <img src="{{ section.settings.background_image | image_url }}" alt="" class="desktop-img" loading="eager">
    <img src="{{ section.settings.mobile_background_image | image_url }}" alt="" class="mobile-img" loading="eager">
  </div>

  <div class="CWC_hero-wrapper">
    <div class="CWC_hero-inner">
      <div class="cwc_hero-content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'star_rating' and block.settings.text != blank %}
              <div
                class="cwc_hero-stars"
                {{ block.shopify_attributes }}
                style="max-width: {{ block.settings.max_width }}px;"
              >
                <span class="cwc_hero-stars-wrap">
                  {% for i in (1..5) %}
                    <svg
                      class="cwc_hero-star"
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="17"
                      viewBox="0 0 18 17"
                      fill="none"
                    >
                      <path
                          d="M8.62838 1.04894C8.83792 0.404019 9.75031 0.404018 9.95986 1.04894L11.4481 5.62937C11.5418 5.91779 11.8106 6.11306 12.1139 6.11306H16.93C17.6081 6.11306 17.8901 6.98079 17.3415 7.37937L13.4451 10.2102C13.1998 10.3885 13.0971 10.7044 13.1908 10.9929L14.6791 15.5733C14.8887 16.2182 14.1505 16.7545 13.6019 16.3559L9.70557 13.5251C9.46023 13.3468 9.12801 13.3468 8.88267 13.5251L4.98632 16.3559C4.43772 16.7545 3.69958 16.2182 3.90913 15.5733L5.3974 10.9929C5.49111 10.7044 5.38845 10.3885 5.14311 10.2102L1.24676 7.37937C0.69816 6.98079 0.980102 6.11306 1.65821 6.11306H6.47436C6.77762 6.11306 7.04639 5.91779 7.1401 5.62937L8.62838 1.04894Z"
                          fill="{{ block.settings.star_color }}" />
                    </svg>
                  {% endfor %}
                </span>

                <span class="star-text">{{ block.settings.text }}</span>
              </div>

            {% when 'headline' %}
              <h1
                class="cwc_hero-headline"
                {{ block.shopify_attributes }}
                style="max-width: {{ block.settings.max_width }}px;"
              >
                {{ block.settings.text }}
              </h1>

            {% when 'subtext' %}
              <div
                class="cwc_hero-subtext"
                {{ block.shopify_attributes }}
                style="max-width: {{ block.settings.max_width }}px;"
              >
                {{ block.settings.text }}
              </div>

            {% when 'cta_button' %}
              <a
                href="{{ block.settings.link }}"
                class="cwc_hero-button"
                {{ block.shopify_attributes }}
                style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}"
              >
                {{ block.settings.text }}
                <span class="promo-button-arrow">
                  {% render 'icon-arrow', fill: '#ffffff' %}
                </span>
              </a>

            {% when 'testimonial' %}
              <div
                class="cwc_hero-testimonial"
                {{ block.shopify_attributes }}
                style="max-width: {{ block.settings.max_width }}px;"
              >
                {% if block.settings.image != blank %}
                  <div class="testimonial-avatar">
                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.author }}">
                  </div>
                {% endif %}
                <div class="testimonial-copy">
                  {% if block.settings['show-stars'] %}
                    <div class="testimonial-star-wrap" style="color: {{ block.settings.star_color }}">
                      {% for i in (1..5) %}
                        <svg
                          class="cwc_hero-star"
                          xmlns="http://www.w3.org/2000/svg"
                          width="18"
                          height="17"
                          viewBox="0 0 18 17"
                          fill="none"
                        >
                          <path
                              d="M8.62838 1.04894C8.83792 0.404019 9.75031 0.404018 9.95986 1.04894L11.4481 5.62937C11.5418 5.91779 11.8106 6.11306 12.1139 6.11306H16.93C17.6081 6.11306 17.8901 6.98079 17.3415 7.37937L13.4451 10.2102C13.1998 10.3885 13.0971 10.7044 13.1908 10.9929L14.6791 15.5733C14.8887 16.2182 14.1505 16.7545 13.6019 16.3559L9.70557 13.5251C9.46023 13.3468 9.12801 13.3468 8.88267 13.5251L4.98632 16.3559C4.43772 16.7545 3.69958 16.2182 3.90913 15.5733L5.3974 10.9929C5.49111 10.7044 5.38845 10.3885 5.14311 10.2102L1.24676 7.37937C0.69816 6.98079 0.980102 6.11306 1.65821 6.11306H6.47436C6.77762 6.11306 7.04639 5.91779 7.1401 5.62937L8.62838 1.04894Z"
                              fill="{{ block.settings.star_color }}" />
                        </svg>
                      {% endfor %}
                    </div>
                  {% endif %}

                  <p class="testimonial-text">{{ block.settings.text }}</p>
                  <div class="testimonial-author">- {{ block.settings.author }}</div>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Global Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontal Content Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "vertical_offset",
      "label": "Vertical Offset (Top)",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "rem",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "star_rating",
      "name": "Star Rating",
      "settings": [
        {
          "type": "color",
          "id": "star_color",
          "label": "Star Color",
          "default": "#FF9736"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Rating Text",
          "default": "Rated 4.9/5 on 250+ Healthy Customers"
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max Width (px)",
          "min": 300,
          "max": 900,
          "step": 20,
          "default": 700
        }
      ]
    },
    {
      "type": "headline",
      "name": "Headline",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Headline Text",
          "default": "Feel Stronger, Clearer, and More Resilient Every Day"
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max Width (px)",
          "min": 300,
          "max": 900,
          "step": 20,
          "default": 700
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Subtext",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Subtext",
          "default": "<p>Potent adaptogens and wild-grown functional mushrooms designed to sharpen focus and restore without.</p>"
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max Width (px)",
          "min": 300,
          "max": 900,
          "step": 20,
          "default": 600
        }
      ]
    },
    {
      "type": "cta_button",
      "name": "Call to Action Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Try ENRICHD Today →"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Button Background Color",
          "default": "#FF6A3D"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Button Text Color",
          "default": "#FFFFFF"
        }
      ]
    },

    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Image"
        },
        {
          "type": "color",
          "id": "star_color",
          "label": "Star Color",
          "default": "#FF9736"
        },
        {
          "type": "checkbox",
          "id": "show-stars",
          "label": "Show Stars",
          "default": true
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Text",
          "default": "I’ve trusted this brand to support my health and wellbeing for several years.."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Jane Doe"
        },
        {
          "type": "range",
          "id": "max_width",
          "label": "Max Width (px)",
          "min": 300,
          "max": 900,
          "step": 20,
          "default": 500
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CWC Hero",
      "category": "Custom",
      "blocks": [
        { "type": "star_rating" },
        { "type": "headline" },
        { "type": "subtext" },
        { "type": "cta_button" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
