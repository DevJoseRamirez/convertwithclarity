{% style %}
  #CWC_hero_overlay-{{ section.id }} {
  --gradient-custom: linear-gradient(
  90deg,
  {{ section.settings.gradient_start | color_modify: 'alpha', section.settings.gradient_start_opacity }} 35.58%,
  {{ section.settings.gradient_end | color_modify: 'alpha', section.settings.gradient_end_opacity }} 70.67%
  );
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  --benefit-bg: {{ section.settings.benefit_bg }};
  --benefit-text: {{ section.settings.benefit_text }};
  }
{% endstyle %}

{{ 'CWC_hero_overlay.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_hero_overlay-{{ section.id }}"
  class="CWC_hero_overlay hero_overlay-{{ section.id }} height-{{ section.settings.image_height }}"
>
  <div class="CWC_hero_overlay-image-wrapper">
    {% if section.settings.mobile_image %}
      <img
        fetchpriority="high"
        loading="eager"
        src="{{ section.settings.mobile_image | image_url }}"
        alt="Mobile Hero Image"
        class="CWC_hero_overlay-image mobile-only"
      >
    {% endif %}

    {% if section.settings.image %}
      <img
        fetchpriority="high"
        loading="eager"
        src="{{ section.settings.image | image_url }}"
        alt="Desktop Hero Image"
        class="CWC_hero_overlay-image desktop-only"
      >
    {% endif %}
  </div>

  {% if section.settings.show_overlay %}
    <div class="CWC_hero_overlay-gradient"></div>
  {% endif %}

  <div
    class="
      CWC_hero_overlay-inner
      align-vertical-{{ section.settings.content_position_vertical }}
      align-horizontal-{{ section.settings.content_position_horizontal }}
    "
  >
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'headline' %}
          <h2 class="CWC_hero_overlay-headline" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
        {% when 'subtext' %}
          <div class="CWC_hero_overlay-subtext" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
        {% when 'button' %}
          <a
            href="{{ block.settings.link }}"
            class="CWC_hero_overlay-button"
            {{ block.shopify_attributes }}
            style="background-color: {{ block.settings.button_color }}; color: {{ block.settings.button_text_color }};"
          >
            {{ block.settings.text }}
          </a>
        {% when 'benefits' %}
          <div class="CWC_hero_overlay-benefits" {{ block.shopify_attributes }}>
            {% for i in (1..5) %}
              {% assign key = 'text_' | append: i %}
              {% if block.settings[key] != blank %}
                <div class="CWC_hero_overlay-benefit">
                  <span class="CWC_hero_overlay-check">{% render 'icon-checkmark' %}</span>
                  <span class="CWC_hero_overlay-benefit-text">{{ block.settings[key] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Overlay",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Background Image (optional)"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Image Height",
      "default": "natural",
      "options": [
        { "value": "natural", "label": "Natural Image Aspect Ratio" },
        { "value": "full_screen", "label": "Full Screen (100vh)" },
        { "value": "large", "label": "Large (80vh)" },
        { "value": "medium", "label": "Medium (60vh)" }
      ]
    },
    {
      "type": "select",
      "id": "content_position_vertical",
      "label": "Vertical Content Alignment",
      "default": "center",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "content_position_horizontal",
      "label": "Horizontal Content Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Gradient",
      "default": true
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient Start Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient End Color",
      "default": "#3a3a3a"
    },
    {
      "type": "range",
      "id": "gradient_start_opacity",
      "label": "Start Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.8
    },
    {
      "type": "range",
      "id": "gradient_end_opacity",
      "label": "End Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "benefit_bg",
      "label": "Benefit Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "benefit_text",
      "label": "Benefit Text Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "headline",
      "name": "Headline",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Headline Text",
          "default": "This one bag handles it all — and actually looks good doing it."
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Subtext",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Subtext",
          "default": "<p>Because not everyone wants 83 pocket layouts or a solar charger. Some of us just want something tha.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Call to Action Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Get Your Own Great F*cking Bag"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button Background Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#000000"
        }
      ]
    },
    {
      "type": "benefits",
      "name": "Benefit Highlights",
      "settings": [
        {
          "type": "text",
          "id": "text_1",
          "label": "Benefit #1"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "Benefit #2"
        },
        {
          "type": "text",
          "id": "text_3",
          "label": "Benefit #3"
        },
        {
          "type": "text",
          "id": "text_4",
          "label": "Benefit #4"
        },
        {
          "type": "text",
          "id": "text_5",
          "label": "Benefit #5"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Overlay",
      "category": "Custom",
      "blocks": [{ "type": "headline" }, { "type": "subtext" }, { "type": "button" }, { "type": "benefits" }]
    }
  ]
}
{% endschema %}
