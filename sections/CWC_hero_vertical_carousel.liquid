{%- liquid
  assign column_count = section.settings.column_count | default: 2 | plus: 0
  assign skew_angle = section.settings.skew_angle | default: -12
  assign scroll_duration = section.settings.scroll_duration | default: 40
  assign image_radius = section.settings.image_radius | default: 12
  assign image_gap = section.settings.image_gap | default: 16
  assign opposing = section.settings.opposing_directions
-%}

{% style %}
  #cwc_hero-vertical-carousel-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#FFFFFF' }};
    --text-color: {{ section.settings.text_color | default: '#0A0A0A' }};
    --highlight-color: {{ section.settings.bold_color | default: '#14a800' }};
    --button-bg: {{ section.settings.button_bg | default: '#14a800' }};
    --button-text: {{ section.settings.button_text | default: '#FFFFFF' }};
    --media-bg: {{ section.settings.media_bg | default: '#F5F5F0' }};
    --carousel-skew: {{ skew_angle }}deg;
    --carousel-duration: {{ scroll_duration }}s;
    --carousel-image-radius: {{ image_radius }}px;
    --carousel-image-gap: {{ image_gap }}px;
    --carousel-columns: {{ column_count }};
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 80 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 80 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_hero_vertical_carousel.css' | asset_url | stylesheet_tag }}

{% if section.settings.bg_image %}
  <div class="cwc_hero-vertical-carousel_texture-wrap">
    {{
      section.settings.bg_image
      | image_url: width: 600
      | image_tag:
        class: 'cwc_hero-vertical-carousel_texture-bg',
        widths: widths,
        height: logo_height,
        width: logo_width,
        alt: logo_alt,
        sizes: sizes,
        preload: true
    }}
  </div>
{% endif %}

<section id="cwc_hero-vertical-carousel-{{ section.id }}" class="cwc_hero-vertical-carousel">
  <div class="cwc_hero-vertical-carousel__container">
    <div class="cwc_hero-vertical-carousel__grid">
      {% comment %} ==== Copy Column (mirrors hero_vsl) ==== {% endcomment %}
      <div class="cwc_hero-vertical-carousel__copy">
        {% if section.settings.eyebrow != blank %}
          <div class="cwc_hero-vertical-carousel__eyebrow cwc-rte">{{ section.settings.eyebrow }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="cwc_hero-vertical-carousel__content-heading cwc-rte">
            {{ section.settings.heading }}
          </div>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <div class="cwc_hero-vertical-carousel__content-subtext cwc-rte">
            {{ section.settings.subtext }}
          </div>
        {% endif %}

        {% render 'CWC_item-vertical-carousel',
          section: section,
          blocks: section.blocks,
          view: 'cwc_mobile-view',
          column_count: column_count,
          skew_angle: skew_angle,
          scroll_duration: scroll_duration,
          image_radius: image_radius,
          image_gap: image_gap,
          opposing: opposing
        %}

        {% if section.settings.cta_label != blank %}
          <div class="cwc_hero-vertical-carousel__cta">
            <a
              href="{{ section.settings.cta_url | default: '#' }}"
              class="cwc_hero-vertical-carousel__button cwc_desktop-view"
              {% if section.settings.cta_new_tab %}
                target="_blank" rel="noopener"
              {% endif %}
            >
              <span class="cwc_hero-vertical-carousel__button-label">{{ section.settings.cta_label }}</span>
              <svg
                class="cwc_hero-vertical-carousel__button-arrow"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <a
              href="{{ section.settings.cta_url | default: '#' }}"
              class="cwc_hero-vertical-carousel__button cwc_mobile-view"
              {% if section.settings.cta_new_tab %}
                target="_blank" rel="noopener"
              {% endif %}
            >
              <span class="cwc_hero-vertical-carousel__button-label">Message Me on Upwork</span>
              <svg
                class="cwc_hero-vertical-carousel__button-arrow"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            {% comment %} social proof {% endcomment %}
            <div class="cwc_hero-vertical-carousel__social-proof-container">
              {% if section.settings.social_proof_image %}
                <div class="cwc_hero-vertical-carousel__social-proof-image">
                  {{
                    section.settings.social_proof_image
                    | image_url: width: 150
                    | image_tag:
                      class: 'cwc_hero-vertical-carousel__social-proof-img',
                      widths: '120, 180, 240, 360, 480',
                      sizes: '240px',
                      alt: '',
                      loading: 'lazy'
                  }}
                </div>
              {% endif %}

              {% comment %} upwork proof {% endcomment %}
              <div class="cwc_hero-vertical-carousel__social-proof_content-wrap">
                <div class="cwc_hero-vertical-carousel__social-proof-stars">
                  {% render 'CWC_icon-upwork_5_star' %}
                </div>
                <div class="cwc_hero-vertical-carousel__social-proof-text">
                  {% if section.settings.trust_text != blank %}
                    <div class="cwc_hero-vertical-carousel__trust cwc-rte">{{ section.settings.trust_text }}</div>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="cwc_hero-vertical-carousel__upwork-badge-container">
              <div class="cwc_hero-vertical-carousel__upwork-badge-wrap">
                <div class="cwc_hero-vertical-carousel__upwork-badge--icon">
                  {% render 'CWC_icon-upwork_job_success' %}
                </div>
                <div class="cwc_hero-vertical-carousel__upwork-badge--label">100% Job Success</div>
              </div>
              <div class="cwc_hero-vertical-carousel__upwork-badge-wrap">
                <div class="cwc_hero-vertical-carousel__upwork-badge--icon">
                  {% render 'CWC_icon-upwork_top_rated' %}
                </div>
                <div class="cwc_hero-vertical-carousel__upwork-badge--label">Top Rated</div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      {% render 'CWC_item-vertical-carousel',
        section: section,
        blocks: section.blocks,
        view: 'cwc_desktop-view',
        column_count: column_count,
        skew_angle: skew_angle,
        scroll_duration: scroll_duration,
        image_radius: image_radius,
        image_gap: image_gap,
        opposing: opposing
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Hero Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "richtext",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "<p>SHOPIFY · CRO · CUSTOM SECTIONS</p>"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h1>Turn your store into a <strong>conversion machine.</strong></h1>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Custom Shopify sections, conversion audits, and theme work for DTC consumer brands.</p>"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Book a free strategy call"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Social Proof"
    },
    {
      "type": "image_picker",
      "id": "social_proof_image",
      "label": "Social Proof Logo (Upwork etc.)"
    },
    {
      "type": "richtext",
      "id": "trust_text",
      "label": "Trust Text",
      "default": "<p>Top Rated · 4.9★ across 31 reviews</p>"
    },
    {
      "type": "header",
      "content": "Vertical Carousel"
    },
    {
      "type": "range",
      "id": "column_count",
      "label": "Number of columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "opposing_directions",
      "label": "Opposing scroll directions",
      "info": "Column 2 scrolls down while columns 1 & 3 scroll up. Adds visual interest.",
      "default": true
    },
    {
      "type": "range",
      "id": "skew_angle",
      "label": "Skew angle",
      "min": -25,
      "max": 25,
      "step": 1,
      "unit": "deg",
      "default": -12
    },
    {
      "type": "range",
      "id": "scroll_duration",
      "label": "Scroll loop duration",
      "info": "Lower = faster scroll. Total time for one full loop of the image set.",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "s",
      "default": 40
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Highlight (bold) Color",
      "default": "#14a800"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#14a800"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "media_bg",
      "label": "Carousel Background",
      "info": "Color behind the scrolling images.",
      "default": "#F5F5F0"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Carousel Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Portrait orientation (3:4 or 4:5) works best."
        },
        {
          "type": "select",
          "id": "column",
          "label": "Column",
          "options": [
            { "value": "1", "label": "Column 1" },
            { "value": "2", "label": "Column 2" },
            { "value": "3", "label": "Column 3" }
          ],
          "default": "1"
        }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Hero Carousel",
      "category": "CWC Custom",
      "blocks": [
        { "type": "image", "settings": { "column": "1" } },
        { "type": "image", "settings": { "column": "1" } },
        { "type": "image", "settings": { "column": "1" } },
        { "type": "image", "settings": { "column": "1" } },
        { "type": "image", "settings": { "column": "2" } },
        { "type": "image", "settings": { "column": "2" } },
        { "type": "image", "settings": { "column": "2" } },
        { "type": "image", "settings": { "column": "2" } }
      ]
    }
  ]
}
{% endschema %}
