{% comment %}
  Section: CWC_image_bullets_compare
  Side-by-side visual comparison of your product vs. a competitor with image blocks and pill-style bullets.
{% endcomment %}

{% style %}
  #cwc_image_bullets_compare-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --text-color: {{ section.settings.text_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --brand-bullet-bg: {{ section.settings.brand_bullet_bg }};
  --brand-bullet-text: {{ section.settings.brand_bullet_text }};
  --competitor-bullet-bg: {{ section.settings.competitor_bullet_bg }};
  --competitor-bullet-text: {{ section.settings.competitor_bullet_text }};
  }
{% endstyle %}

{{ 'CWC_image_bullets_compare.css' | asset_url | stylesheet_tag }}

<div
  id="cwc_image_bullets_compare-{{ section.id }}"
  class="cwc_image_bullets_compare cwc_image_bullets_compare-{{ section.id }}"
>
  <div class="cwc_image_bullets_compare-wrapper">
    <div class="cwc_image_bullets_compare-inner">
      {% if section.settings.title or section.settings.subtext %}
        <div class="compare-header">
          {% if section.settings.title %}
            <h2 class="compare-title" style="color: {{ section.settings.title_color }};">
              {{ section.settings.title }}
            </h2>
          {% endif %}
          {% if section.settings.subtext %}
            <div class="compare-subtext">
              {{ section.settings.subtext }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="compare-columns">
        <!-- BRAND COLUMN -->
        <div class="compare-column brand">
          <div class="compare-image">
            {% if section.settings.brand_image %}
              <div class="compare-vs-badge">vs</div>
              <img src="{{ section.settings.brand_image | image_url }}" alt="Brand Image">
            {% else %}
              <img src="{{ 'placeholder.png' | asset_url }}" alt="Placeholder image">
            {% endif %}
          </div>
          <div class="compare-bullets brand">
            {% for block in section.blocks %}
              <div class="compare-bullet" {{ block.shopify_attributes }}>
                <div class="bullet-icon">{% render 'check-icon' %}</div>
                <div class="bullet-text">{{ block.settings.brand_text }}</div>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- VS BADGE -->

        <!-- COMPETITOR COLUMN -->
        <div class="compare-column competitor">
          <div class="compare-image">
            {% if section.settings.competitor_image %}
              <img src="{{ section.settings.competitor_image | image_url }}" alt="Competitor Image">
            {% else %}
              <img src="{{ 'placeholder.png' | asset_url }}" alt="Placeholder image">
            {% endif %}
          </div>
          <div class="compare-bullets competitor">
            {% for block in section.blocks %}
              <div class="compare-bullet" {{ block.shopify_attributes }}>
                <div class="bullet-icon">{% render 'x-icon' %}</div>
                <div class="bullet-text">{{ block.settings.competitor_text }}</div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Bullets Compare",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Our Product vs. Other Brands"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Why customers choose us over the rest.</p>"
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Your Product Image"
    },
    {
      "type": "image_picker",
      "id": "competitor_image",
      "label": "Competitor Product Image"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Text Color",
      "default": "#D67941"
    },
    {
      "type": "color",
      "id": "brand_bullet_bg",
      "label": "Brand Bullet Background",
      "default": "#D67941"
    },
    {
      "type": "color",
      "id": "brand_bullet_text",
      "label": "Brand Bullet Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "competitor_bullet_bg",
      "label": "Competitor Bullet Background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "competitor_bullet_text",
      "label": "Competitor Bullet Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 40,
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "bullet_row",
      "name": "Bullet Row",
      "settings": [
        {
          "type": "text",
          "id": "brand_text",
          "label": "Brand Bullet Text",
          "default": "natural fruit flavors"
        },
        {
          "type": "text",
          "id": "competitor_text",
          "label": "Competitor Bullet Text",
          "default": "natural fruit flavors"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Bullets Compare",
      "category": "Custom",
      "blocks": [{ "type": "bullet_row" }, { "type": "bullet_row" }, { "type": "bullet_row" }, { "type": "bullet_row" }]
    }
  ]
}
{% endschema %}
