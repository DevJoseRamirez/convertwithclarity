{% style %}
  #CWC_image_highlight-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --title-color: {{ section.settings.title_color }};
  --highlight-color: {{ section.settings.bold_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.6 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.6 }}px;
  }
{% endstyle %}

{{ 'CWC_image_highlight.css' | asset_url | stylesheet_tag }}

{% comment %}
  ================================
  Calculate midpoint for splitting blocks
  - Count only highlight_item blocks (exclude button)
  - Divide by 2, round up for left column
  ================================
{% endcomment %}
{% liquid
  assign highlight_items = section.blocks | where: 'type', 'highlight_item'
  assign total_items = highlight_items.size
  assign midpoint = total_items | divided_by: 2.0 | ceil
%}

<div id="CWC_image_highlight-{{ section.id }}" class="cwc_image_highlight">
  <div class="cwc_image_highlight-inner">
    {% if section.settings.section_title != blank %}
      <div class="cwc_image_highlight__section-title rte">
        {{ section.settings.section_title }}
      </div>
    {% endif %}

    {% if section.settings.section_subtitle != blank %}
      <div class="cwc_image_highlight__section-subtitle rte">
        {{ section.settings.section_subtitle }}
      </div>
    {% endif %}

    <div class="highlight-columns">
      {% comment %}
        ==============================
        LEFT COLUMN: First half of highlight items
        ==============================
      {% endcomment %}
      <div class="highlight-column highlight-column--left">
        {% for block in highlight_items limit: midpoint %}
          <div class="highlight-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <div class="highlight-icon">
                <img src="{{ block.settings.icon | image_url }}" alt="">
              </div>
            {% endif %}
            <div>
              <h3 class="highlight-item-title">{{ block.settings.title }}</h3>
              <p class="highlight-item-text">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      {% comment %}
        ==============================
        CENTER COLUMN: Featured image
        ==============================
      {% endcomment %}
      <div class="highlight-column highlight-column--center">
        <div class="highlight-main-image">
          {% if section.settings.featured_image %}
            <img src="{{ section.settings.featured_image | image_url }}" alt="">
          {% else %}
            <div class="highlight-main-image__placeholder">
              <span>Add an image</span>
            </div>
          {% endif %}
        </div>
      </div>

      {% comment %}
        ==============================
        RIGHT COLUMN: Second half of highlight items
        ==============================
      {% endcomment %}
      <div class="highlight-column highlight-column--right">
        {% for block in highlight_items offset: midpoint %}
          <div class="highlight-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <div class="highlight-icon">
                <img src="{{ block.settings.icon | image_url }}" alt="">
              </div>
            {% endif %}
            <div>
              <h3 class="highlight-item-title">{{ block.settings.title }}</h3>
              <p class="highlight-item-text">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {% comment %}
      ==============================
      Button Block (separate from highlight items)
      ==============================
    {% endcomment %}
    {% for block in section.blocks %}
      {% if block.type == 'button' %}
        <div class="cwc_image_highlight__cta" {{ block.shopify_attributes }}>
          {% render 'CWC_button', product: product, section_id: section.id, block: block %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "CWC Image Highlight",
  "settings": [
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h2>The Ollie Advantage: Right Concentration, Right Shape, Right Price</h2>"
    },
    {
      "type": "richtext",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "<p>Not all hydroxyapatite toothpastes are created equal. Here's what makes Ollie different.</p>"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Featured Center Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Text Bold Color",
      "default": "#00766F"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "highlight_item",
      "name": "Highlight Item",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon or Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Item Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Item Text",
          "default": "Describe this feature in one or two lines."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#125657"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CWC Image Highlight",
      "category": "Custom",
      "blocks": [
        { "type": "highlight_item" },
        { "type": "highlight_item" },
        { "type": "highlight_item" },
        { "type": "highlight_item" },
        { "type": "highlight_item" },
        { "type": "highlight_item" }
      ]
    }
  ]
}
{% endschema %}
