{% style %}
  #CWC_image_text-{{ section.id }} {
    --section-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#202020' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_image_text.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_image_text-{{ section.id }}"
  class="cwc_image_text{% if section.settings.image_position == 'right' %} reverse{% endif %}"
>
  <div class="cwc_image_text__container">
    <div class="cwc_image_text__wrapper">
      {% comment %}
        ==============================
        Image Column
        ==============================
      {% endcomment %}
      <div class="cwc_image_text__image">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 600 }}"
            alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {% else %}
          <div class="placeholder-image">
            <span>Add an image</span>
          </div>
        {% endif %}
      </div>

      {% comment %}
        ==============================
        Content Column
        ==============================
      {% endcomment %}
      <div class="cwc_image_text__content">
        {% for block in section.blocks %}
          {% case block.type %}
              {% comment %} Title Block {% endcomment %}
            {% when 'title' %}
              {% if block.settings.text != blank %}
                <div class="cwc_image_text__title rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {% endif %}

              {% comment %} Text Block {% endcomment %}
            {% when 'text' %}
              {% if block.settings.text != blank %}
                <div class="cwc_image_text__text rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              {% endif %}

              {% comment %} Button Block {% endcomment %}
            {% when 'button' %}
              {% if block.settings.text != blank %}
                <div class="cwc_image_text__button" {{ block.shopify_attributes }}>
                  {% render 'CWC_button', product: product, section_id: section.id, block: block %}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image + Text",
  "settings": [
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Featured Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#202020"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Title",
          "default": "<h2>Your Section Title</h2>"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text Content",
          "default": "<p>Add your supporting text or description here.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#125657"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image + Text",
      "category": "Custom",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
