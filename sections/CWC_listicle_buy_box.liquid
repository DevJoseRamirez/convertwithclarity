{% style %}
  #CWC_listicle_buy_box-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#f0fdf4' }}; /* Light green from image */
    --bold-color: {{ section.settings.bold_color | default: '#ef4444' }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --button-bg: {{ section.settings.button_color | default: '#4c1d95' }}; /* Dark purple from image */
    --button-text: {{ section.settings.button_text_color | default: '#ffffff' }};
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_listicle_buy_box.css' | asset_url | stylesheet_tag }}

<div id="CWC_listicle_buy_box--anchor"></div>

<section
  id="CWC_listicle_buy_box-{{ section.id }}"
  class="cwc-buy-box"
>
  <div class="cwc-buy-box__container">
    <div class="cwc-buy-box__card">
      {% if section.settings.floating_badge_text != blank %}
        <div class="cwc-buy-box__floating-badge">
          <div class="cwc-buy-box__floating-badge-text">
            {{ section.settings.floating_badge_text }}
          </div>
        </div>
      {% endif %}

      <div class="cwc-buy-box__content-wrapper">
        <div class="cwc-buy-box__image-area">
          {% if section.settings.image != blank %}
            <img
              src="{{ section.settings.image | image_url: width: 500 }}"
              alt="Content image"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <div class="cwc-buy-box__text-area">
          {% if section.settings.sub_head != blank %}
            <div class="cwc-buy-box__sub_head">
              {{ section.settings.sub_head }}
            </div>
          {% endif %}

          {% if section.settings.title != blank %}
            <div class="cwc-buy-box__title rte">
              {{ section.settings.title }}
            </div>
          {% endif %}

          {% if section.settings.sub_text != blank %}
            <div class="cwc-buy-box__sub_text rte">
              {{ section.settings.sub_text }}
            </div>
          {% endif %}

          {% if section.settings.button_link != blank and section.settings.button_text != blank %}
            <a href="{{ section.settings.button_link }}" class="cwc-buy-box__button">
              {{ section.settings.button_text }}
            </a>
          {% endif %}

          {% comment %}
            {% if section.settings.subtext != blank %}
              <div class="cwc-buy-box__subtext rte">
                {{ section.settings.subtext }}
              </div>
            {% endif %}
          {% endcomment %}

          {% comment %} Render blocks for additional offers {% endcomment %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'timer' %}
                {% assign assign use_synced_timer = block.settings.use_synced_timer %}
                {% assign synced_timer_id = block.settings.synced_timer_section_id %}

                {% comment %} use_synced_timer {% endcomment %}
                <div class="cwc-buy-box__offer-block" {{ block.shopify_attributes }}>
                  {% if use_synced_timer %}
                    <div class="cwc-buy-box__offer-timer-wrapper">
                      <span class="cwc-buy-box__offer-timer-label">DEAL ENDING IN:</span>
                      <div
                        class="cwc-buy-box__offer-timer"
                        id="offer-timer-{{ block.id }}"
                        data-synced-timer-id="{{ synced_timer_id }}"
                      >
                        <span class="cwc-buy-box__offer-timer-value" data-unit="hours">00</span>
                        <span class="cwc-buy-box__offer-timer-separator">:</span>
                        <span class="cwc-buy-box__offer-timer-value" data-unit="minutes">00</span>
                        <span class="cwc-buy-box__offer-timer-separator">:</span>
                        <span class="cwc-buy-box__offer-timer-value" data-unit="seconds">00</span>
                      </div>
                    </div>
                    <script>
                      (function () {
                        const el = document.getElementById('offer-timer-{{ block.id }}');
                        if (!el) return;

                        const syncedTimerId = el.dataset.syncedTimerId || 'global_promo_timer';
                        const COOKIE_NAME = 'promo_timer_end_' + syncedTimerId;

                        function getCookie(name) {
                          const m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                          return m ? m[2] : null;
                        }

                        const hEl = el.querySelector('[data-unit="hours"]');
                        const mEl = el.querySelector('[data-unit="minutes"]');
                        const sEl = el.querySelector('[data-unit="seconds"]');

                        let endTime = Number.parseInt(getCookie(COOKIE_NAME), 10);
                        let interval = null;

                        function start(end) {
                          endTime = end;
                          if (interval) {
                            clearInterval(interval);
                            interval = null;
                          }

                          function update() {
                            const left = endTime - Date.now();
                            if (left <= 0) {
                              // Show expired until banner resets; keep listening for event
                              if (el) el.innerHTML = '<span class="cwc-buy-box__offer-timer-expired">EXPIRED</span>';
                              clearInterval(interval);
                              interval = null;
                              return;
                            }
                            const hrs = Math.floor(left / 3600_000);
                            const mins = Math.floor((left % 3600_000) / 60_000);
                            const secs = Math.floor((left % 60_000) / 1000);
                            hEl.textContent = String(hrs).padStart(2, '0');
                            mEl.textContent = String(mins).padStart(2, '0');
                            sEl.textContent = String(secs).padStart(2, '0');
                          }

                          // restore structure if we had replaced content
                          if (!hEl || !mEl || !sEl) {
                            el.innerHTML = `
        <span class="cwc-buy-box__offer-timer-value" data-unit="hours">00</span>
        <span class="cwc-buy-box__offer-timer-separator">:</span>
        <span class="cwc-buy-box__offer-timer-value" data-unit="minutes">00</span>
        <span class="cwc-buy-box__offer-timer-separator">:</span>
        <span class="cwc-buy-box__offer-timer-value" data-unit="seconds">00</span>`;
                          }

                          update();
                          interval = setInterval(update, 1000);
                        }

                        // 1) If we already have a valid future cookie, start immediately
                        if (Number.isFinite(endTime) && endTime > Date.now()) {
                          start(endTime);
                        } else {
                          // 2) Otherwise show waiting/expired and listen for the banner to announce
                          el.innerHTML = '<span class="cwc-buy-box__offer-timer-value">Waiting for timer…</span>';

                          // Also do a light poll as a fallback in case event is missed
                          let pollCount = 0;
                          const poll = setInterval(() => {
                            const v = Number.parseInt(getCookie(COOKIE_NAME), 10);
                            if (Number.isFinite(v) && v > Date.now()) {
                              clearInterval(poll);
                              start(v);
                            } else if (++pollCount > 60) {
                              // ~60s max
                              clearInterval(poll);
                              el.innerHTML = '<span class="cwc-buy-box__offer-timer-expired">EXPIRED</span>';
                            }
                          }, 1000);

                          // Primary: event-driven sync from the banner
                          function onReady(e) {
                            if (!e.detail || e.detail.name !== COOKIE_NAME) return;
                            if (Number.isFinite(e.detail.endTime) && e.detail.endTime > Date.now()) {
                              clearInterval(poll);
                              start(e.detail.endTime);
                            }
                          }
                          window.addEventListener('promoTimerReady', onReady, { once: false });
                        }
                      })();
                    </script>
                  {% endif %}
                </div>

                {% comment %} use_synced_timer {% endcomment %}

              {% when 'offer-off' %}
                {% liquid
                  assign block_button_bg = block.settings.button_bg_color | default: section.settings.button_color
                  assign block_button_text = block.settings.button_text_color | default: section.settings.button_text_color
                  assign use_synced_timer = block.settings.use_synced_timer
                  assign synced_timer_id = block.settings.synced_timer_section_id
                %}
                <div class="cwc-buy-box__offer-block-2" {{ block.shopify_attributes }}>
                  {% comment %} RISK BLOCK {% endcomment %}
                  {% comment %} prefix all clas names with "cwc-buy-box__offer-" {% endcomment %}

                  {% comment %} RISK BLOCK {% endcomment %}
                  <div class="cwc-buy-box__offer-risk-block">
                    <span class="cwc-buy-box__offer-risk-label">
                      {{ block.settings.risk_label }}:
                      <span class="cwc-buy-box__offer-risk-value">{{ block.settings.risk_value }}</span>
                    </span>
                    <span class="cwc-buy-box__offer-divider">|</span>
                    <span class="cwc-buy-box__offer-shipping">
                      <span class="cwc-buy-box__offer-shipping-highlight">{{ block.settings.shipping_highlight }}</span>
                      {{ block.settings.shipping_text }}
                    </span>
                  </div>

                  {% if block.settings.title != blank %}
                    <div class="cwc-buy-box__offer-title rte">
                      {{ block.settings.title }}
                    </div>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="cwc-buy-box__offer-text rte">
                      {{ block.settings.text }}
                    </div>
                  {% endif %}

                  {% if block.settings.button_link != blank and block.settings.button_text != blank %}
                    <a
                      href="{{ block.settings.button_link }}"
                      class="cwc-buy-box__offer-button"
                      style="--offer-button-bg: {{ block_button_bg }}; --offer-button-text: {{ block_button_text }};"
                    >
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Listicle Buy Box",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background color",
      "default": "#f0fdf4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Highlight color",
      "default": "#ef4444"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "richtext",
      "id": "sub_head",
      "label": "Sub Head",
      "default": "<p>FREE GIFTS WITH YOUR ORDER</p>"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Main Title",
      "default": "<h3><strong>UP TO 60% OFF FOR A LIMITED TIME ONLY!</strong></h3>"
    },
    {
      "type": "richtext",
      "id": "sub_text",
      "label": "Sub Text",
      "default": "<p>This limited-time deal is in high demand and stock keeps selling out.</p>"
    },
    {
      "type": "text",
      "id": "floating_badge_text",
      "label": "Floating Badge Text",
      "default": "⚡BLACK FRIDAY EXCLUSIVE"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Main Button color",
      "default": "#4c1d95"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Main Button text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Main Button text",
      "default": "GET 60% OFF →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Main Button link"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext (below main button)",
      "default": "<p>Try it today with a 30-Day Money-Back Guarantee!</p>"
    }
  ],
  "blocks": [
    {
      "type": "timer",
      "name": "Timer Block",
      "settings": [
        {
          "type": "checkbox",
          "id": "use_synced_timer",
          "label": "Use Synced Timer",
          "info": "Sync with promotion banner timer. IMPORTANT: Promotion banner must be on the page!",
          "default": true
        },
        {
          "type": "text",
          "id": "synced_timer_section_id",
          "label": "Timer Sync ID",
          "info": "Must match the promotion banner section ID (default: global_promo_timer)",
          "default": "global_promo_timer"
        }
      ]
    },
    {
      "type": "offer",
      "name": "Offer Block",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "label": "Offer Title",
          "default": "<h4>Limited Time Offer!</h4>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Offer Text",
          "default": "<p>This is a special, time-sensitive offer.</p>"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Offer Subtext",
          "default": "<p>Risk: High | Free Shipping</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Claim Offer"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color (Override)"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color (Override)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Listicle Buy Box",
      "category": "Listicle",
      "blocks": [
        {
          "type": "offer"
        }
      ]
    }
  ]
}
{% endschema %}
