{% style %}
  #CWC_listicle_card_image_text-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#f0fdf4' }};
    --number-bg: {{ section.settings.card_bg_color | color_darken: 5 }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --badge-bg: {{ section.settings.badge_bg_color | default: '#d1fae5' }};
    --badge-text: var(--card-bg); /* Badge text color matches card background color */
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_listicle_card_image_text.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_listicle_card_image_text-{{ section.id }}"
  class="cwc-card-image-text"
>
  <div class="cwc-card-image-text__container">
    <div class="cwc-card-image-text__card">
      <div class="cwc-card-image-text__grid">
        <div
          class="cwc-card-image-text__item--image{% unless section.settings.image_first %} last {% endunless %}"
        >
          {% if section.settings.image != blank %}
            <div class="cwc-card-image-text__image-wrapper">
              {% comment %} Render image with responsive settings {% endcomment %}
              {{
                section.settings.image
                | image_url: width: 800
                | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', widths: '300, 500, 700, 1000'
              }}
            </div>
          {% endif %}
        </div>

        <div class="cwc-card-image-text__item--text">
          {% if section.settings.number_text != blank or section.settings.badge_text != blank %}
            <div class="cwc-card-image-text__header">
              {% if section.settings.number_text != blank %}
                <div class="cwc-card-image-text__number">
                  {{ section.settings.number_text }}
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if section.settings.title != blank %}
            <div class="cwc-card-image-text__title rte">
              {{ section.settings.title }}
            </div>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="cwc-card-image-text__text rte">
              {{ section.settings.text }}
            </div>
          {% endif %}

          {% if section.settings.badge_text != blank %}
            <div class="cwc-card-image-text__badge">
              {{ section.settings.badge_text }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Listicle Card Image Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background color",
      "default": "#f0fdf4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "image_first",
      "label": "Show image first (left side)",
      "default": false,
      "info": "Unchecked: Text on left, Image on right. Checked: Image on left, Text on right."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "number_text",
      "label": "Number/Index Text (e.g., 01)",
      "default": "01"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<h3>Your Multivitamin Uses Cheap Forms Your Body Can't Absorb</h3>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content",
      "default": "<p>Not all B12 is created equal. The cheap version in most drugstore vitamins is like giving your body instructions in a foreign language...</p>"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text (e.g., Thumbs Down)",
      "info": "This is the small floating badge on the image.",
      "default": "Badge Text"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#10b981"
    }
  ],
  "presets": [
    {
      "name": "Listicle Card Image Text",
      "category": "Listicle"
    }
  ]
}
{% endschema %}
