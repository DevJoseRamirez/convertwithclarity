{% style %}
  #CWC_listicle_card_summary-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#e0f2fe' }}; /* Light blue from image */
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --card-bg-border: {{ section.settings.card_bg_color | color_darken: 10 }};
    --alt-text-color: {{ section.settings.card_bg_color | color_darken: 74 }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_listicle_card_summary.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_listicle_card_summary-{{ section.id }}"
  class="cwc-card-summary"
>
  <div class="cwc-card-summary__container">
    <div class="cwc-card-summary__card">
      {% if section.settings.title != blank %}
        <div class="cwc-card-summary__title rte">
          {{ section.settings.title }}
        </div>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="cwc-card-summary__text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.text_2 != blank %}
        <div class="cwc-card-summary__text-2 rte">
          {{ section.settings.text_2 }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Listicle Card Summary",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background color",
      "default": "#FAF8F3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<h2>The Bottom Line</h2>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Your summary text goes here.</p>"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Additional Text (Optional)",
      "default": "<p>Secondary text input.</p>"
    }
  ],
  "presets": [
    {
      "name": "Listicle Card Summary",
      "category": "Listicle"
    }
  ]
}
{% endschema %}
