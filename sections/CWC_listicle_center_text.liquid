{% style %}
  #CWC_center_text-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --text-align: {{ section.settings.text_align | default: 'center' }};
    --max-width: {{ section.settings.max_width | default: 1000 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_listicle_center_text.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_center_text-{{ section.id }}"
  class="cwc-center-text"
>
  <div class="cwc-center-text__container">
    {% if section.settings.title != blank %}
      <div class="cwc-center-text__title rte">
        {{ section.settings.title }}
      </div>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="cwc-center-text__text rte">
        {{ section.settings.text }}
      </div>
    {% endif %}

    {% if section.settings.text_2 != blank %}
      <div class="cwc-center-text__text-2 rte">
        {{ section.settings.text_2 }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Center Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Content max width",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<h2>Your Title Here</h2>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Your content goes here.</p>"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Text 2",
      "default": "<p>Additional content goes here.</p>"
    }
  ],
  "presets": [
    {
      "name": "Listicle Center Text",
      "category": "Listicle"
    }
  ]
}
{% endschema %}
