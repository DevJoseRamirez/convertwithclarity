{% style %}
  #CWC_listicle_promotion_banner-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#1f2937' }};
    --text-color: {{ section.settings.text_color | default: '#ffffff' }};
    --padding-top: {{ section.settings.padding_top | default: 20 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 20 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;

    /* Timer colors - inverse of section colors */
    --timer-bg: var(--text-color);
    --timer-text: var(--section-bg);
  }
{% endstyle %}

{{ 'CWC_listicle_promotion_banner.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_listicle_promotion_banner-{{ section.id }}"
  class="cwc-promotion-banner"
>
  <div class="cwc-promotion-banner__container">
    <div class="cwc-promotion-banner__content">
      {% if section.settings.top_text != blank %}
        <div class="cwc-promotion-banner__top-text rte">
          {{ section.settings.top_text }}
        </div>
      {% endif %}

      {% if section.settings.bottom_text != blank %}
        <div class="cwc-promotion-banner__bottom-text rte">
          {{ section.settings.bottom_text }}
        </div>
      {% endif %}
    </div>

    {% if section.settings.show_timer %}
      <div class="cwc-promotion-banner__timer-wrapper">
        <div
          class="cwc-promotion-banner__timer"
          id="timer-{{ section.id }}"
        >
          <div class="cwc-promotion-banner__timer-segment">
            <div class="cwc-promotion-banner__timer-top">
              <span class="cwc-promotion-banner__timer-value" data-unit="hours">00</span>
              <span class="cwc-promotion-banner__timer-separator">:</span>
            </div>
            <span class="cwc-promotion-banner__timer-label">HRS</span>
          </div>

          <div class="cwc-promotion-banner__timer-segment">
            <div class="cwc-promotion-banner__timer-top">
              <span class="cwc-promotion-banner__timer-value" data-unit="minutes">00</span>
              <span class="cwc-promotion-banner__timer-separator">:</span>
            </div>
            <span class="cwc-promotion-banner__timer-label">MIN</span>
          </div>

          <div class="cwc-promotion-banner__timer-segment">
            <div class="cwc-promotion-banner__timer-top">
              <span class="cwc-promotion-banner__timer-value" data-unit="seconds">00</span>
            </div>
            <span class="cwc-promotion-banner__timer-label">SEC</span>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% if section.settings.show_timer %}
  <script>
    (function () {
      const el = document.getElementById('timer-{{ section.id }}');
      if (!el) return;

      const COOKIE_NAME = 'promo_timer_end_global_promo_timer';
      const MIN_HOURS = Number({{ section.settings.min_hours | default: 3 }}) || 3;
      const MAX_HOURS = Number({{ section.settings.max_hours | default: 6 }}) || 6;

      function getCookie(name) {
        const m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return m ? m[2] : null;
      }
      function setCookie(name, value, days = 365) {
        const d = new Date();
        d.setTime(d.getTime() + days * 864e5);
        const secure = location.protocol === 'https:' ? ';Secure' : '';
        document.cookie = name + '=' + value + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax' + secure;
      }
      function randHours() { return MIN_HOURS + Math.random() * Math.max(0, (MAX_HOURS - MIN_HOURS)); }

      let endTime = Number.parseInt(getCookie(COOKIE_NAME), 10);
      if (!Number.isFinite(endTime) || endTime <= Date.now()) {
        endTime = Date.now() + randHours() * 3600_000;
        setCookie(COOKIE_NAME, String(endTime));
      }

      // 🔔 Let any listeners (buy-box) know the current endTime
      window.dispatchEvent(new CustomEvent('promoTimerReady', { detail: { name: COOKIE_NAME, endTime } }));

      const hEl = el.querySelector('[data-unit="hours"]');
      const mEl = el.querySelector('[data-unit="minutes"]');
      const sEl = el.querySelector('[data-unit="seconds"]');

      function tick() {
        const left = endTime - Date.now();
        if (left <= 0) {
          // Reset & announce again
          endTime = Date.now() + randHours() * 3600_000;
          setCookie(COOKIE_NAME, String(endTime));
          window.dispatchEvent(new CustomEvent('promoTimerReady', { detail: { name: COOKIE_NAME, endTime } }));
          return; // next interval will pick up the new endTime
        }
        const hrs = Math.floor(left / 3600_000);
        const mins = Math.floor((left % 3600_000) / 60_000);
        const secs = Math.floor((left % 60_000) / 1000);
        hEl.textContent = String(hrs).padStart(2, '0');
        mEl.textContent = String(mins).padStart(2, '0');
        sEl.textContent = String(secs).padStart(2, '0');
      }

      tick();
      const timer = setInterval(tick, 1000);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Listicle Promotion Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    },
    {
      "type": "richtext",
      "id": "top_text",
      "label": "Top Text (e.g., Badge/Headline)",
      "default": "<p>⚡ BLACK FRIDAY VIP ACCESS</p>"
    },
    {
      "type": "richtext",
      "id": "bottom_text",
      "label": "Bottom Text (e.g., Offer Detail)",
      "default": "<p>UP TO 50% OFF WITH FREE GIFTS</p>"
    },
    {
      "type": "checkbox",
      "id": "show_timer",
      "label": "Show Countdown Timer",
      "default": true
    },
    {
      "type": "range",
      "id": "min_hours",
      "min": 1,
      "max": 12,
      "step": 0.5,
      "unit": "hrs",
      "label": "Minimum Hours",
      "default": 3
    },
    {
      "type": "range",
      "id": "max_hours",
      "min": 1,
      "max": 24,
      "step": 0.5,
      "unit": "hrs",
      "label": "Maximum Hours",
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Listicle Promotion Banner",
      "category": "Listicle"
    }
  ]
}
{% endschema %}
