{% comment %}
  🔧 SECTION TEMPLATE: CWC_overlay_compare_table.liquid
  Visual product comparison with an overlayed brand column.
{% endcomment %}

{{ 'CWC_overlay_compare_table.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #cwc_overlay_compare_table-{{ section.id }} * {
  /* overflow: hidden !important; */
  }
  #cwc_overlay_compare_table-{{ section.id }} {
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --background-color: {{ section.settings.background_color }};
  --color: {{ section.settings.text_color }};
  }

  .cwc_overlay_compare_table .cwc_compare_table-wrapper {
  background-color: {{ section.settings.table_background_color }};
  border: 1px solid {{ section.settings.border_color }};
  }

  .cwc_overlay_compare_table .cwc_overlay_column {
  background-color: {{ section.settings.overlay_column_color }};
  }

  .cwc_overlay_compare_table .compare-cell.comp,
  .cwc_overlay_compare_table .compare-cell.label {
  background-color: {{ section.settings.table_base_color }};
  }

  .cwc_overlay_compare_table .compare-cell.brand {
  background-color: {{ section.settings.brand_column_color }};
  }
{%- endstyle -%}

<div
  id="cwc_overlay_compare_table-{{ section.id }}"
  class="cwc_overlay_compare_table"
  style="--section-bg: {{ section.settings.background_color }}; --text-color: {{ section.settings.text_color }};"
>
  <div class="cwc_overlay_compare_table-inner">
    {% if section.settings.title != blank %}
      <h2 class="compare-title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="compare-subtext">{{ section.settings.subtext }}</div>
    {% endif %}

    <div class="compare-table-wrapper">
      <!-- Table -->

      <div class="compare-table">
        <!-- Header Row -->
        <div class="compare-row head">
          <div class="compare-cell label">{{ section.settings.feature_column_title }}</div>
          <div class="compare-cell brand">
            {% if section.settings.brand_image %}
              <img src="{{ section.settings.brand_image | image_url }}" alt="Brand Image">
            {% endif %}
          </div>
          <div class="compare-cell comp">
            <div class="other_brands">Other Brands</div>
            {% if section.settings.competitor_image %}
              <img src="{{ section.settings.competitor_image | image_url }}" alt="Competitor Image">
            {% endif %}
          </div>
        </div>

        <!-- Comparison Rows -->
        {% for block in section.blocks %}
          <div class="compare-row rows" {{ block.shopify_attributes }}>
            <div class="compare-cell label">
              {{ block.settings.label }}
            </div>
            <div class="compare-cell brand">
              {% render 'check-icon' %}
            </div>
            <div class="compare-cell comp">
              {% render 'x-icon' %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Overlay Compare Table",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Enrichd vs. Other Brands"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>See the clear difference in what we offer.</p>"
    },
    {
      "type": "text",
      "id": "feature_column_title",
      "label": "Feature Column Title",
      "default": "Compare"
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Brand Image"
    },
    {
      "type": "image_picker",
      "id": "competitor_image",
      "label": "Competitor Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "table_base_color",
      "label": "Table Background Color",
      "default": "#FFF1E8"
    },
    {
      "type": "color",
      "id": "brand_column_color",
      "label": "Brand Column Color",
      "default": "#E2EBED"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider Line Color",
      "default": "#d0d0d0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Feature",
          "default": "Fully Extracted"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Overlay Compare Table",
      "category": "Custom",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
{% endschema %}
