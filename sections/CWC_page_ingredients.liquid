{% style %}
  #CWC_page_ingredients-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --wrap-section-bg: {{ section.settings.wrap_background_color }};
  --card-bg: {{ section.settings.card_bg_color }};
  --card-text: {{ section.settings.card_text_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_page_ingredients.css' | asset_url | stylesheet_tag }}

<section id="CWC_page_ingredients-{{ section.id }}" class="CWC_page_ingredients">
  <div class="CWC_page_ingredients-container">
    <div class="CWC_page_ingredients-wrapper">
      {% if section.settings.section_title != blank %}
        <div class="CWC_page_ingredients-header">
          <div class="CWC_page_ingredients-title">
            {{ section.settings.section_title }}
          </div>
        </div>
      {% endif %}

      <div class="CWC_page_ingredients-grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'ingredient_card' %}
              <div class="CWC_page_ingredients-card" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                  <div class="ingredient-image">
                    <img
                      src="{{ block.settings.image | image_url: width: 150 }}"
                      alt="{{ block.settings.image.alt | default: block.settings.title }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                      priority="medium"
                    >
                  </div>
                {% endif %}

                <div class="ingredient-content">
                  {% if block.settings.title != blank %}
                    <h6 class="ingredient-title">
                      {{ block.settings.title }}
                    </h6>
                  {% endif %}

                  {% if block.settings.text != blank %}
                    <div class="ingredient-text">
                      {{ block.settings.text }}
                    </div>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC Page Ingredients",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h2>5 Super Fruit Powders:</h2>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "wrap_background_color",
      "label": "Section Wrap Background Color",
      "default": "#FFEAE5"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "ingredient_card",
      "name": "Ingredient Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Title",
          "default": "1. Acai"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Ingredient Description",
          "default": "<p>Acai are extremely antioxidant-rich berries that are an excellent source of vitamin C and minerals such as potassium, copper, and manganese.</p>"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Page Ingredients",
      "category": "Page",
      "blocks": [
        {
          "type": "ingredient_card",
          "settings": {
            "title": "1. Acai",
            "text": "<p>Acai are extremely antioxidant-rich berries that are an excellent source of vitamin C and minerals such as potassium, copper, and manganese. They promote gut, heart, immune system and brain health (and they help fight stress too).</p>"
          }
        },
        {
          "type": "ingredient_card",
          "settings": {
            "title": "2. Avocado",
            "text": "<p>Avocados are a heart-healthy source of monounsaturated fats, dietary fiber, Vitamin K, and all of the essential amino acids, and support brain function, appetite control, weight management and nutrient absorption.</p>"
          }
        },
        {
          "type": "ingredient_card",
          "settings": {
            "title": "3. Apple",
            "text": "<p>Apples contain a significant source of flavonoids, are full of fiber, high in vitamin C and a healthy source of probiotics. They promote heart, liver, lung, eye, bone, and immune system health.</p>"
          }
        },
        {
          "type": "ingredient_card",
          "settings": {
            "title": "4. Blueberry",
            "text": "<p>Blueberries are rich in anthocyanins, which support cognitive function, reduce inflammation and protect cells from damage. They are high in antioxidants such as vitamin C and offer benefits for brain, heart, skin, bone, and digestive health.</p>"
          }
        },
        {
          "type": "ingredient_card",
          "settings": {
            "title": "5. Raspberry",
            "text": "<p>Raspberries are rich in fiber, antioxidants, vitamins C, A, E, and minerals such as potassium, manganese, and iron. They may help to boost skin, eye, digestive, and immune system health.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
