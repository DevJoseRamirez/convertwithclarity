{% style %}
  #cwc_portfolio_stats-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#0F0F0F' }};
    --accent-color: {{ section.settings.accent_color | default: '#4ade80' }};
    --label-color: {{ section.settings.label_color | default: '#666666' }};
    --padding-top: {{ section.settings.padding_top | default: 32 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 32 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 32 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 32 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_portfolio_stats.css' | asset_url | stylesheet_tag }}

<section id="cwc_portfolio_stats-{{ section.id }}" class="cwc_portfolio_stats">
  <div class="cwc_portfolio_stats__container">
    {% if section.blocks.size > 0 %}
      <div class="cwc_portfolio_stats__row">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="cwc_portfolio_stats__item" {{ block.shopify_attributes }}>
              {% if block.settings.number != blank %}
                <div class="cwc_portfolio_stats__num">{{ block.settings.number }}</div>
              {% endif %}
              {% if block.settings.label != blank %}
                <div class="cwc_portfolio_stats__lbl">{{ block.settings.label }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Portfolio Stats",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0F0F0F" },
    { "type": "color", "id": "accent_color", "label": "Number Color", "default": "#4ade80" },
    { "type": "color", "id": "label_color", "label": "Label Color", "default": "#666666" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "settings": [
        { "type": "text", "id": "number", "label": "Number / Value", "default": "60+" },
        { "type": "text", "id": "label", "label": "Label", "default": "DTC Builds" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Portfolio Stats",
      "category": "Portfolio",
      "blocks": [
        { "type": "stat", "settings": { "number": "60+", "label": "DTC Builds" } },
        { "type": "stat", "settings": { "number": "100%", "label": "Job Success (Upwork)" } },
        { "type": "stat", "settings": { "number": "+31%", "label": "CVR Lift" } },
        { "type": "stat", "settings": { "number": "+36%", "label": "Revenue MoM" } },
        { "type": "stat", "settings": { "number": "5+", "label": "Platform Migrations" } }
      ]
    }
  ]
}
{% endschema %}
