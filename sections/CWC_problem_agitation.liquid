{% style %}
  #cwc_problem-agitation-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#F5F5F0' }};
    --text-color: {{ section.settings.text_color | default: '#181818' }};
    --highlight-color: {{ section.settings.bold_color | default: '#C0392B' }};
    --rule-color: {{ section.settings.rule_color | default: '#E5E5E0' }};
    --number-color: {{ section.settings.number_color | default: '#8A8A85' }};
    --link-color: {{ section.settings.link_color | default: '#0A0A0A' }};
    --card-bg: {{ section.settings.card_bg | default: '#FFFFFF' }};
    --card-padding: {{ section.settings.card_padding | default: 32 }}px;
    --card-radius: {{ section.settings.card_radius | default: 0 }}px;
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 80 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 80 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_problem_agitation.css' | asset_url | stylesheet_tag }}

<section id="cwc_problem-agitation-{{ section.id }}" class="cwc_problem-agitation">
  <div class="cwc_problem-agitation__container">
    {% comment %} Section Header {% endcomment %}
    <div class="cwc_problem-agitation__content">
      {% if section.settings.eyebrow != blank %}
        <div class="cwc_problem-agitation__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="cwc_problem-agitation__content-heading rte">
          {{ section.settings.heading }}
        </div>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <div class="cwc_problem-agitation__content-subtext rte">
          {{ section.settings.subtext }}
        </div>
      {% endif %}
    </div>

    {% comment %} Problem Cards Grid {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="cwc_problem-agitation__grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'problem' %}
              <div class="cwc_problem-agitation__card" {{ block.shopify_attributes }}>
                <div class="cwc_problem-agitation__card-number">
                  {{ forloop.index | prepend: '0' | slice: -2, 2 }}
                </div>

                {% if block.settings.title != blank %}
                  <div class="cwc_problem-agitation__card-title rte">
                    {{ block.settings.title }}
                  </div>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="cwc_problem-agitation__card-text rte">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                  <a
                    href="{{ block.settings.link_url }}"
                    class="cwc_problem-agitation__card-link"
                    {% if block.settings.link_new_tab %}
                      target="_blank" rel="noopener"
                    {% endif %}
                  >
                    <span class="cwc_problem-agitation__card-link-label">{{ block.settings.link_label }}</span>
                    <svg
                      class="cwc_problem-agitation__card-link-arrow"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      focusable="false"
                    >
                      <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {% endif %}

                <div class="cwc_problem-agitation__card-spotlight">n</div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Problem Agitation",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "01 / The Problem"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Section Heading",
      "info": "Wrap any words you want accented in <strong> tags.",
      "default": "<h2>The 3 Biggest Challenges /n Growing DTC Brands Face.</h2>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Section Subtext",
      "info": "Optional. Leave blank to hide.",
      "default": "<p></p>"
    },
    {
      "type": "header",
      "content": "Card Layout"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card Padding",
      "min": 16,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Corner Radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F5F5F0"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#181818"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Heading Highlight Color",
      "default": "#C0392B"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Hairline Rule Color",
      "default": "#E5E5E0"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Card Number Color",
      "default": "#8A8A85"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Card Link Color",
      "default": "#0A0A0A"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "problem",
      "name": "Problem Card",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "label": "Problem Title",
          "default": "<p>Pain Point Title</p>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Problem Description",
          "default": "<p>Describe the specific pain point your customer is feeling. Make it concrete and recognizable so they nod along.</p>"
        },
        {
          "type": "header",
          "content": "Optional Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "info": "Leave blank to hide the link."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "link_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "CWC Problem Agitation",
      "category": "CWC Custom",
      "blocks": [{ "type": "problem" }, { "type": "problem" }, { "type": "problem" }]
    }
  ]
}
{% endschema %}
