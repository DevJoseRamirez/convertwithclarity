{% style %}
  #CWC_product_card_options-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#f9f9f9' }};
    --price-color: {{ section.settings.price_color | default: '#8b5cf6' }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --button-bg: {{ section.settings.button_color | default: '#8b5cf6' }};
    --button-text: {{ section.settings.button_text_color | default: '#ffffff' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_product_card_options.css' | asset_url | stylesheet_tag }}
{{ 'CWC_product_card_options.js' | asset_url | script_tag }}

{% liquid
  assign selected_product = section.settings.product
  assign section_id = section.id
%}

{% comment %} Developer Mode - Show Variant IDs (for setup) -UTILITY{% endcomment %}
{% if section.settings.show_variant_ids and selected_product %}
  <div style="background: #fef3c7; border: 2px solid #f59e0b; padding: 20px; margin: 20px; border-radius: 8px;">
    <h3 style="margin: 0 0 10px 0; color: #92400e;">🔧 Developer Mode - Copy Variant IDs:</h3>
    {% for variant in selected_product.variants %}
      <p style="margin: 5px 0; font-family: monospace; color: #78350f;">
        <strong>{{ variant.title }}</strong>:
        <code style="background: #fff; padding: 2px 6px; border-radius: 3px;">{{ variant.id }}</code>
      </p>
    {% endfor %}
    <p style="margin: 10px 0 0 0; font-size: 14px; color: #92400e;">
      ℹ️ Copy the variant ID and paste it into the corresponding block's "Variant ID" field below. Then disable this
      toggle.
    </p>
  </div>
{% endif %}

<section
  id="CWC_product_card_options-{{ section_id }}"
  class="cwc-product-cards"
  data-section-id="{{ section_id }}"
  data-product-id="{{ selected_product.id }}"
  data-variants="{{ selected_product.variants | json | escape }}"
>
  <div id="cwc-product-cards--anchor"></div>
  <div class="cwc-product-cards__container">
    {% if section.settings.section_title != blank %}
      <div class="cwc-product-cards__section-title rte">
        {{ section.settings.section_title }}
      </div>
    {% endif %}

    {% if section.settings.section_subtitle != blank %}
      <div class="cwc-product-cards__section-subtitle rte">
        {{ section.settings.section_subtitle }}
      </div>
    {% endif %}

    {% if selected_product and section.blocks.size > 0 %}
      <form
        action="/cart/add"
        method="post"
        enctype="multipart/form-data"
        class="cwc-product-cards__section__form"
        id="cwc-product-cards__section-{{ section.id }}"
      >
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          class="variant-id-input"
        >
        <div class="cwc-product-cards__grid cwc-product-cards__grid--{{ section.blocks.size }}">
          {% for block in section.blocks %}
            {% liquid
              assign block_variant_id = block.settings.variant_id | times: 1
              assign variant = selected_product.variants | where: 'id', block_variant_id | first
            %}

            {% if variant %}
              {% comment %} Badge text {% endcomment %}
              {% comment %}
                <div class="cwc-product-card__badge">
                  {% if forloop.index0 == 1 %}
                    {{ forloop.index0 }}

                  {% elsif forloop.index0 == 2 %}
                    {{ forloop.index0 }}
                  {% endif %}
                </div>
              {% endcomment %}

              <div
                class="cwc-product-card"
                data-variant-id="{{ variant.id }}"
                data-available="{{ variant.available }}"
                {{ block.shopify_attributes }}
              >
                {% comment %} Badge from block {% endcomment %}
                {% if block.settings.badge != blank %}
                  <div class="cwc-product-card__badge">
                    {{ block.settings.badge }}
                  </div>
                {% endif %}

                {% comment %} Title from block or variant {% endcomment %}
                <div class="cwc-product-card__title">
                  {% if block.settings.title != blank %}
                    {{ block.settings.title }}
                  {% else %}
                    {{ variant.title }}
                  {% endif %}
                </div>

                {% comment %} Pricing from Shopify {% endcomment %}
                <div class="cwc-product-card__pricing">
                  {% if variant.compare_at_price > variant.price %}
                    <span class="cwc-product-card__compare-price">
                      {{ variant.compare_at_price | money }}
                    </span>
                  {% endif %}
                  <span class="cwc-product-card__price">
                    {{ variant.price | money }}
                  </span>

                  {% comment %} Calculate savings {% endcomment %}
                  {% if variant.compare_at_price > variant.price %}
                    {% assign savings = variant.compare_at_price | minus: variant.price %}
                    {% assign savings_percent = savings | times: 100.0 | divided_by: variant.compare_at_price | round %}
                    <span class="cwc-product-card__savings"> Save {{ savings_percent }}% </span>
                  {% endif %}
                </div>

                {% comment %} Bullets {% endcomment %}
                {% liquid
                  assign has_bullets = false
                  if block.settings.bullet_1 != blank or block.settings.bullet_2 != blank or block.settings.bullet_3 != blank or block.settings.bullet_4 != blank or block.settings.bullet_5 != blank
                    assign has_bullets = true
                  endif
                %}

                {% if has_bullets %}
                  <ul class="cwc-product-card__bullets">
                    {% if block.settings.bullet_1 != blank %}
                      <li class="cwc-product-card__bullet rte">{{ block.settings.bullet_1 }}</li>
                    {% endif %}
                    {% if block.settings.bullet_2 != blank %}
                      <li class="cwc-product-card__bullet rte">{{ block.settings.bullet_2 }}</li>
                    {% endif %}
                    {% if block.settings.bullet_3 != blank %}
                      <li class="cwc-product-card__bullet rte">{{ block.settings.bullet_3 }}</li>
                    {% endif %}
                    {% if block.settings.bullet_4 != blank %}
                      <li class="cwc-product-card__bullet rte">{{ block.settings.bullet_4 }}</li>
                    {% endif %}
                    {% if block.settings.bullet_5 != blank %}
                      <li class="cwc-product-card__bullet rte">{{ block.settings.bullet_5 }}</li>
                    {% endif %}
                  </ul>
                {% endif %}

                {% comment %} Button - uses variant URL as fallback for add-to-cart {% endcomment %}
                {% if block.settings.button_text != blank %}
                  <button
                    type="button"
                    class="cwc-product-card__button"
                    data-variant-id="{{ variant.id }}"
                  >
                    {{ block.settings.button_text }}
                  </button>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </form>

    {% else %}
      <p style="text-align: center; padding: 40px;">
        Please select a product and configure blocks in the section settings.
      </p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Card Options",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product",
      "info": "The variants of this product will be used for the cards."
    },
    {
      "type": "checkbox",
      "id": "show_variant_ids",
      "label": "🔧 Show Variant IDs (Developer Mode)",
      "info": "Enable this to see variant IDs, copy them to blocks, then disable",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h2>Choose Your Comeback Plan</h2>"
    },
    {
      "type": "richtext",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "<p>Exclusive pricing for customers who want to restart their progress.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#8b5cf6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background color",
      "default": "#8b5cf6"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "product_option",
      "name": "Product Option",
      "settings": [
        {
          "type": "paragraph",
          "content": "Enter the Variant ID for this option card. Use the 'Show Variant IDs' toggle above for help."
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID",
          "info": "Required - Must match a variant ID from the selected product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "info": "e.g., 'MOST POPULAR' or 'BEST VALUE'"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Custom Title",
          "info": "Optional - Overrides variant title if provided"
        },
        {
          "type": "richtext",
          "id": "bullet_1",
          "label": "Bullet Point 1"
        },
        {
          "type": "richtext",
          "id": "bullet_2",
          "label": "Bullet Point 2"
        },
        {
          "type": "richtext",
          "id": "bullet_3",
          "label": "Bullet Point 3"
        },
        {
          "type": "richtext",
          "id": "bullet_4",
          "label": "Bullet Point 4"
        },
        {
          "type": "richtext",
          "id": "bullet_5",
          "label": "Bullet Point 5"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Get This Deal"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Card Options",
      "category": "Custom",
      "blocks": [{ "type": "product_option" }, { "type": "product_option" }, { "type": "product_option" }]
    }
  ]
}
{% endschema %}
