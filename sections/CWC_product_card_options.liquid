{% style %}
  #CWC_product_card_options-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#F3F4F6' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --accent-color: {{ section.settings.accent_color | default: '#10b981' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_product_card_options.css' | asset_url | stylesheet_tag }}

{% liquid
  assign selected_product = section.settings.product
  assign section_id = section.id
  assign selling_plan_groups = selected_product.selling_plan_groups
%}

{% comment %} Developer Mode - Show Variant IDs (for setup) -UTILITY{% endcomment %}
{% if section.settings.show_variant_ids and selected_product %}
  <div style="background: #fef3c7; border: 2px solid #f59e0b; padding: 20px; margin: 20px; border-radius: 8px;">
    <h3 style="margin: 0 0 10px 0; color: #92400e;">🔧 Developer Mode - Copy Variant IDs:</h3>
    {% for variant in selected_product.variants %}
      <p style="margin: 5px 0; font-family: monospace; color: #78350f;">
        <strong>{{ variant.title }}</strong>:
        <code style="background: #fff; padding: 2px 6px; border-radius: 3px;">{{ variant.id }}</code>
      </p>
    {% endfor %}
    <p style="margin: 10px 0 0 0; font-size: 14px; color: #92400e;">
      ℹ️ Copy the variant ID and paste it into the corresponding block's "Variant ID" field below. Then disable this
      toggle.
    </p>
  </div>
{% endif %}
{% comment %} Developer Mode - Show Variant IDs (for setup) -UTILITY{% endcomment %}
<div id="cwc-product-cards--anchor__OFF"></div>

<section
  id="CWC_product_card_options-{{ section_id }}"
  class="cwc-product-cards"
  data-section-id="{{ section_id }}"
  data-product-id="{{ selected_product.id }}"
  data-variants="{{ selected_product.variants | json | escape }}"
  data-selling-plans="{{ selling_plan_groups | json | escape }}"
  data-skip-cart="{{ section.settings.skip_cart }}"
>
  <div class="cwc-product-cards__container">
    {% comment %} Section Header {% endcomment %}
    {% if section.settings.title != blank %}
      <div class="cwc-product-cards__title rte">
        {{ section.settings.title }}
      </div>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="cwc-product-cards__subtext rte">
        {{ section.settings.subtext }}
      </div>
    {% endif %}

    {% comment %} Subscription Toggle {% endcomment %}
    {% if selling_plan_groups.size > 0 %}
      <div class="cwc-product-cards__toggle-wrapper">
        <span class="cwc-product-cards__toggle-label">One-Time Purchase</span>

        <label class="cwc-product-cards__toggle">
          <input
            type="checkbox"
            id="subscription-toggle-{{ section_id }}"
            class="cwc-product-cards__toggle-input"
            checked
          >
          <span class="cwc-product-cards__toggle-slider"></span>
        </label>

        <span class="cwc-product-cards__toggle-label cwc-product-cards__toggle-label--active">
          {{ section.settings.subscribe_text }}
        </span>
      </div>
    {% endif %}

    {% comment %} Product Cards Grid {% endcomment %}
    {% if selected_product and section.blocks.size > 0 %}
      <form
        action="/cart/add"
        method="post"
        enctype="multipart/form-data"
        class="cwc-product-cards__form"
        id="product-form-{{ section_id }}"
      >
        <input
          type="hidden"
          name="id"
          value="{{ selected_product.selected_or_first_available_variant.id }}"
          class="variant-id-input"
        >
        <input
          type="hidden"
          name="selling_plan"
          value=""
          class="selling-plan-input"
        >

        <div class="cwc-product-cards__grid cwc-product-cards__grid--{{ section.blocks.size }}">
          {% for block in section.blocks %}
            {% assign variant_id = block.settings.variant_id | plus: 0 %}
            {% assign target_variant = null %}
            {% for variant in selected_product.variants %}
              {% if variant.id == variant_id %}
                {% assign target_variant = variant %}
                {% break %}
              {% endif %}
            {% endfor %}

            {% if target_variant %}
              <div
                class="
                  cwc-product-cards__card

                  {% if forloop.index == 1 %} cwc-product-cards__card--1{% endif %}
                  {% if forloop.index == 2 %} cwc-product-cards__card--2{% endif %}
                  {% if forloop.index == 3 %} cwc-product-cards__card--3{% endif %}
                "
                data-variant-id="{{ target_variant.id }}"
                data-price="{{ target_variant.price }}"
                data-compare="{{ target_variant.compare_at_price }}"
                data-available="{{ target_variant.available }}"
                {{ block.shopify_attributes }}
              >
                {% comment %} Badge {% endcomment %}
                {% if block.settings.badge != blank %}
                  <div class="cwc-product-cards__badge">
                    {{ block.settings.badge }}
                  </div>
                {% endif %}

                {% comment %} Title {% endcomment %}
                {% if block.settings.title != blank %}
                  <div class="cwc-product-cards__card-title">
                    {{ block.settings.title }}
                  </div>
                {% else %}
                  <div class="cwc-product-cards__card-title">
                    {{ target_variant.title }}
                  </div>
                {% endif %}

                {% comment %} Product Image {% endcomment %}
                <div class="cwc-product-cards__image">
                  {% if block.settings.custom_image != blank %}
                    {%- comment -%} Use custom image from block settings {%- endcomment -%}
                    <img
                      src="{{ block.settings.custom_image | image_url: width: 400 }}"
                      alt="{{ block.settings.custom_image.alt | default: target_variant.title }}"
                      loading="lazy"
                      priority="meduim"
                      class="cwc-product-cards__img"
                      height="{{ block.settings.custom_image.height }}"
                      width="{{ block.settings.custom_image.width }}"
                    >
                  {% elsif target_variant.featured_image %}
                    {%- comment -%} Use variant's featured image {%- endcomment -%}
                    <img
                      src="{{ target_variant.featured_image | image_url: width: 400 }}"
                      alt="{{ target_variant.featured_image.alt | default: target_variant.title }}"
                      loading="lazy"
                      priority="meduim"

                      class="cwc-product-cards__img"
                      height="{{ target_variant.featured_image.height }}"
                      width="{{ target_variant.featured_image.width }}"
                    >
                  {% elsif selected_product.featured_image %}
                    {%- comment -%} Fallback to product's featured image {%- endcomment -%}
                    <img
                      src="{{ selected_product.featured_image | image_url: width: 400 }}"
                      alt="{{ selected_product.featured_image.alt | default: selected_product.title }}"
                      loading="lazy"
                      class="cwc-product-cards__img"
                      height="{{ selected_product.featured_image.height }}"
                      width="{{ selected_product.featured_image.width }}"
                    >
                  {% endif %}
                </div>

                {% comment %} Pricing {% endcomment %}
                <div class="cwc-product-cards__pricing">
                  <div class="cwc-product-cards__price-main" data-price-display>
                    {{ target_variant.price | money }}
                  </div>

                  {% if block.settings.price_subtext != blank or block.settings.price_subtext_onetime != blank %}
                    <div
                      class="cwc-product-cards__price-subtext"
                      data-subtext-subscription="{{ block.settings.price_subtext | escape }}"
                      data-subtext-onetime="{{ block.settings.price_subtext_onetime | escape }}"
                    >
                      {%- comment -%} Default to subscription text if toggle starts checked {%- endcomment -%}
                      {{ block.settings.price_subtext }}
                    </div>
                  {% endif %}
                </div>

                {% comment %} Description Text {% endcomment %}
                {% if block.settings.text != blank %}
                  <div class="cwc-product-cards__card-text rte">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% comment %} Button {% endcomment %}

                {% if block.settings.button_text != blank %}
                  <button
                    type="button"
                    class="cwc-product-cards__button"
                    data-variant-id="{{ target_variant.id }}"
                    {% unless target_variant.available %}
                      disabled
                    {% endunless %}
                  >
                    {% if target_variant.available %}
                      {{ block.settings.button_text }}
                    {% else %}
                      Sold Out
                    {% endif %}
                  </button>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </form>
    {% else %}
      <h3 class="rte" style="text-align: center; padding: 40px;">
        Please select a product and configure blocks in the section settings.
      </h3>
    {% endif %}
  </div>
</section>
{{ 'CWC_product_card_options.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Product Card Options",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Product",
      "info": "Product variants will be used for the cards"
    },
    {
      "type": "checkbox",
      "id": "show_variant_ids",
      "label": "🔧 Show Variant IDs (Developer Mode)",
      "info": "Enable this to see variant IDs, copy them to blocks, then disable",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Section Title",
      "default": "<h2>Ready to Start Healing Your Teeth?</h2>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Section Subtext",
      "default": "<p>Choose the option that works best for you. All orders include free shipping and our 365-day guarantee.</p>"
    },
    {
      "type": "text",
      "id": "subscribe_text",
      "label": "Subscribe text",
      "default": "Subscribe & Save 25%"
    },
    {
      "type": "checkbox",
      "id": "skip_cart",
      "label": "Skip cart and go directly to checkout",
      "default": false,
      "info": "When enabled, customers will be redirected to checkout immediately after adding to cart"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (toggle, outlines)",
      "default": "#10b981"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product_option",
      "name": "Product Option Card",
      "limit": 3,
      "settings": [
        {
          "type": "paragraph",
          "content": "This card will display a specific product variant based on the option value you enter below."
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID",
          "info": "Enter the variant ID (enable Developer Mode above to see IDs)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "info": "e.g., 'Most Popular' or 'Best Value'"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)",
          "info": "Override variant image. Leave blank to use variant's featured image."
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon/Label Text",
          "info": "e.g., '1 Tube', '2 Tubes'"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "info": "Leave blank to use variant title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description Text"
        },
        {
          "type": "text",
          "id": "price_subtext_onetime",
          "label": "Price Subtext (One-Time)",
          "info": "Text below price for one-time purchase (e.g., 'One-time purchase' or leave blank)"
        },
        {
          "type": "text",
          "id": "price_subtext",
          "label": "Price Subtext",
          "info": "Text below price (e.g., 'Delivered every 60 days')"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "info": "Get Started"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Card Options",
      "category": "Custom",
      "blocks": [
        {
          "type": "product_option",
          "settings": {
            "title": "Single Tube",
            "icon_text": "1 Tube",
            "price_subtext_onetime": "Clinically Backed",
            "price_subtext": "Delivered every 60 days"
          }
        },
        {
          "type": "product_option",
          "settings": {
            "badge": "Most Popular",
            "title": "2-Pack Bundle",
            "icon_text": "2 Tubes",
            "price_subtext_onetime": "$13.50/tube",
            "price_subtext": "$13.50/tube • Every 120 days"
          }
        },
        {
          "type": "product_option",
          "settings": {
            "badge": "Best Value",
            "title": "3-Pack Bundle",
            "icon_text": "3 Tubes",
            "price_subtext_onetime": "$12.67/tube",
            "price_subtext": "$12.67/tube • Every 180 days"
          }
        }
      ]
    }
  ]
}
{% endschema %}
