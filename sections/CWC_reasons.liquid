{% style %}
  #CWC_reasons-{{ section.id }} {
  --padding-top: {{ section.settings.padding_top | default: 60 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
  --section-bg: {{ section.settings.section_bg }};
  --heading-color: {{ section.settings.heading_color }};
  --text-color: {{ section.settings.text_color }};
  --card-bg: {{ section.settings.card_bg }};
  --card-text: {{ section.settings.card_text }};
  --caption-bg: {{ section.settings.caption_bg }};
  --caption-color: {{ section.settings.caption_color }};
  }
{% endstyle %}

{{ 'CWC_reasons.css' | asset_url | stylesheet_tag }}

<section id="CWC_reasons-{{ section.id }}" class="cwc-reasons">
  <div class="cwc-reasons__wrapper">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'caption' %}
          {% if block.settings.text != blank %}
            <div
              class="cwc-reasons__caption"
              {{ block.shopify_attributes }}
              style="background-color: {{ block.settings.caption_bg }}; color: {{ block.settings.caption_color }}"
            >
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% when 'heading' %}
          {% if block.settings.text != blank %}
            <div
              class="cwc-reasons__heading"
              {{ block.shopify_attributes }}
              style="color: {{ block.settings.heading_color }}"
            >
              {{ block.settings.text }}
            </div>
          {% endif %}

        {% when 'text' %}
          {% if block.settings.text != blank %}
            <div
              class="cwc-reasons__text"
              {{ block.shopify_attributes }}
              style="color: {{ block.settings.text_color }}"
            >
              {{ block.settings.text }}
            </div>
          {% endif %}
      {% endcase %}
    {% endfor %}

    <!-- Grid of reason cards -->
    <div class="cwc-reasons__grid">
      {% for block in section.blocks %}
        {% if block.type == 'reason' %}
          <div class="cwc-reasons__card" {{ block.shopify_attributes }}>
            <div class="cwc-reasons__content">
              <!-- FRONT -->
              <div class="cwc-reasons__front">
                {% if block.settings.img != blank %}
                  <div class="cwc-reasons__image">
                    <img
                      loading="lazy"
                      fetchpriority="medium"
                      src="{{ block.settings.img | image_url: width: 300   }}"
                      alt="{{ block.settings.title | escape }}"
                      width="{{ block.settings.img.width }}"
                      height="{{ block.settings.img.height }}"
                    >
                  </div>
                {% else %}
                  <div class="cwc-reasons__image">
                    <img
                      loading="lazy"
                      fetchpriority="medium"
                      src="{{ 'round-placeholder.png' | asset_url }}"
                      alt="{{ block.settings.title | escape }}"
                      width="{{ block.settings.img.width }}"
                      height="{{ block.settings.img.height }}"
                    >
                  </div>
                {% endif %}

                {% if block.settings.badge != blank or block.settings.title != blank %}
                  <div class="cwc-reasons-content">
                    {% if block.settings.badge != blank %}
                      <div
                        class="cwc-reasons__badge"
                        style="background-color: {{ block.settings.badge_bg }}; color: {{ block.settings.badge_color }}"
                      >
                        {{ block.settings.badge }}
                      </div>
                    {% endif %}

                    {% if block.settings.title != blank %}
                      <h3 class="cwc-reasons__title">{{ block.settings.title }}</h3>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
            <!-- BACK -->
            <div class="cwc-reasons__back">
              {% if block.settings.text != blank %}
                <div class="cwc-reasons__desc">{{ block.settings.text }}</div>
              {% endif %}
            </div>
            <!-- Toggle button always at bottom -->
            <button class="toggle-button" aria-expanded="false">
              <span class="cwc-icon-plus">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                      d="M5.72069 11.033V5.96898H0.656637V5.38515H5.72069V0.321103H6.30451V5.38515H11.3686V5.96898H6.30451V11.033H5.72069Z"
                      fill="black"></path>
                </svg>
              </span>
              <span class="cwc-icon-minus" style="display:none;">
                <svg width="8" height="1" viewBox="0 0 8 1" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.97719 0.0678547V0.65168H0.920525V0.0678547H7.97719Z" fill="black"></path>
                </svg>
              </span>
            </button>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- CTA block(s) below grid -->
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'button' %}
          <div class="cwc-reasons__cta" {{ block.shopify_attributes }}>
            {% render 'CWC_button', product: product, section_id: section.id, block: block %}
          </div>

        {% when 'guarantee_text' %}
          <div class="cwc_product-template__guarantee_text" {{ block.shopify_attributes }}>
            {% comment %} {%- render 'CWC_icon-check_badge', fill: '#fff' -%} {% endcomment %}

            {% render 'CWC_guarantee_text', product: product, section_id: section.id, block: block %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{{ 'CWC_reasons.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC Reasons",
  "settings": [
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "card_text",
      "label": "Card text color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "caption",
      "name": "Caption",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Caption text",
          "default": "Why Choose Us?"
        },
        {
          "type": "color",
          "id": "caption_bg",
          "label": "Caption background",
          "default": "#60A1A2"
        },
        {
          "type": "color",
          "id": "caption_color",
          "label": "Caption text color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Heading text",
          "default": "<p>The Reasons Customers Love Us</p>"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#111111"
        }
      ]
    },
    {
      "type": "text",
      "name": "Intro text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Intro text",
          "default": "<p>Here’s what sets us apart from other brands.</p>"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#444444"
        }
      ]
    },
    {
      "type": "reason",
      "name": "Reason card",
      "settings": [
        {
          "type": "image_picker",
          "id": "img",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Reason 1"
        },
        {
          "type": "color",
          "id": "badge_bg",
          "label": "Badge background",
          "default": "#60A1A2"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Badge text color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Reason title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Explain this reason in 1–2 short sentences.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Call to action",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#125657"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "guarantee_text",
      "name": "Guarantee Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "365-day money back guarantee"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reasons",
      "category": "Custom",
      "blocks": [
        {
          "type": "caption"
        },
        {
          "type": "heading"
        },
        {
          "type": "reason",
          "settings": {
            "badge": "Reason 1'"
          }
        },
        {
          "type": "reason",
          "settings": {
            "badge": "Reason 2'"
          }
        },
        {
          "type": "reason",
          "settings": {
            "badge": "Reason 3'"
          }
        },
        {
          "type": "reason",
          "settings": {
            "badge": "Reason 4'"
          }
        },
        {
          "type": "reason",
          "settings": {
            "badge": "Reason 5'"
          }
        },
        {
          "type": "button"
        },
        {
          "type": "guarantee_text"
        }
      ]
    }
  ]
}
{% endschema %}
