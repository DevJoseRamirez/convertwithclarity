        },
        {
          "type": "textarea",
          "id": "review_text_2",
          "label": "Review Text 2"
        },
        {
          "type": "text",
          "id": "review_author_2",
          "label": "Author 2",
          "default": "Julie S."
        },
        {
          "type": "text",
          "id": "review_title_3",
          "label": "Review Title 3",
          "default": "Best sleep ever"
        },
        {
          "type": "textarea",
          "id": "review_text_3",
          "label": "Review Text 3"
        },
        {
          "type": "text",
          "id": "review_author_3",
          "label": "Author 3",
          "default": "Nat T."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Tabs",
      "category": "Custom",
      "blocks": [
        {
          "type": "tab"
        },
        {
          "type": "tab"
        },
        {
          "type": "tab"
        }
      ]
    }
  ]
}
{% endschema %}
