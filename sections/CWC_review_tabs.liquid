{% style %}
  #CWC_review_tabs-{{ section.id }} {
    --section-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#000000' }};
    --card-bg: {{ section.settings.card_background_color | default: '#ffffff' }};
    --highlight-color: {{ section.settings.highlight_color | default: '#009370' }};
    --button-active-bg: {{ section.settings.button_active_color | default: '#60A1A2' }};
    --button-active-text: {{ section.settings.button_active_text_color | default: '#ffffff' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.6 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.6 }}px;
  }
{% endstyle %}

{{ 'CWC_review_tabs.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_review_tabs-{{ section.id }}"
  class="cwc-review-tabs"
  data-section-id="{{ section.id }}"
>
  <div class="cwc-review-tabs__container">
    {% if section.settings.show_stars %}
      <div class="cwc-review-tabs__head-stars">
        {% render 'CWC_trust_stars' %}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="cwc-review-tabs__section-title rte">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="cwc-review-tabs__section-subtitle rte">
        {{ section.settings.subtext }}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="cwc-review-tabs__buttons">
        {% for block in section.blocks %}
          {% if block.settings.tab_title != blank %}
            <button
              {{ block.shopify_attributes }}
              class="cwc-review-tabs__button{% if forloop.first %} active{% endif %}"
              data-tab="{{ block.id }}"
              aria-label="{{ block.settings.tab_title }}"
            >
              {{ block.settings.tab_title }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      {% for block in section.blocks %}
        <div
          class="cwc-review-tabs__grid{% if forloop.first %} active{% endif %}"
          data-content="{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {% for i in (1..3) %}
            {% liquid
              # Build setting keys dynamically
              assign rating_key = 'review_rating_' | append: i
              assign title_key = 'review_title_' | append: i
              assign text_key = 'review_text_' | append: i
              assign author_key = 'review_author_' | append: i
              assign image_key = 'review_author_image_' | append: i
              assign tag1_key = 'review_tag1_' | append: i
              assign tag2_key = 'review_tag2_' | append: i

              # Get values
              assign card_rating = block.settings[rating_key] | default: '5.0'
              assign card_title = block.settings[title_key]
              assign card_text = block.settings[text_key]
              assign card_author = block.settings[author_key]
              assign card_image = block.settings[image_key]
              assign card_tag1 = block.settings[tag1_key]
              assign card_tag2 = block.settings[tag2_key]
            %}

            {% comment %} Only render card if it has content {% endcomment %}
            {% if card_title != blank or card_text != blank %}
              <div class="cwc-review-tabs__card">
                <div class="cwc-review-tabs__card-top">
                  {% comment %} Rating {% endcomment %}
                  <div class="cwc-review-tabs__rating">
                    <span class="cwc-review-tabs__rating-text">{{ card_rating }}</span>
                    {% render 'CWC_trust_stars' %}
                  </div>

                  {% comment %} Title {% endcomment %}
                  {% if card_title != blank %}
                    <h3 class="cwc-review-tabs__card-title">"{{ card_title }}"</h3>
                  {% endif %}

                  {% comment %} Text {% endcomment %}
                  {% if card_text != blank %}
                    <p class="cwc-review-tabs__card-text">{{ card_text }}</p>
                  {% endif %}
                </div>

                <div class="cwc-review-tabs__card-bottom">
                  {% comment %} Author Row {% endcomment %}
                  <div class="cwc-review-tabs__author-wrapper">
                    <div class="cwc-review-tabs__author">
                      {% if card_image != blank %}
                        <img
                          src="{{ card_image | image_url: width: 36 }}"
                          alt="{{ card_author }}"
                          width="36"
                          height="36"
                          loading="lazy"
                        >
                      {% else %}
                        {% comment %} Letter avatar with rotating colors {% endcomment %}
                        {% assign color_index = i | modulo: 4 %}
                        {% case color_index %}
                          {% when 1 %}
                            {% assign avatar_color = '#2EB67D' %}
                          {% when 2 %}
                            {% assign avatar_color = '#E01E5A' %}
                          {% when 3 %}
                            {% assign avatar_color = '#36C5F0' %}
                          {% else %}
                            {% assign avatar_color = '#ECB22E' %}
                        {% endcase %}
                        <div
                          class="cwc-review-tabs__author-letter"
                          style="background: {{ avatar_color }}"
                        >
                          {{ card_author | slice: 0 }}
                        </div>
                      {% endif %}
                      <span class="cwc-review-tabs__author-name">{{ card_author }}</span>
                    </div>

                    <div class="cwc-review-tabs__verified">
                      <span class="cwc-review-tabs__verified-icon">
                        {% render 'CWC_icon-check_badge-fill', fill_color: '#009370' %}
                      </span>
                      <span class="cwc-review-tabs__verified-text">Verified Customer</span>
                    </div>
                  </div>

                  {% comment %} Tags {% endcomment %}
                  {% if card_tag1 != blank or card_tag2 != blank %}
                    <div class="cwc-review-tabs__tags">
                      {% if card_tag1 != blank %}
                        <span class="cwc-review-tabs__tag">{{ card_tag1 }}</span>
                      {% endif %}
                      {% if card_tag2 != blank %}
                        <span class="cwc-review-tabs__tag">{{ card_tag2 }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    {% else %}
      <div class="cwc-review-tabs__empty">
        <p>Add review tab blocks to display customer reviews.</p>
      </div>
    {% endif %}
  </div>
</section>

{{ 'CWC_review_tabs.js' | asset_url | script_tag }}

