{% style %}
  #CWC_review_tabs-{{ section.id }} {
    --section-bg: {{ section.settings.background_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#000000' }};
    --card-bg: {{ section.settings.card_background_color | default: '#E2EBED' }};
    --star-color: {{ section.settings.star_color | default: '#F97316' }};
    --button-active-bg: {{ section.settings.button_active_color | default: '#d47442' }};
    --button-active-text: {{ section.settings.button_active_text_color | default: '#ffffff' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_review_tabs.css' | asset_url | stylesheet_tag }}

{% comment %} ================================
   SECTION: CWC Review Tabs
   Purpose: Tabbed customer reviews by category
   ================================ {% endcomment %}

<section
  id="CWC_review_tabs-{{ section.id }}"
  class="cwc-review-tabs"
  data-section-id="{{ section.id }}"
>
  <div class="cwc-review-tabs__container">
    {% comment %} ==============================
       Section Header
       ============================== {% endcomment %}
    {% if section.settings.heading != blank or section.settings.subtext != blank %}
      <div class="cwc-review-tabs__header">
        {% if section.settings.heading != blank %}
          <h2 class="cwc-review-tabs__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subtext != blank %}
          <p class="cwc-review-tabs__subtext">
            {{ section.settings.subtext }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} ==============================
       Tab Buttons
       ============================== {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="cwc-review-tabs__buttons">
        {% for block in section.blocks %}
          {% if block.settings.tab_title != blank %}
            <button
              class="cwc-review-tabs__button{% if forloop.first %} active{% endif %}"
              data-tab="{{ block.id }}"
              aria-label="{{ block.settings.tab_title }}"
            >
              {{ block.settings.tab_title }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} ==============================
         Tab Content (Review Grids)
         ============================== {% endcomment %}
      {% for block in section.blocks %}
        <div
          class="cwc-review-tabs__grid{% if forloop.first %} active{% endif %}"
          data-content="{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {% comment %} Review Card 1 {% endcomment %}
          {% if block.settings.review_title_1 != blank or block.settings.review_text_1 != blank %}
            <div class="cwc-review-tabs__card">
              <div class="cwc-review-tabs__stars" aria-label="5 star rating">
                ★★★★★
              </div>

              {% if block.settings.review_title_1 != blank %}
                <h4 class="cwc-review-tabs__card-title">
                  {{ block.settings.review_title_1 }}
                </h4>
              {% endif %}

              {% if block.settings.review_text_1 != blank %}
                <p class="cwc-review-tabs__card-text">
                  {{ block.settings.review_text_1 }}
                </p>
              {% endif %}

              {% if block.settings.review_author_1 != blank %}
                <cite class="cwc-review-tabs__card-author">
                  – {{ block.settings.review_author_1 }}
                </cite>
              {% endif %}
            </div>
          {% endif %}

          {% comment %} Review Card 2 {% endcomment %}
          {% if block.settings.review_title_2 != blank or block.settings.review_text_2 != blank %}
            <div class="cwc-review-tabs__card">
              <div class="cwc-review-tabs__stars" aria-label="5 star rating">
                ★★★★★
              </div>

              {% if block.settings.review_title_2 != blank %}
                <h4 class="cwc-review-tabs__card-title">
                  {{ block.settings.review_title_2 }}
                </h4>
              {% endif %}

              {% if block.settings.review_text_2 != blank %}
                <p class="cwc-review-tabs__card-text">
                  {{ block.settings.review_text_2 }}
                </p>
              {% endif %}

              {% if block.settings.review_author_2 != blank %}
                <cite class="cwc-review-tabs__card-author">
                  – {{ block.settings.review_author_2 }}
                </cite>
              {% endif %}
            </div>
          {% endif %}

          {% comment %} Review Card 3 {% endcomment %}
          {% if block.settings.review_title_3 != blank or block.settings.review_text_3 != blank %}
            <div class="cwc-review-tabs__card">
              <div class="cwc-review-tabs__stars" aria-label="5 star rating">
                ★★★★★
              </div>

              {% if block.settings.review_title_3 != blank %}
                <h4 class="cwc-review-tabs__card-title">
                  {{ block.settings.review_title_3 }}
                </h4>
              {% endif %}

              {% if block.settings.review_text_3 != blank %}
                <p class="cwc-review-tabs__card-text">
                  {{ block.settings.review_text_3 }}
                </p>
              {% endif %}

              {% if block.settings.review_author_3 != blank %}
                <cite class="cwc-review-tabs__card-author">
                  – {{ block.settings.review_author_3 }}
                </cite>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="cwc-review-tabs__empty">
        <p>Add review tab blocks to display customer reviews.</p>
      </div>
    {% endif %}
  </div>
</section>

{{ 'CWC_review_tabs.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Review Tabs",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "People Love ENRICHD"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Backed by hundreds of customers who feel the difference every day."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background Color",
      "default": "#E2EBED"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#F97316"
    },
    {
      "type": "color",
      "id": "button_active_color",
      "label": "Active Tab Button Color",
      "default": "#d47442"
    },
    {
      "type": "color",
      "id": "button_active_text_color",
      "label": "Active Tab Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Review Tab",
      "settings": [
        {
          "type": "paragraph",
          "content": "Each tab displays 3 customer reviews in a grid layout."
        },
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Button Title",
          "default": "Category Name",
          "info": "Text shown on the tab button"
        },
        {
          "type": "header",
          "content": "Review 1"
        },
        {
          "type": "text",
          "id": "review_title_1",
          "label": "Review Title",
          "default": "Amazing product"
        },
        {
          "type": "textarea",
          "id": "review_text_1",
          "label": "Review Text",
          "default": "This product exceeded my expectations. Highly recommend!"
        },
        {
          "type": "text",
          "id": "review_author_1",
          "label": "Author Name",
          "default": "Sam H."
        },
        {
          "type": "header",
          "content": "Review 2"
        },
        {
          "type": "text",
          "id": "review_title_2",
          "label": "Review Title",
          "default": "My new favorite"
        },
        {
          "type": "textarea",
          "id": "review_text_2",
          "label": "Review Text",
          "default": "Can't imagine my routine without this now."
        },
        {
          "type": "text",
          "id": "review_author_2",
          "label": "Author Name",
          "default": "Julie S."
        },
        {
          "type": "header",
          "content": "Review 3"
        },
        {
          "type": "text",
          "id": "review_title_3",
          "label": "Review Title",
          "default": "Best decision"
        },
        {
          "type": "textarea",
          "id": "review_text_3",
          "label": "Review Text",
          "default": "Worth every penny. Results speak for themselves."
        },
        {
          "type": "text",
          "id": "review_author_3",
          "label": "Author Name",
          "default": "Nat T."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Tabs",
      "category": "Custom",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_title": "Protein"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Greens"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Collagen"
          }
        }
      ]
    }
  ]
}
{% endschema %}
