{% style %}
  #CWC_row_cards-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --card-bg: {{ section.settings.card_bg_color | default: '#fcfcfc' }};
    --text-color: {{ section.settings.text_color | default: '#111111' }};
    --icon-bg: {{ section.settings.icon_bg_color | default: '#D1F4F0' }};
    --padding-top: {{ section.settings.padding_top | default: 60 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_row_cards.css' | asset_url | stylesheet_tag }}

<section
  id="CWC_row_cards-{{ section.id }}"
  class="cwc-row-cards"
>
  <div class="cwc-row-cards__container">
    {% if section.settings.section_title != blank %}
      <div class="cwc-row-cards__section-title rte">
        {{ section.settings.section_title }}
      </div>
    {% endif %}

    {% if section.settings.section_subtitle != blank %}
      <div class="cwc-row-cards__section-subtitle rte">
        {{ section.settings.section_subtitle }}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="cwc-row-cards__grid cwc-row-cards__grid--{{ section.blocks.size }}">
        {% for block in section.blocks %}
          <div class="cwc-row-cards__card" {{ block.shopify_attributes }}>
            {% comment %} Icon Circle {% endcomment %}
            {% if block.settings.image_icon != blank %}
              <div class="cwc-row-cards__icon-wrapper">
                <img
                  src="{{ block.settings.image_icon | image_url: width: 80 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                  width="80"
                  height="80"
                >
              </div>
            {% elsif block.settings.text_icon != blank %}
              <div class="cwc-row-cards__icon-wrapper">
                {{ block.settings.text_icon }}
              </div>
            {% endif %}

            {% comment %} Card Title {% endcomment %}
            {% if block.settings.title != blank %}
              <div class="cwc-row-cards__card-title rte">
                {{ block.settings.title }}
              </div>
            {% endif %}

            {% comment %} Card Text {% endcomment %}
            {% if block.settings.text != blank %}
              <div class="cwc-row-cards__card-text rte">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Row Cards",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "section_title",
      "label": "Section Title",
      "default": "<h2>The Ollie Advantage: Right Concentration, Right Shape, Right Price</h2>"
    },
    {
      "type": "richtext",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "<p>Not all hydroxyapatite toothpastes are created equal. Here's what makes Ollie different.</p>"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background color",
      "default": "#fcfcfc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "#D1F4F0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_icon",
          "label": "Icon Image",
          "info": "Recommended: 80x80px or larger square image"
        },
        {
          "type": "text",
          "id": "text_icon",
          "label": "Icon",
          "default": "<h3>💪</h3>"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<h3>True 10% Concentration</h3>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Most brands use 1-5%. Ollie delivers a full 10% nano-hydroxyapatite—the clinically proven amount for real remineralization.</p>"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Row Cards",
      "category": "Custom",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
