{% style %}
  #cwc_services-cards-{{ section.id }} {
    --section-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --text-color: {{ section.settings.text_color | default: '#0a0a0a' }};
    --highlight-color: {{ section.settings.bold_color | default: '#14a800' }};
    --rule-color: {{ section.settings.rule_color | default: '#e5e5e5' }};
    --number-color: {{ section.settings.number_color | default: '#cfcfcf' }};
    --link-color: {{ section.settings.link_color | default: '#0a0a0a' }};
    --padding-top: {{ section.settings.padding_top | default: 80 }}px;
    --padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    --padding-top-mobile: {{ section.settings.padding_top | default: 80 | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | default: 80 | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_services_cards.css' | asset_url | stylesheet_tag }}

<section id="cwc_services-cards-{{ section.id }}" class="cwc_services-cards">
  <div class="cwc_services-cards__container">
    {% comment %} Section Header {% endcomment %}
    <div class="cwc_services-cards__content">
      {% if section.settings.eyebrow != blank %}
        <div class="cwc_services-cards__eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="cwc_services-cards__content-heading rte">
          {{ section.settings.heading }}
        </div>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <div class="cwc_services-cards__content-subtext rte">
          {{ section.settings.subtext }}
        </div>
      {% endif %}
    </div>

    {% comment %} Service Cards Grid {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="cwc_services-cards__grid">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'service' %}
              <div class="cwc_services-cards__card" {{ block.shopify_attributes }}>
                <div class="cwc_services-cards__card-number">
                  {{ forloop.index | prepend: '0' | slice: -2, 2 }}
                </div>

                {% if block.settings.title != blank %}
                  <div class="cwc_services-cards__card-title rte">
                    {{ block.settings.title }}
                  </div>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="cwc_services-cards__card-text rte">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                  <a
                    href="{{ block.settings.link_url }}"
                    class="cwc_services-cards__card-link"
                    {% if block.settings.link_new_tab %}
                      target="_blank" rel="noopener"
                    {% endif %}
                  >
                    <span class="cwc_services-cards__card-link-label">{{ block.settings.link_label }}</span>
                    <svg
                      class="cwc_services-cards__card-link-arrow"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      focusable="false"
                    >
                      <path d="M5 12h14M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Services Cards",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "03 / Services"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Section Heading",
      "info": "Wrap any words you want accented in <strong> tags.",
      "default": "<p>Three ways I help brands <strong>convert more.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Section Subtext",
      "info": "Optional. Leave blank to hide.",
      "default": "<p></p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Heading Highlight Color",
      "default": "#14a800"
    },
    {
      "type": "color",
      "id": "rule_color",
      "label": "Hairline Rule Color",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Card Number Color",
      "default": "#cfcfcf"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Card Link Color",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "label": "Service Title",
          "default": "<p>Service Title</p>"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Service Description",
          "default": "<p>Description of the service goes here. Keep it tight and focused on the outcome.</p>"
        },
        {
          "type": "header",
          "content": "Optional Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "info": "Leave blank to hide the link."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "checkbox",
          "id": "link_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "CWC Services Cards",
      "category": "CWC Custom",
      "blocks": [{ "type": "service" }, { "type": "service" }, { "type": "service" }]
    }
  ]
}
{% endschema %}
