{% comment %}
  🔧 SECTION TEMPLATE: CWC_store_benefit_cards.liquid
  Displays 3 benefit cards in a clean layout, stacking on mobile.
{% endcomment %}

<style>
  .cwc_store_benefit_cards-wrapper {
    padding: 0 2rem;
  }

  .cwc_store_benefit_cards-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cwc_store_benefit_cards-heading {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 2.5rem;
    color: {{ section.settings.heading_color }};
  }

  .cwc_store_benefit_cards-grid {
    display: grid;
    gap: 2rem;
    gap: 1.5rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .cwc_store_benefit_cards-block {
    background-color: {{ section.settings.card_background }};
    border: 1px solid #C8C8C8;
    padding: 2rem;
    border-radius: 6px;
    text-align: center;
  }

  .cwc_store_benefit_cards-block img,
  .cwc_store_benefit_cards-block .emoji {
    margin-bottom: 1rem;
    font-size: 2rem;
  }

  .cwc_store_benefit_cards-block h4 {
    font-weight: 700;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .cwc_store_benefit_cards-block p {
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media screen and (max-width: 767px) {
      .cwc_store_benefit_cards-wrapper {
    padding: 0 1rem;
  }

    .cwc_store_benefit_cards-heading {
      font-size: 1.5rem;
    }

    .cwc_store_benefit_cards-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>

{%- style -%}
  #cwc_store_benefit_cards-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div id="cwc_store_benefit_cards-{{ section.id }}" class="cwc_store_benefit_cards">
  <div class="cwc_store_benefit_cards-wrapper">
    <div class="cwc_store_benefit_cards-inner">
      {% if section.settings.heading != blank %}
        <h2 class="cwc_store_benefit_cards-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      <div class="cwc_store_benefit_cards-grid">
        {% for block in section.blocks %}
          <div class="cwc_store_benefit_cards-block" {{ block.shopify_attributes }}>
            {% if block.settings.icon_image != blank %}
              <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="" loading="lazy">
            {% elsif block.settings.icon_emoji != blank %}
              <div class="emoji">{{ block.settings.icon_emoji }}</div>
            {% endif %}

            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Store Benefit Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why ENRICHD?"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#DD7544"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#E2EBED"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Sourced from nature, never compromised."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "All our mushrooms are either wild-foraged or wood-grown in pristine conditions."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Benefit Cards",
      "category": "Custom",
      "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }]
    }
  ]
}
{% endschema %}
