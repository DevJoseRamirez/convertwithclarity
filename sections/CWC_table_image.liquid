{% style %}
  #CWC_table_image-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --text-color: {{ section.settings.text_color }};
  --bold-color: {{ section.settings.bold_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_table_image.css' | asset_url | stylesheet_tag }}

<section id="CWC_table_image-{{ section.id }}" class="cwc_table_image">
  <div class="cwc_table_image-wrapper">
    {% if section.settings.title != blank or section.settings.text != blank %}
      <div class="cwc_table_image-header">
        {% if section.settings.title != blank %}
          <div class="cwc_table_image-title">{{ section.settings.title }}</div>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="cwc_table_image-text">{{ section.settings.text }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.image != blank %}
      <div class="cwc_table_image-image">
        {% if section.settings.image_mobile != blank %}
          <picture>
            <source media="(max-width: 768px)" srcset="{{ section.settings.image_mobile | image_url }}">
            <img
              src="{{ section.settings.image | image_url }}"
              alt="{{ section.settings.image.alt | default: 'Comparison table' }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              loading="lazy"
            >
          </picture>
        {% else %}
          <img
            src="{{ section.settings.image | image_url }}"
            alt="{{ section.settings.image.alt | default: 'Comparison table' }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CWC Table Image",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Section Title",
      "default": "<h3>How It Stacks Up Against The Big Brands</h3>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Section Text",
      "default": "<p><strong>Yo Fruits Yo Veggies</strong> delivers <strong>6–8x more real fruit + veggie nutrition</strong> than leading brands — in a <strong>clean</strong>, plastic-free, <strong>certified organic formula</strong>. No fluff. Just food.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Table Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Table Image (Mobile - Optional)",
      "info": "If provided, this image will be shown on mobile devices (768px and below)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Bold Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Table Image",
      "category": "Custom"
    }
  ]
}
{% endschema %}
