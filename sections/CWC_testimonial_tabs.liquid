{% style %}
  #CWC_testimonial_tabs-{{ section.id }} {
  --section-bg: {{ section.settings.background_color }};
  --text-color: {{ section.settings.text_color }};
  --card-bg: {{ section.settings.card_background_color }};
  --star-color: {{ section.settings.star_color }};
  --button-bg: {{ section.settings.button_bg_color }};
  --button-text: {{ section.settings.button_text_color }};
  --button-active-bg: {{ section.settings.button_active_bg_color }};
  --button-active-text: {{ section.settings.button_active_text_color }};
  --padding-top: {{ section.settings.padding_top }}px;
  --padding-bottom: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_testimonial_tabs.css' | asset_url | stylesheet_tag }}

<section id="CWC_testimonial_tabs-{{ section.id }}" class="cwc_testimonial_tabs">
  <div class="cwc_testimonial_tabs-wrapper">
    <div class="cwc_testimonial_tabs-inner">
      {% if section.settings.heading != blank or section.settings.subtext != blank %}
        <div class="cwc_testimonial_tabs-header">
          {% if section.settings.caption != blank %}
            <div
              class="cwc_testimonial_tabs-caption"
              style="
                --caption_color: {{ section.settings.caption_color }};
                --caption_bold_color: {{ section.settings.caption_bold_color }};
              "
            >
              {{ section.settings.caption }}
            </div>
          {% endif %}
          {% if section.settings.heading != blank %}
            <div
              class="cwc_testimonial_tabs-heading"
              style="
                --title_color: {{ section.settings.title_color }};
                --bold_color: {{ section.settings.bold_color }};
              "
            >
              {{ section.settings.heading }}
            </div>
          {% endif %}
          {% if section.settings.subtext != blank %}
            <div class="cwc_testimonial_tabs-subtext">{{ section.settings.subtext }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.blocks.size > 1 %}
        <div class="cwc_testimonial_tabs-buttons">
          {% for block in section.blocks %}
            <button
              class="cwc_testimonial-tab-button{% if forloop.first %} active{% endif %}"
              data-tab="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.tab_title }}
            </button>
          {% endfor %}
        </div>
      {% endif %}

      {% for block in section.blocks %}
        <div
          class="cwc_testimonial_tabs-grid{% if forloop.first %} active{% endif %}"
          data-content="{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.review_title_1 != blank or block.settings.review_text_1 != blank %}
            <div class="cwc_testimonial_tabs-testimonial-card">
              <div class="cwc_testimonial_tabs-testimonial-stars">
                {% render 'CWC_rating_stars', fill_color: section.settings.star_color %}
              </div>
              {% if block.settings.review_title_1 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-title">{{ block.settings.review_title_1 }}</div>
              {% endif %}
              {% if block.settings.review_text_1 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-text">{{ block.settings.review_text_1 }}</div>
              {% endif %}
              {% if block.settings.review_author_1 != blank %}
                <cite class="cwc_testimonial_tabs-testimonial-author">– {{ block.settings.review_author_1 }}</cite>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.review_title_2 != blank or block.settings.review_text_2 != blank %}
            <div class="cwc_testimonial_tabs-testimonial-card">
              <div class="cwc_testimonial_tabs-testimonial-stars">
                {% render 'CWC_rating_stars', fill_color: section.settings.star_color %}
              </div>
              {% if block.settings.review_title_2 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-title">{{ block.settings.review_title_2 }}</div>
              {% endif %}
              {% if block.settings.review_text_2 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-text">{{ block.settings.review_text_2 }}</div>
              {% endif %}
              {% if block.settings.review_author_2 != blank %}
                <cite class="cwc_testimonial_tabs-testimonial-author">– {{ block.settings.review_author_2 }}</cite>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.review_title_3 != blank or block.settings.review_text_3 != blank %}
            <div class="cwc_testimonial_tabs-testimonial-card">
              <div class="cwc_testimonial_tabs-testimonial-stars">
                {% render 'CWC_rating_stars', fill_color: section.settings.star_color %}
              </div>
              {% if block.settings.review_title_3 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-title">{{ block.settings.review_title_3 }}</div>
              {% endif %}
              {% if block.settings.review_text_3 != blank %}
                <div class="cwc_testimonial_tabs-testimonial-text">{{ block.settings.review_text_3 }}</div>
              {% endif %}
              {% if block.settings.review_author_3 != blank %}
                <cite class="cwc_testimonial_tabs-testimonial-author">– {{ block.settings.review_author_3 }}</cite>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{{ 'CWC_testimonial_tabs.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC Testimonial Tabs",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption",
      "default": "<h5>Real reviews from real customers who love our products.</h5>"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Title Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "caption_bold_color",
      "label": "Bold Color",
      "default": "#526D05"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h3>People Love Our Products</h3>"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Bold Color",
      "default": "#526D05"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Backed by hundreds of customers who feel the difference every day.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#F97316"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Tab Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Tab Button Text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_active_bg_color",
      "label": "Active Tab Background",
      "default": "#125657"
    },
    {
      "type": "color",
      "id": "button_active_text_color",
      "label": "Active Tab Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial_tab",
      "name": "Testimonial Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Energy"
        },
        {
          "type": "richtext",
          "id": "review_title_1",
          "label": "Review Title 1",
          "default": "<p>Amazing energy boost</p>"
        },
        {
          "type": "textarea",
          "id": "review_text_1",
          "label": "Review Text 1",
          "default": "This product has completely transformed my daily energy levels."
        },
        {
          "type": "text",
          "id": "review_author_1",
          "label": "Author 1",
          "default": "Sarah M."
        },
        {
          "type": "richtext",
          "id": "review_title_2",
          "label": "Review Title 2",
          "default": "<p>Perfect for workouts</p>"
        },
        {
          "type": "textarea",
          "id": "review_text_2",
          "label": "Review Text 2",
          "default": "I take this before every workout and feel the difference immediately."
        },
        {
          "type": "text",
          "id": "review_author_2",
          "label": "Author 2",
          "default": "Mike D."
        },
        {
          "type": "richtext",
          "id": "review_title_3",
          "label": "Review Title 3",
          "default": "<p>Sustained energy all</p>"
        },
        {
          "type": "textarea",
          "id": "review_text_3",
          "label": "Review Text 3",
          "default": "No crashes, just clean energy that lasts throughout the day."
        },
        {
          "type": "text",
          "id": "review_author_3",
          "label": "Author 3",
          "default": "Lisa K."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Testimonial Tabs",
      "category": "Custom",
      "blocks": [
        {
          "type": "testimonial_tab",
          "settings": {
            "tab_title": "Benefits"
          }
        },
        {
          "type": "testimonial_tab",
          "settings": {
            "tab_title": "Taste"
          }
        },
        {
          "type": "testimonial_tab",
          "settings": {
            "tab_title": "Ingredients"
          }
        }
      ]
    }
  ]
}
{% endschema %}
