{% style %}
  #CWC_testimonials-{{ section.id }} {
  --section-bg: {{ section.settings.bg_color | default: '#FAF9F6' }};
  --text-color: {{ section.settings.text_color | default: '#111111' }};
  --card-bg: {{ section.settings.card_bg | default: '#ffffff' }};
  --highlight-color: {{ section.settings.highlight_color | default: '#009370' }};
  --padding-top: {{ section.settings.padding_top | default: 60 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
  }
{% endstyle %}

{{ 'CWC_testimonials.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

{% comment %}
  UNIFIED DATA ASSIGNMENT
  Create consistent data structure regardless of source
{% endcomment %}
{% if section.settings.testimonials_collection %}
  {% comment %} Use metaobject data {% endcomment %}
  {% assign customer_testimonial_list = section.settings.testimonials_collection.testimonials.value %}
{% else %}
  {% comment %} Use section blocks data {% endcomment %}
  {% assign customer_testimonial_list = section.blocks %}
{% endif %}

<section id="CWC_testimonials-{{ section.id }}" class="cwc-testimonials">
  <div class="cwc-testimonials__wrapper">
    <div class="swiper cwc-testimonials__carousel">
      <div class="swiper-wrapper cwc-testimonials__carousel_swiper-wrapper">
        {% for customer_testimonial in customer_testimonial_list %}
          {% comment %}
            UNIFIED VARIABLE ASSIGNMENT
            Assign variables based on data source
          {% endcomment %}
          {% if section.settings.testimonials_collection %}
            {% comment %} Metaobject source {% endcomment %}
            {% assign rating = customer_testimonial.rating %}
            {% assign title = customer_testimonial.title %}
            {% assign text = customer_testimonial.text %}
            {% assign author = customer_testimonial.author %}
            {% assign tag1 = customer_testimonial.tag1 %}
            {% assign tag2 = customer_testimonial.tag2 %}
            {% assign img_value = customer_testimonial.profile_image %}
            {% assign img_url = customer_testimonial.profile_image | image_url: width: 36 %}

            {% comment %} {{ customer_testimonial_list | json }} {% endcomment %}
          {% else %}
            {% comment %} Block source {% endcomment %}
            {% assign rating = customer_testimonial.settings.star_rating %}
            {% assign title = customer_testimonial.settings.title %}
            {% assign text = customer_testimonial.settings.text %}
            {% assign author = customer_testimonial.settings.author_name %}
            {% assign tag1 = customer_testimonial.settings.feature_one %}
            {% assign tag2 = customer_testimonial.settings.feature_two %}
            {% assign img_value = customer_testimonial.settings.author_image %}
            {% assign img_url = customer_testimonial.settings.author_image | image_url: width: 36 %}
          {% endif %}
          {% comment %}
            SINGLE RENDER SECTION
            Everything below uses the same unified variables
          {% endcomment %}
          <div class="swiper-slide cwc-testimonials__carousel_swiper-slide">
            <div class="cwc-testimonial-card" {{ block.shopify_attributes }}>
              <div class="cwc-testimonials__testimonial-top">
                <div class="cwc-testimonial-rating">
                  <span class="cwc-testimonial-rating_text">{{ rating }}</span>
                  {% render 'CWC_trust_stars' %}
                </div>

                {% if title != blank %}
                  <h3 class="cwc-testimonials__testimonial-title">"{{ title }}"</h3>
                {% endif %}

                {% if text != blank %}
                  <p class="cwc-testimonials__testimonial-text">{{ text }}</p>
                {% endif %}
              </div>

              <div class="cwc-testimonials__testimonial-bottom">
                <div class="cwc-testimonials__testimonial-author_wrapper">
                  <div class="cwc-testimonials__testimonial-author">
                    {% if img_value != blank %}
                      <img
                        loading="lazy"
                        fetchpriority="low"
                        src="{{ img_url }}"
                        alt="{{ author }}"
                        width="36"
                        height="36"
                      >
                    {% else %}
                      <img
                        fetchpriority="low"
                        src="{{ 'icon-placeholder.png' | asset_url }}"
                        alt="Author placeholder"
                        width="36"
                        height="36"
                      >
                    {% endif %}
                    <span class="author-name">{{ author }}</span>
                  </div>

                  <div class="cwc-testimonials__testimonial-author-verified">
                    <span class="cwc-testimonials__testimonial-author-verified-icon">
                      {%- render 'CWC_icon-check_badge', fill: '#009370' -%}
                    </span>
                    <span class="cwc-testimonials__testimonial-author-verified-text"> Verified Customer </span>
                  </div>
                </div>

                <div class="cwc-testimonials__testimonial-tags">
                  {% if tag1 != blank %}
                    <span class="tag">{{ tag1 }}</span>
                  {% endif %}
                  {% if tag2 != blank %}
                    <span class="tag">{{ tag2 }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="cwc-testimonials__carousel-progress">
    <div class="cwc-testimonials__progress-bar"></div>
  </div>

  <!-- Swiper controls -->
  <div class="cwc-testimonials__carousel-controls">
    <div class="swiper-button-prev cwc-testimonials__carousel-prev"></div>
    <div class="swiper-button-next cwc-testimonials__carousel-next"></div>
  </div>
</section>

{{ 'CWC_testimonials.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "metaobject",
      "id": "testimonials_collection",
      "label": "Testimonials Collection",
      "metaobject_type": "testimonial_collections",
      "info": "Select a testimonial collection metaobject. Leave blank to use individual blocks below."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#009370"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "star_rating",
          "label": "Star rating",
          "default": "4.9"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Headline",
          "default": "Amazing product!"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "This product completely exceeded my expectations..."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Jane D."
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author image"
        },
        {
          "type": "text",
          "id": "feature_one",
          "label": "Tag / Feature #1",
          "default": "Eco-friendly"
        },
        {
          "type": "text",
          "id": "feature_two",
          "label": "Tag / Feature #2",
          "default": "Durable"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Testimonials",
      "category": "Custom",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
