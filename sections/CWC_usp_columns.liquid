{% style %}
  #CWC_usp_columns-{{ section.id }} {
    --section-bg: {{ section.settings.background_color }};
    --text-color: {{ section.settings.text_color }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-top-mobile: {{ section.settings.padding_top | times: 0.5 }}px;
    --padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }
{% endstyle %}

{{ 'CWC_usp_columns.css' | asset_url | stylesheet_tag }}

<section id="CWC_usp_columns-{{ section.id }}" class="cwc_usp_columns cwc_usp_columns-{{ section.id }}">
  <div class="cwc_usp_columns-wrapper">
    <div class="cwc_usp_columns-container">
      {% for block in section.blocks %}
        {% if block.type == 'usp' %}
          <div class="usp-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <span class="usp-icon">
                <img
                  src="{{ block.settings.icon | image_url }}"
                  alt="{{ block.settings.text | strip_html | escape }}"
                  loading="lazy"
                >
              </span>
            {% endif %}
            {% if block.settings.text != blank %}
              <span class="usp-text">{{ block.settings.text }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CWC USP Columns",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#125657"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "USP Text",
          "default": "Your USP text here"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "USP Columns",
      "category": "Custom",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "text": "No Harsh Side Effects"
          }
        },
        {
          "type": "usp",
          "settings": {
            "text": "THIRD PARTY TESTED"
          }
        },
        {
          "type": "usp",
          "settings": {
            "text": "CLEAN INGREDIENT"
          }
        }
      ]
    }
  ]
}
{% endschema %}
