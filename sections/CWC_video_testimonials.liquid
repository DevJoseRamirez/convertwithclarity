{% style %}
  #CWC_video_testimonials-{{ section.id }} {
  --section-bg: {{ section.settings.bg_color | default: '#FAF9F6' }};
  --text-color: {{ section.settings.text_color | default: '#111111' }};
  --button-bg: {{ section.settings.button_bg | default: '#009370' }};
  --button-text: {{ section.settings.button_text | default: '#ffffff' }};
  --padding-top: {{ section.settings.padding_top | default: 60 }}px;
  --padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
  --accent-color: {{ section.settings.bold_color }};
  }
{% endstyle %}

{{ 'CWC_video_testimonials.css' | asset_url | stylesheet_tag }}
{{ 'CWC_swiper-bundle.min.css' | asset_url | stylesheet_tag }}

<section id="CWC_video_testimonials-{{ section.id }}" class="cwc-video-testimonials">
  <div class="cwc-video-testimonials__wrapper">
    {% if section.settings.heading != blank %}
      <div class="cwc-video-testimonials__heading rte">
        {{ section.settings.heading }}
      </div>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="cwc-video-testimonials__text rte">{{ section.settings.text }}</div>
    {% endif %}

    {%- liquid
      assign video_count = 0

      if section.settings.video_testimonials_collection != blank
        assign video_count = section.settings.video_testimonials_collection.testimonial_list.value.size
      else
        for block in section.blocks
          if block.type == 'testimonial'
            assign video_count = video_count | plus: 1
          endif
        endfor
      endif
    -%}

    <div
      class="swiper cwc-video-testimonials__carousel"
      data-video-count="{{ video_count }}"
      data-max-desktop-slides="{{ section.settings.max_desktop_slides | default: 4 }}"
      data-max-tablet-slides="{{ section.settings.max_tablet_slides | default: 3 }}"
      data-max-mobile-slides="{{ section.settings.max_mobile_slides | default: 1.5 }}"
    >
      <div class="swiper-wrapper cwc-video-testimonials__swiper-wrapper">
        {% if section.settings.video_testimonials_collection != blank %}
          {% comment %} METAOBJECT LOOP {% endcomment %}
          {% for video_testimonial in section.settings.video_testimonials_collection.testimonial_list.value %}
            <div class="swiper-slide cwc-video-testimonials__swiper-slide">
              <div class="cwc-video-testimonials__video-card">
                {% if video_testimonial.video != blank %}
                  {% assign mp4_source = video_testimonial.video.value.sources | where: 'format', 'mp4' | first %}

                  <div class="cwc-video-testimonials__video-wrapper">
                    <video
                      data-video-id="{{ video_testimonial.id }}{{ forloop.index0 }}"
                      class="cwc-video-testimonials__video"
                      playsinline
                      preload="metadata"
                      poster="{{ video_testimonial.video.value.preview_image | image_url: width: 300 }}"
                      height="{{ video_testimonial.video.value.preview_image.width }}"
                      width="{{ video_testimonial.video.value.preview_image.height }}"
                    >
                      {% if mp4_source %}
                        <source src="{{ mp4_source.url }}" type="video/mp4">
                      {% endif %}
                    </video>

                    <button class="cwc-video-testimonials__custom-play-button" aria-label="Play video">
                      <svg
                        class="play-icon"
                        width="44"
                        height="44"
                        viewBox="0 0 44 44"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <foreignObject x="-7.62703" y="-7.61355" width="59.9436" height="59.9436">
                            <div xmlns="http://www.w3.org/1999/xhtml"
                                style="backdrop-filter:blur(4.23px);clip-path:url(#bgblur_0_184_1311_clip_path);height:100%;width:100%">
                            </div>
                        </foreignObject>
                        <circle data-figma-bg-blur-radius="8.46486" cx="22.3448" cy="22.3583" r="21.5069"
                            fill="white" fill-opacity="0.2"></circle>
                        <path
                            d="M30.407 20.8061C31.6018 21.4959 31.6018 23.2205 30.407 23.9103L19.6535 30.1189C18.4587 30.8087 16.9652 29.9464 16.9652 28.5667L16.9652 16.1497C16.9652 14.77 18.4587 13.9077 19.6535 14.5976L30.407 20.8061Z"
                            fill="white"></path>
                        <defs>
                            <clipPath id="bgblur_0_184_1311_clip_path" transform="translate(7.62703 7.61355)">
                                <circle cx="22.3448" cy="22.3583" r="21.5069"></circle>
                            </clipPath>
                        </defs>
                      </svg>
                    </button>
                  </div>
                {% endif %}

                {% unless section.settings.hide_video_footer %}
                  <div class="cwc-video-testimonials__video-author">
                    <span class="cwc-video-testimonials__author-name">{{ video_testimonial.author }}</span>

                    <div class="cwc-video-testimonials__verified">
                      <span class="cwc-video-testimonials__verified-icon">
                        {%- render 'CWC_icon-check_badge', fill_color: '#009370' -%}
                      </span>
                      <span class="cwc-video-testimonials__verified-text"> Verified Customer </span>
                    </div>
                  </div>
                {% endunless %}
              </div>
            </div>
          {% endfor %}

        {% else %}
          {% comment %} BLOCKS LOOP {% endcomment %}
          {% for block in section.blocks %}
            {% if block.type == 'testimonial' %}
              <div class="swiper-slide cwc-video-testimonials__swiper-slide">
                <div class="cwc-video-testimonials__video-card" {{ block.shopify_attributes }}>
                  {% if block.settings.video_file != blank %}
                    {% assign mp4_source = block.settings.video_file.sources | where: 'format', 'mp4' | first %}

                    <div class="cwc-video-testimonials__video-wrapper">
                      <video
                        data-video-id="{{ block.id }}{{ forloop.index0 }}"
                        class="cwc-video-testimonials__video"
                        playsinline
                        preload="metadata"
                        poster="{{ block.settings.video_file.preview_image | image_url: width: 300 }}"
                        height="{{ block.settings.video_file.preview_image.width }}"
                        width="{{ block.settings.video_file.preview_image.height }}"
                      >
                        {% if mp4_source %}
                          <source src="{{ mp4_source.url }}" type="video/mp4">
                        {% endif %}
                      </video>

                      <button class="cwc-video-testimonials__custom-play-button" aria-label="Play video">
                        <svg
                          class="play-icon"
                          width="44"
                          height="44"
                          viewBox="0 0 44 44"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <foreignObject x="-7.62703" y="-7.61355" width="59.9436" height="59.9436">
                              <div xmlns="http://www.w3.org/1999/xhtml"
                                  style="backdrop-filter:blur(4.23px);clip-path:url(#bgblur_0_184_1311_clip_path);height:100%;width:100%">
                              </div>
                          </foreignObject>
                          <circle data-figma-bg-blur-radius="8.46486" cx="22.3448" cy="22.3583" r="21.5069"
                              fill="white" fill-opacity="0.2"></circle>
                          <path
                              d="M30.407 20.8061C31.6018 21.4959 31.6018 23.2205 30.407 23.9103L19.6535 30.1189C18.4587 30.8087 16.9652 29.9464 16.9652 28.5667L16.9652 16.1497C16.9652 14.77 18.4587 13.9077 19.6535 14.5976L30.407 20.8061Z"
                              fill="white"></path>
                          <defs>
                              <clipPath id="bgblur_0_184_1311_clip_path" transform="translate(7.62703 7.61355)">
                                  <circle cx="22.3448" cy="22.3583" r="21.5069"></circle>
                              </clipPath>
                          </defs>
                        </svg>
                      </button>
                    </div>

                  {% elsif block.settings.video_url != blank %}
                    <div class="cwc-video-testimonials__video-wrapper">
                      <video
                        playsinline
                        loop
                        preload="metadata"
                        poster="{% if block.settings.thumbnail != blank %}{{ block.settings.thumbnail | image_url: width: 1100 }}{% endif %}"
                      >
                        <source src="{{ block.settings.video_url }}" type="video/mp4">
                      </video>
                      <button class="cwc-custom-play-button" aria-label="Play video">
                        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <foreignObject x="-7.62703" y="-7.61355" width="59.9436" height="59.9436">
                              <div xmlns="http://www.w3.org/1999/xhtml"
                                  style="backdrop-filter:blur(4.23px);clip-path:url(#bgblur_0_184_1311_clip_path);height:100%;width:100%">
                              </div>
                          </foreignObject>
                          <circle data-figma-bg-blur-radius="8.46486" cx="22.3448" cy="22.3583" r="21.5069"
                              fill="white" fill-opacity="0.2"></circle>
                          <path
                              d="M30.407 20.8061C31.6018 21.4959 31.6018 23.2205 30.407 23.9103L19.6535 30.1189C18.4587 30.8087 16.9652 29.9464 16.9652 28.5667L16.9652 16.1497C16.9652 14.77 18.4587 13.9077 19.6535 14.5976L30.407 20.8061Z"
                              fill="white"></path>
                          <defs>
                              <clipPath id="bgblur_0_184_1311_clip_path" transform="translate(7.62703 7.61355)">
                                  <circle cx="22.3448" cy="22.3583" r="21.5069"></circle>
                              </clipPath>
                          </defs>
                        </svg>
                      </button>
                    </div>
                  {% else %}
                    <div class="cwc-video-testimonials__video-wrapper">
                      <div>video placeholder</div>
                      <button class="cwc-custom-play-button" aria-label="Play video">
                        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <foreignObject x="-7.62703" y="-7.61355" width="59.9436" height="59.9436">
                              <div xmlns="http://www.w3.org/1999/xhtml"
                                  style="backdrop-filter:blur(4.23px);clip-path:url(#bgblur_0_184_1311_clip_path);height:100%;width:100%">
                              </div>
                          </foreignObject>
                          <circle data-figma-bg-blur-radius="8.46486" cx="22.3448" cy="22.3583" r="21.5069"
                              fill="white" fill-opacity="0.2"></circle>
                          <path
                              d="M30.407 20.8061C31.6018 21.4959 31.6018 23.2205 30.407 23.9103L19.6535 30.1189C18.4587 30.8087 16.9652 29.9464 16.9652 28.5667L16.9652 16.1497C16.9652 14.77 18.4587 13.9077 19.6535 14.5976L30.407 20.8061Z"
                              fill="white"></path>
                          <defs>
                              <clipPath id="bgblur_0_184_1311_clip_path" transform="translate(7.62703 7.61355)">
                                  <circle cx="22.3448" cy="22.3583" r="21.5069"></circle>
                              </clipPath>
                          </defs>
                        </svg>
                      </button>
                    </div>
                  {% endif %}
                  {% unless section.settings.hide_video_footer %}
                    <div class="cwc-video-testimonials__video-author" {{ block.shopify_attributes }}>
                      <span class="cwc-video-testimonials__author-name">{{ block.settings.author_name }}</span>

                      <div class="cwc-video-testimonials__verified">
                        <span class="cwc-video-testimonials__verified-icon">
                          {%- render 'CWC_icon-check_badge', fill: '#009370' -%}
                        </span>
                        <span class="cwc-video-testimonials__verified-text"> Verified Customer </span>
                      </div>
                    </div>
                  {% endunless %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <!-- Swiper progress + controls -->
    <div class="cwc-video-testimonials__carousel-progress">
      <div class="cwc-video-testimonials__progress-bar"></div>
    </div>

    <div class="cwc-video-testimonials__carousel-controls">
      <div class="swiper-button-prev cwc-video-testimonials__carousel-prev">
        {% render 'CWC_icon-arrow-chev', fill_color: section.settings.text_color | default: '#6b7280' %}
      </div>
      <div class="swiper-button-next cwc-video-testimonials__carousel-next">
        {% render 'CWC_icon-arrow-chev', fill_color: section.settings.text_color| default: '#6b7280' %}
      </div>
    </div>

    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'button' %}
          <div class="cwc-video-testimonials__cta" {{ block.shopify_attributes }}>
            {% render 'CWC_button', product: product, section_id: section.id, block: block %}
          </div>

        {% when 'guarantee_text' %}
          <div class="cwc-video-testimonials__note" {{ block.shopify_attributes }}>
            {% render 'CWC_guarantee_text', product: product, section_id: section.id, block: block %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{{ 'CWC_video_testimonials.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "CWC Video Testimonials",
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2>Real People, <strong>Real Results</strong></h2>"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Bold Text Color",
      "default": "#125657"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Subtext",
      "default": "<p>See why thousands of people love our products</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background color",
      "default": "#125657"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "max_desktop_slides",
      "min": 1,
      "max": 7,
      "step": 0.5,
      "label": "Max slides visible (Desktop)",
      "default": 4,
      "info": "Maximum number of slides shown at once on desktop (1200px+)"
    },
    {
      "type": "range",
      "id": "max_tablet_slides",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "label": "Max slides visible (Tablet)",
      "default": 3,
      "info": "Maximum number of slides shown at once on tablet (992px-1199px)"
    },
    {
      "type": "range",
      "id": "max_mobile_slides",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "label": "Max slides visible (Mobile)",
      "default": 1.5,
      "info": "Maximum number of slides shown at once on mobile"
    },
    {
      "type": "checkbox",
      "id": "hide_controls_when_all_visible",
      "label": "Hide controls when all slides visible",
      "default": true,
      "info": "Automatically hide navigation arrows and progress bar when all content fits on screen"
    },
    {
      "type": "checkbox",
      "id": "hide_video_footer",
      "label": "Hide Video Footer",
      "default": true
    },
    {
      "type": "metaobject",
      "id": "video_testimonials_collection",
      "label": "Video Testimonials Collection",
      "metaobject_type": "video_testimonial_list",
      "info": "Select a video testimonial collection metaobject. Leave blank to use individual blocks below."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "video",
          "id": "video_file",
          "label": "Upload video"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "External Video URL (optional)"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Customer Name"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Text",
          "default": "Try Risk-Free Today"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#125657"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "guarantee_text",
      "name": "Guarantee Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "365-day money back guarantee"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Video Testimonials",
      "category": "Custom",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "button" },
        { "type": "guarantee_text" }
      ]
    }
  ]
}
{% endschema %}
