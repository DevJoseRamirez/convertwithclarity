          {% render 'CWC_icon-check_fill', fill_color: block.settings.icon_color %}
        </div>
        <div class="cwc_bullet_points-text">
          {{ block.settings.bullet_3 }}
        </div>
      </li>
    {% endif %}

    {% if block.settings.bullet_4 != blank %}
      <li class="cwc_bullet_points-item">
        <div class="cwc_bullet_points-icon">
          {% render 'CWC_icon-check_fill', fill_color: block.settings.icon_color %}
        </div>
