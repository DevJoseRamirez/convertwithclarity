{% style %}
  /* == CWC Ingredients List Block == */
  .cwc_ingredients_list-block {
    margin-top: 2rem;
    margin-bottom: 2rem;
    /* margin: 1rem 0rem; */
  }

  .cwc_ingredients_list-title {
    text-align: center;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: #202020;
  }

  /* === Grid Layout === */
  .cwc_ingredients_list-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  /* === Individual Items === */
  .cwc_ingredients_list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .cwc_ingredients_list-icon {
    flex-shrink: 0;
    width: 65px;
    border: grey 1px solid;
    height: 65px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(228, 228, 228, 1);
  }

  .cwc_ingredients_list-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cwc_ingredients_list-content {
    flex: 1;
  }

  .cwc_ingredients_list-name {
    /* font-size: 1.125rem; */
    /* font-size: 1rem; */
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: #202020;
    line-height: 1.2;
  }

  .cwc_ingredients_list-description {
    font-size: 0.95rem;
    line-height: 1.5;
    color: #666666;
    margin: 0;

    margin: 0;
    font-size: 1rem;
    line-height: 1.4rem;
    margin-bottom: 1.5rem;
    font-weight: 400;
    font-size: 15px;
    letter-spacing: 0;
    text-align: left;
    /* margin-bottom: 20px; */
    margin-bottom: 0.5rem;
    max-width: 400px;
    display: flex;
    font-size: 0.875rem;
  }

  /* === Mobile Styles === */
  @media screen and (max-width: 767px) {
    .cwc_ingredients_list-block {
      margin-top: 2rem;
      margin-bottom: 2rem;
      padding: 0 1rem;
    }

    .cwc_ingredients_list-title {
      /* font-size: 1.5rem; */
      margin-bottom: 2rem;
    }

    .cwc_ingredients_list-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cwc_ingredients_list-item {
      gap: 0.75rem;
    }

    .cwc_ingredients_list-name {
      font-size: 1rem;
    }

    .cwc_ingredients_list-description {
      font-size: 0.875rem;
    }
  }
{% endstyle %}
{% comment %}
  CWC Ingredients List Snippet
  Usage: {% render 'cwc_ingredients_list', product: product, section_id: section.id, block: block %}

  Metaobject Structure:
  1. Ingredient Item (individual ingredients)
  2. Ingredients List (collection of ingredients)
  3. Product Metafield -> Ingredients List
{% endcomment %}

{% assign ingredients_list = product.metafields.custom.ingredients_list.value %}

<div class="cwc_ingredients_list-block" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <div class="cwc_ingredients_list-title">{{ block.settings.title }}</div>
  {% endif %}

  <div class="cwc_ingredients_list-grid">
    {% comment %} Access the ingredients from the list metaobject {% endcomment %}
    {% comment %} {% assign ingredients = ingredients_list.ingredients.value %} {% endcomment %}

    {% for ingredient in ingredients_list.ingredient.value %}
      {% comment %} {{ ingredient | json }} {% endcomment %}
      <div class="cwc_ingredients_list-item">
        {% if ingredient.image.value %}
          <div class="cwc_ingredients_list-icon">
            <img
              src="{{ ingredient.image.value | image_url: width: 80 }}"
              alt="{{ ingredient.title.value | escape }}"
              width="40"
              height="40"
              loading="lazy"
            >
          </div>
        {% endif %}

        <div class="cwc_ingredients_list-content">
          {% if ingredient.title.value != blank %}
            <h3 class="cwc_ingredients_list-name">{{ ingredient.title.value }}</h3>
          {% endif %}

          {% if ingredient.text.value != blank %}
            <p class="cwc_ingredients_list-description">{{ ingredient.text.value }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>
