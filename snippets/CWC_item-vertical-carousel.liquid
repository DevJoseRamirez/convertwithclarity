{% comment %} {{ view }} {% endcomment %}

{% comment %} {{ section.blocks.size }} {% endcomment %}
{% comment %} {{ section.id }} {% endcomment %}
{% comment %} {{ blocks.size }} {% endcomment %}
{% comment %} {% render 'CWC_item-vertical-carousel', section: section, view: 'cwc_desktop-view' %} {% endcomment %}

{% comment %} ==== Vertical Carousel Column ==== {% endcomment %}
<div class="cwc_hero-vertical-carousel__media {{ view }}">
  <div class="cwc_hero-vertical-carousel__stage">
    <div class="cwc_hero-vertical-carousel__columns">
      {%- comment -%}
        Render up to 3 columns. For each, loop blocks twice:
        once for the initial set, once duplicated (aria-hidden)
        so the translateY(-50%) loop is seamless.
      {%- endcomment -%}

      {% for col_idx in (1..3) %}
        {% if col_idx <= column_count %}
          {%- assign col_str = col_idx | append: '' -%}

          {%- assign col_has_images = false -%}
          {% for block in blocks %}
            {% if block.type == 'image' and block.settings.column == col_str and block.settings.image %}
              {%- assign col_has_images = true -%}
              {%- break -%}
            {% endif %}
          {% endfor %}

          {% if col_has_images %}
            {%- assign direction_class = 'cwc_hero-vertical-carousel__column--up' -%}
            {% if opposing and col_idx == 2 %}
              {%- assign direction_class = 'cwc_hero-vertical-carousel__column--down' -%}
            {% endif %}

            <div class="cwc_hero-vertical-carousel__column {{ direction_class }}">
              {% comment %} First pass — visible images {% endcomment %}
              {% for block in blocks %}
                {% if block.type == 'image' and block.settings.column == col_str and block.settings.image %}
                  <div class="cwc_hero-vertical-carousel__image-wrap" {{ block.shopify_attributes }}>
                    {{
                      block.settings.image
                      | image_url: width: 300
                      | image_tag:
                        class: 'cwc_hero-vertical-carousel__image',
                        widths: '300, 450, 600, 900',
                        sizes: '(max-width: 768px) 40vw, 25vw',
                        alt: block.settings.image.alt
                      | default: '', loading: 'lazy'
                    }}
                  </div>
                {% endif %}
              {% endfor %}

              {% comment %} Second pass — duplicate set for seamless loop {% endcomment %}
              {% for block in blocks %}
                {% if block.type == 'image' and block.settings.column == col_str and block.settings.image %}
                  <div class="cwc_hero-vertical-carousel__image-wrap" aria-hidden="true">
                    {{
                      block.settings.image
                      | image_url: width: 300
                      | image_tag:
                        class: 'cwc_hero-vertical-carousel__image',
                        widths: '300, 450, 600, 900',
                        sizes: '(max-width: 768px) 40vw, 25vw',
                        alt: '',
                        loading: 'lazy'
                    }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
