{% style %}
  /* ================================
     Price Display
     ================================ */

  .cwc_product-template__price,
  .cwc-featured-product__price {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin: 0rem 0 1rem 0;
    font-size: 1.3125rem;
    width: 100%;
    gap: 3rem;
    padding: 0rem;
  }

  .cwc_product-template__price.show_save,
  .cwc-featured-product__price.show_save {
    border-top: 0.55px solid rgba(0, 0, 0, 0.2);
    border-bottom: 0.55px solid rgba(0, 0, 0, 0.2);
    padding: 0.7rem 0rem;
    margin: 0rem 0 1rem 0;
  }

  .cwc-featured-product__price-current {
    font-weight: 700;
    color: #60a1a2;
    font-size: 1.25rem;
  }

  .cwc-featured-product__price-compare {
    font-size: 1.25rem;
    font-weight: 400;
    color: #08122a;
    text-decoration: line-through;
  }

  .cwc-featured-product__price-save {
    display: flex;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    padding: 4px 10px;
    background: #60a1a2;
    border-radius: 5px;
    gap: 6px;
    vertical-align: middle;
    line-height: 100%;
  }

  .cwc-featured-product__price-save span {
    font-size: inherit;
    font-size: 0.9rem;
  }

  @media (max-width: 991px) {
    .cwc-featured-product__price-current,
    .cwc-featured-product__price-compare {
      font-size: 1.125rem;
    }
    .cwc-featured-product__price-save span {
      font-size: 0.86rem;
    }
    .cwc_product-template__price,
    .cwc-featured-product__price {
      gap: 2rem;
    }
  }

  /* ================================
   Mobile Responsive (max-width: 768px)
   ================================ */
  @media (max-width: 768px) {
    .cwc_product-template__price,
    .cwc-featured-product__price {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      margin: 0rem 0 1rem 0;
      border-top: 0.55px solid rgba(0, 0, 0, 0.2);
      border-bottom: 0.55px solid rgba(0, 0, 0, 0.2);
      font-size: 1.3125rem;
      width: 100%;
      padding: 0.5rem 0rem;
      gap: 1rem;
    }
    .cwc-featured-product__price-save {
      line-height: normal;
      font-size: 0.86rem;
    }
  }
{% endstyle %}

{% comment %}
  CWC Price Display - Simplified Version
  Features:
  - Uses product's compare_at_price if available
  - Shows save amount when compare price exists
{% endcomment %}

{% liquid
  # Calculate savings if compare price exists
  if product.compare_at_price and product.compare_at_price > product.price
    assign save_amount = product.compare_at_price | minus: product.price
  endif
%}

<span class="cwc-featured-product__price-current" id="current-price-{{ section_id }}">
  {{ product.price | money }}
</span>

{% if product.compare_at_price and product.compare_at_price > product.price %}
  <span class="cwc-featured-product__price-compare" id="compare-price-{{ section_id }}">
    {{ product.compare_at_price | money }}
  </span>

  <div class="cwc-featured-product__price-save" id="save-amount-{{ section_id }}">
    <span>Save</span>
    <span class="cwc-featured-product__price-save-amount">
      {{ save_amount | money }}
    </span>
  </div>
{% endif %}
