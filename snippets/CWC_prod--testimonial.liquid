{% style %}
  .cwc_featured-review-snippet {
    border-radius: 6px;
    padding: 1rem;
    font-size: 0.95rem;
    line-height: 1.5;
    /* max-width: 600px; */
    width: calc(100% - 2rem);
    width: 100%;
    margin: auto;
  }

  .cwc_featured-review-snippet .stars {
    font-size: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .cwc_featured-review-snippet .review-author {
    font-weight: 600;
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
  }
  .cwc_featured-review-snippet .featured-review-star-wrap {
    margin-bottom: 0rem;
  }
  .cwc_featured-review-snippet .review-text {
    margin: 0;
    font-size: 0.8rem;
  }
  .cwc_featured-review-top {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
  }
  /* MOBILE ========================================= */

  @media screen and (max-width: 768px) {
  }
{% endstyle %}

<div
  class="cwc_featured-review-snippet"
  {{ block.shopify_attributes }}
  style="
    background-color: {{ block.settings.background }};
    border: 1px solid {{ block.settings.border }};
    color: {{ block.settings.text_color }};
  "
>
  <div class="cwc_featured-review-top">
    <div class="stars" style="color: {{ block.settings.star_color }};">
      <div class="featured-review-star-wrap" style="color: {{ block.settings.star_color }}">
        {% for i in (1..5) %}
          <svg
            class="cwc_hero-star"
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="17"
            viewBox="0 0 18 17"
            fill="none"
          >
            <path
                d="M8.62838 1.04894C8.83792 0.404019 9.75031 0.404018 9.95986 1.04894L11.4481 5.62937C11.5418 5.91779 11.8106 6.11306 12.1139 6.11306H16.93C17.6081 6.11306 17.8901 6.98079 17.3415 7.37937L13.4451 10.2102C13.1998 10.3885 13.0971 10.7044 13.1908 10.9929L14.6791 15.5733C14.8887 16.2182 14.1505 16.7545 13.6019 16.3559L9.70557 13.5251C9.46023 13.3468 9.12801 13.3468 8.88267 13.5251L4.98632 16.3559C4.43772 16.7545 3.69958 16.2182 3.90913 15.5733L5.3974 10.9929C5.49111 10.7044 5.38845 10.3885 5.14311 10.2102L1.24676 7.37937C0.69816 6.98079 0.980102 6.11306 1.65821 6.11306H6.47436C6.77762 6.11306 7.04639 5.91779 7.1401 5.62937L8.62838 1.04894Z"
                fill="{{ block.settings.star_color }}" />
          </svg>
        {% endfor %}
      </div>
    </div>
    <strong class="review-author">{{ block.settings.author }}</strong>
  </div>

  <p class="review-text">{{ block.settings.text }}</p>
</div>
