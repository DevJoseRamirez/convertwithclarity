{% else %}
  {% comment %} Option not found - show helpful message in theme editor {% endcomment %}
  <div
    class="cwc-featured-product__option_size-error"
    style="padding: 1rem; background: #FEF2F2; border: 1px solid #FCA5A5; border-radius: 4px; color: #991B1B;"
  >
    <strong>Option "{{ target_option_name }}" not found.</strong><br>
    Available options:
    {% for opt in product.options -%}
      {{- opt -}}
      {%- unless forloop.last %}, {% endunless -%}
    {%- endfor %}
  </div>
{% endif %}

{% comment %} JavaScript to manage selected state {% endcomment %}
<script>
  (function () {
    // Find the size option wrapper by class instead of position attribute
    const optionWrapper = document.querySelector('.cwc-featured-product__option_size');
    if (!optionWrapper) return;

    const buttons = optionWrapper.querySelectorAll('.cwc-featured-product__option_size_button');
    const hiddenInput = optionWrapper.querySelector('.cwc-featured-product__option_size-input');

    // Function to sync visual selection with current hidden input value
    function syncSelectionFromInput() {
      if (!hiddenInput) return;

      const currentValue = hiddenInput.value;
      buttons.forEach((button) => {
        if (button.dataset.value === currentValue) {
          // Update visual selection state
          buttons.forEach((btn) => btn.classList.remove('selected'));
          button.classList.add('selected');
        }
      });
    }

    // NOTE: Click handling is done by the main JS (CWC_featured_product.js)
    // This script only handles SYNCING the visual state when the value changes externally

    // Watch for changes to the hidden input value attribute (from other option changes)
    if (hiddenInput && window.MutationObserver) {
      const observer = new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
          if (mutation.type === 'attributes' && mutation.attributeName === 'value') {
            syncSelectionFromInput();
          }
        });
      });

      observer.observe(hiddenInput, {
        attributes: true,
        attributeFilter: ['value'],
      });
    }

    // Also listen for value changes via events
    if (hiddenInput) {
      hiddenInput.addEventListener('change', syncSelectionFromInput);
      hiddenInput.addEventListener('input', syncSelectionFromInput);
    }

    // Initial sync on page load
    function init() {
      syncSelectionFromInput();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
