{% comment %}
  CWC Product Options Type
  Displays type/flavor options with selected option name and description
{% endcomment %}

{{ 'CWC_product_options_type.css' | asset_url | stylesheet_tag }}

{% liquid
  assign sel = product.selected_or_first_available_variant
  assign target_option_name = block.settings.option_name
  assign option_label = block.settings.option_label
  assign layout_mode = block.settings.layout_mode
  assign show_images = block.settings.show_images
%}

{% comment %} Find the matching option {% endcomment %}
{% assign target_option = null %}
{% for option in product.options_with_values %}
  {% if option.name == target_option_name %}
    {% assign target_option = option %}
    {% break %}
  {% endif %}
{% endfor %}

{% if target_option %}
  <div
    class="cwc-featured-product__option_type layout-{{ layout_mode }} {% if show_images %}show-images{% else %}hide-images{% endif %}"
    {{ block.shopify_attributes }}
    data-option-position="{{ target_option.position }}"
  >
    {% if option_label != blank %}
      <label class="cwc-featured-product__option_type-label">{{ option_label }}</label>
    {% endif %}

    <div class="cwc-featured-product__option_type_buttons">
      {% for value in target_option.values %}
        {% comment %} Find candidate variant {% endcomment %}
        {% assign candidate = null %}
        {% for v in product.variants %}
          {% assign match = true %}

          {% comment %} Match this option value {% endcomment %}
          {% if target_option.position == 1 %}
            {% if v.option1 != value %}{% assign match = false %}{% endif %}
            {% if product.options.size > 1 and v.option2 != sel.option2 %}{% assign match = false %}{% endif %}
            {% if product.options.size > 2 and v.option3 != sel.option3 %}{% assign match = false %}{% endif %}
          {% elsif target_option.position == 2 %}
            {% if v.option2 != value %}{% assign match = false %}{% endif %}
            {% if v.option1 != sel.option1 %}{% assign match = false %}{% endif %}
            {% if product.options.size > 2 and v.option3 != sel.option3 %}{% assign match = false %}{% endif %}
          {% else %}
            {% if v.option3 != value %}{% assign match = false %}{% endif %}
            {% if v.option1 != sel.option1 %}{% assign match = false %}{% endif %}
            {% if v.option2 != sel.option2 %}{% assign match = false %}{% endif %}
          {% endif %}

          {% if match %}
            {% assign candidate = v %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% assign is_selected = false %}
        {% if target_option.position == 1 and sel.option1 == value %}
          {% assign is_selected = true %}
        {% elsif target_option.position == 2 and sel.option2 == value %}
          {% assign is_selected = true %}
        {% elsif target_option.position == 3 and sel.option3 == value %}
          {% assign is_selected = true %}
        {% endif %}

        {% comment %} Calculate savings {% endcomment %}
        {% assign show_compare = false %}
        {% assign save_pct = 0 %}
        {% if candidate and candidate.compare_at_price and candidate.compare_at_price > candidate.price %}
          {% assign show_compare = true %}
          {% assign save_money = candidate.compare_at_price | minus: candidate.price %}
          {% assign save_pct = save_money | times: 100 | divided_by: candidate.compare_at_price %}
        {% endif %}

        {% comment %} Get thumbnail URL {% endcomment %}
        {% assign thumb_url = null %}
        {% assign option_index = forloop.index %}

        {% if option_index == 1 and block.settings.image1 != blank %}
          {% assign thumb_url = block.settings.image1 | image_url: width: 120 %}
        {% elsif option_index == 2 and block.settings.image2 != blank %}
          {% assign thumb_url = block.settings.image2 | image_url: width: 120 %}
        {% elsif option_index == 3 and block.settings.image3 != blank %}
          {% assign thumb_url = block.settings.image3 | image_url: width: 120 %}
        {% elsif option_index == 4 and block.settings.image4 != blank %}
          {% assign thumb_url = block.settings.image4 | image_url: width: 120 %}
        {% elsif candidate and candidate.featured_image %}
          {% assign thumb_url = candidate.featured_image | image_url: width: 120 %}
        {% elsif candidate and candidate.image %}
          {% assign thumb_url = candidate.image | image_url: width: 120 %}
        {% endif %}

        {% comment %} Get variant description {% endcomment %}
        {% assign desc_key = 'variant_text' | append: option_index %}
        {% assign variant_description = block.settings[desc_key] %}

        {% comment %} Render Button {% endcomment %}

        {% if candidate and candidate.available %}
          <button
            type="button"
            class="cwc-featured-product__option_type_button{% if is_selected %} selected{% endif %}"
            data-option-index="{{ target_option.position | minus: 1 }}"
            data-option-name="{{ target_option.name | escape }}"
            data-value="{{ value | escape }}"
            data-variant-description="{{ variant_description | escape }}"
            {% if candidate %}
              data-variant-id="{{ candidate.id }}"
              data-price="{{ candidate.price }}"
              data-compare="{{ candidate.compare_at_price | default: 0 }}"
            {% endif %}
            {% if thumb_url %}
              data-thumb="{{ thumb_url }}"
            {% endif %}
            {% unless candidate and candidate.available %}
              disabled aria-disabled="true"
            {% endunless %}
          >
            {% if show_images and thumb_url %}
              <span class="cwc-featured-product__option_type_button_thumb-wrap">
                <img
                  class="cwc-featured-product__option_type_button_thumb"
                  src="{{ thumb_url }}"
                  alt="{{ value | escape }}"
                >
              </span>
            {% endif %}

            <div class="cwc-featured-product__option_type_button_value_wrap">
              <span class="cwc-featured-product__option_type_button_value">{{ value }}</span>
              {% if save_pct > 0 %}
                {% if block.settings.show_savings %}
                  <span class="cwc-featured-product__option_type_button_save_perc">You Save {{ save_pct }}%</span>
                {% endif %}
              {% endif %}
            </div>

            {% if candidate %}
              {% if block.settings.show_prices %}
                <span class="cwc-featured-product__option_type_button_prices">
                  <span class="cwc-featured-product__option_type_button_price">{{ candidate.price | money }}</span>
                  {% if show_compare %}
                    <span class="cwc-featured-product__option_type_button_compare_price">
                      {{- candidate.compare_at_price | money -}}
                    </span>
                  {% endif %}
                </span>
              {% endif %}
            {% endif %}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    {% comment %} Selected Option Display {% endcomment %}
    {% if block.settings.type_desc %}
      <div class="cwc-featured-product__option_type_selected-display">
        <div class="cwc-featured-product__option_type_selected-name">
          {% if target_option.position == 1 %}
            {{ sel.option1 }}
          {% elsif target_option.position == 2 %}
            {{ sel.option2 }}
          {% else %}
            {{ sel.option3 }}
          {% endif %}
        </div>
        <div class="cwc-featured-product__option_type_selected-description">
          {% comment %} Find the index of selected option to show correct description {% endcomment %}
          {% for value in target_option.values %}
            {% assign current_value = '' %}
            {% if target_option.position == 1 %}
              {% assign current_value = sel.option1 %}
            {% elsif target_option.position == 2 %}
              {% assign current_value = sel.option2 %}
            {% else %}
              {% assign current_value = sel.option3 %}
            {% endif %}

            {% if value == current_value %}
              {% assign desc_key = 'variant_text' | append: forloop.index %}
              {% assign variant_description = block.settings[desc_key] %}
              {{ variant_description }}
              {% break %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <input
      type="hidden"
      name="options[{{ target_option.name | escape }}]"
      class="cwc-featured-product__option_type-input"
      data-option-index="{{ target_option.position | minus: 1 }}"
      value="{% if target_option.position == 1 %}{{ sel.option1 }}{% elsif target_option.position == 2 %}{{ sel.option2 }}{% else %}{{ sel.option3 }}{% endif %}"
    >
  </div>
{% else %}
  {% comment %} Option not found {% endcomment %}
  <div
    class="cwc-featured-product__option_type-error"
    style="padding: 1rem; background: #FEF2F2; border: 1px solid #FCA5A5; border-radius: 4px; color: #991B1B;"
  >
    <strong>Option "{{ target_option_name }}" not found.</strong><br>
    Available options:
    {% for opt in product.options -%}
      {{- opt -}}
      {%- unless forloop.last %}, {% endunless -%}
    {%- endfor %}
  </div>
{% endif %}



{% comment %} JavaScript to update selected display {% endcomment %}
<script>
  (function () {
    const optionPosition = '{{ target_option.position }}';
    const optionWrapper = document.querySelector('[data-option-position="' + optionPosition + '"]');
    if (!optionWrapper) return;

    const buttons = optionWrapper.querySelectorAll('.cwc-featured-product__option_type_button');
    const selectedName = optionWrapper.querySelector('.cwc-featured-product__option_type_selected-name');
    const selectedDesc = optionWrapper.querySelector('.cwc-featured-product__option_type_selected-description');
    const hiddenInput = optionWrapper.querySelector('.cwc-featured-product__option_type-input');

    // Function to update the selected display based on current value
    function updateSelectedDisplay(optionValue, description) {
      if (selectedName) selectedName.textContent = optionValue;
      if (selectedDesc) selectedDesc.textContent = description || '';
    }

    // Function to sync display with current hidden input value
    function syncDisplayFromInput() {
      if (!hiddenInput) return;

      const currentValue = hiddenInput.value;
      buttons.forEach((button) => {
        if (button.dataset.value === currentValue) {
          const description = button.dataset.variantDescription || '';
          updateSelectedDisplay(currentValue, description);

          // Update visual selection state
          buttons.forEach((btn) => btn.classList.remove('selected'));
          button.classList.add('selected');
        }
      });
    }

    // NOTE: Click handling is done by the main JS (CWC_featured_product.js)
    // This script only handles SYNCING the visual state when the value changes externally

    // Watch for changes to the hidden input value attribute (from other option changes)
    if (hiddenInput && window.MutationObserver) {
      const observer = new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
          if (mutation.type === 'attributes' && mutation.attributeName === 'value') {
            syncDisplayFromInput();
          }
        });
      });

      observer.observe(hiddenInput, {
        attributes: true,
        attributeFilter: ['value'],
      });
    }

    // Also listen for value changes via events
    if (hiddenInput) {
      hiddenInput.addEventListener('change', syncDisplayFromInput);
      hiddenInput.addEventListener('input', syncDisplayFromInput);
    }

    // Initial sync on page load
    function init() {
      syncDisplayFromInput();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
