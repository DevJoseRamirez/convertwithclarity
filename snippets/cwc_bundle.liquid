{% style %}
  .swatch.is-bundle-swatch {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    width: 100%;
  }

  .swatch.is-bundle-swatch .swatch-items-wrapper {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    padding-top: 1.5rem;
    width: 100%;
  }
  .swatch.is-bundle-swatch .swatch-element {
    position: relative;
    border: 2px solid #e3e3e3;
    border-radius: 6px;
    padding: 0.5rem 0rem 0.5rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    background: #fff;
    flex: 1;
  }

  .cwc_bundle-selector .bundle-option.active {
    border-color: rgba(36 36 36 / 1) !important;
  }

  .swatch.is-bundle-swatch .swatch-element.active {
    border-color: #242424;
  }

  .swatch.is-bundle-swatch .swatch-element label {
    all: unset;
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    line-height: 1.2;
    width: 100%;
    height: 100%;
  }

  .swatch.is-bundle-swatch .swatch-element input {
    display: none;
  }
  .header.label-font {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0rem;
    text-align: left;
  }

  .cwc_bundle {
    padding: 2rem 0rem;
  }

  .swatch.is-bundle-swatch .bundle-option {
    position: relative;
    border: 2px solid #e3e3e3;
    border-radius: 6px;
    padding: 0.5rem 0rem 0.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.25s ease;
    background: #fff;
    flex: 1;
  }

  .swatch.is-bundle-swatch .bundle-swatch {
    width: 100%;
    height: auto;
  }
  .swatch.is-bundle-swatch {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0rem;
    padding-top: 1.5rem;
    flex-direction: column;
    position: relative;
    max-width: 100%;
  }

  .swatch.is-bundle-swatch .bundle-option img {
    width: 100%;
    height: auto;
    max-height: 130px;
    object-fit: contain;
  }

  .swatch.is-bundle-swatch .bundle-label {
    /* margin-top: 0.75rem; */
    margin-top: 0rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    line-height: 1.2;
    letter-spacing: 0.3px;
  }

  .swatch.is-bundle-swatch .bundle-badge {
    position: absolute;
    bottom: 100%;
    bottom: 101%;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--badge-bg, #eaeaea);
    color: white;
    font-size: 0.73rem;
    font-weight: 600;
    padding: 0.3rem 0.7rem;
    border-radius: 5px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    white-space: nowrap;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    z-index: -1;
  }
  .swatch.is-bundle-swatch .bundle-option.three .bundle-badge {
    color: black;
  }
  .bundle-block-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0rem;
    text-align: left;
  }
  .swatch.is-bundle-swatch .bundle-option.active {
    border-color: rgba(36 36 36 / 1) !important;
    transition: all 0s;
  }

  .swatch.is-bundle-swatch .bundle-swatch-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .swatch .swatch-items-wrapper .swatch-element label:hover,
  .swatch .swatch-items-wrapper .swatch-element:not(.sibling-hover-active) input:checked + label {
    background: white;
    color: black;
  }
  .swatch .swatch-items-wrapper .swatch-element label:hover,
  .swatch .swatch-items-wrapper .swatch-element:not(.sibling-hover-active) input:checked + label {
    outline: none;
  }

  .swatch.is-bundle-swatch .swatch-items-2 {
    border-color: #eda774; /* 2nd */
  }

  .swatch.is-bundle-swatch .swatch-items-2 .bundle-badge,
  .swatch.is-bundle-swatch .swatch-items-3 .bundle-badge {
    z-index: -1;
    text-transform: none;
  }

  .swatch.is-bundle-swatch .swatch-items-3 .bundle-badge {
    color: black;
  }
  .swatch.is-bundle-swatch .swatch-items-3 {
    border-color: #e2ebed; /* 3rd */
  }

  @media screen and (max-width: 768px) {
    .swatch.is-bundle-swatch .swatch-items-wrapper {
      gap: 0.6rem;
    }
    .swatch.is-bundle-swatch {
      gap: 10px;
    }
  }
{% endstyle %}

{% comment %}
  Renders text/color swatches for a product option.
  Set the extension of your color files below. Use 'png', 'jpeg', 'jpg' or 'gif'.

  Accepts:
  - swatch_option: The product option to render as a swatch.
  - option_index: The index of the option.
  - swatch_section_id: The section id. (required)
  - size_option_name: The name of the size option.
  - size_guide_page: The size guide page object.
  - size_guide_label: The label for the size guide link.
  - hide_out_of_stock_variants: Boolean to hide out of stock variants.

  Usage:
  {% render 'swatch' with swatch_option: option, option_index: option_idx, product: product, size_option_name:
  size_option_name, size_guide_page: size_guide_page, size_guide_label: size_guide_label, hide_out_of_stock_variants:
  hide_out_of_stock_variants %}
{% endcomment %}

<safe-load-scripts class="hidden">
  <script
    src="{{ 'component-product-swatch.js' | asset_url }}"
    defer="defer"
    type="module"
    data-flow-load-key="product-swatch"
  ></script>
</safe-load-scripts>

{% liquid
  assign file_extension = 'png'
  assign color_langs = 'color,colour,couleur,colore,farbe,색,色,färg,farve' | split: ','
  assign swatch_image_options = settings.show_variant_image_for_options | split: ','

  comment
    Check if the swatch is a category metafield swatch
  endcomment
  for value in swatch_option.values
    assign is_category_swatch = false
    if value.swatch.image != blank
      assign is_category_swatch = true
    elsif value.swatch.color != blank
      assign is_category_swatch = true
    endif
  endfor

  comment
    Check if the swatch should reflect the variant image
  endcomment
  assign option_name_formatted = swatch_option.name | camelize
  for image_option in swatch_image_options
    assign show_variant_image = false
    assign image_option_formatted = image_option | camelize
    if image_option_formatted == option_name_formatted
      assign show_variant_image = true
    endif
    if show_variant_image
      break
    endif
  endfor

  comment
    Check if the swatch is a regular color swatch
  endcomment
  assign is_color_swatch = false
  assign downcased_option = swatch_option.name | camelize | downcase
  if color_langs contains downcased_option
    assign is_color_swatch = true
  endif
%}

{% if swatch_option == blank %}
  <div class="swatch error">
    <p>You must include the snippet swatch.liquid with the product option.</p>
    <p>
      Use: <code>{% raw %}{% render 'swatch' with swatch_option: 'product option here' %}{% endraw %}</code>
    </p>
    <p>
      Example: <code>{% raw %}{% render 'swatch' with swatch_option: option %}{% endraw %}</code>
    </p>
  </div>
{% else %}
  <product-swatch
    data-swatch-sold-out-string="{{ 'products.product.sold_out' | t }}"
    class="
      swatch{% if is_color_swatch or is_category_swatch or show_variant_image %} is-color-swatch{% endif %}
      {% if swatch_option.name == 'Bundle & Save' %} is-bundle-swatch{% endif %}
    "
    data-option-index="{{ option_index }}"
    data-section-id="{{ swatch_section_id }}"
  >
    {% comment %} ============ OPTION LABEL ============ {% endcomment %}
    <div
      class="option-label-wrapper{% if is_color_swatch or is_category_swatch or show_variant_image %} is-color-label{% endif %}"
    >
      <div>
        <div class="header label-font">{{ swatch_option.name }}</div>
        {% if is_color_swatch or is_category_swatch or show_variant_image %}
          <div class="header product-swatch-color-name" data-color-swatch-name-container>
            <span data-color-swatch-name>{{ swatch_option.selected_value | truncate: 22 }}</span>
            <span data-color-swatch-state></span>
          </div>
        {% endif %}
      </div>
      {% assign formatted_swatch_option_name = swatch_option.name | downcase %}
      {% assign formatted_size_option_name = size_option_name | downcase %}
      {%- if formatted_swatch_option_name == formatted_size_option_name and size_guide_page != blank -%}
        <safe-load-scripts class="hidden">
          <script
            src="{{ 'component-size-guide-link.js' | asset_url }}"
            defer="defer"
            type="module"
            data-flow-load-key="size-guide-link"
          ></script>
        </safe-load-scripts>

        <size-guide-link id="size-guide" class="text-link-animated">
          <a data-size-guide-link id="size-guide-link" tabindex="0" href="{{ size_guide_page.url }}">
            {{- size_guide_label | default: size_guide_page.title -}}
          </a>
        </size-guide-link>
      {%- endif -%}
    </div>

    {% comment %} ============ OPTION VARIANTS (SWATCHES) ============ {% endcomment %}
    <div class="swatch-items-wrapper">
      {% for value in swatch_option.values %}
        {% liquid
          if hide_out_of_stock_variants and value.available == false
            assign show_variant = false
          else
            assign show_variant = true
          endif

          assign is_combined_listing = false
          if value.product_url != blank
            assign is_combined_listing = true
            assign show_variant = true
            assign item_fetch_url = value.product_url | append: '?variant=' | append: value.variant.id
            assign product_url = value.product_url
          else
            assign item_fetch_url = value.variant.url
            assign product_url = value.variant.product.url
          endif
        %}

        {%- capture input_id -%}
        {{ swatch_section_id }}-{{ option_index }}-{{ forloop.index0 -}}
        {%- endcapture -%}

        {% if show_variant %}
          <div
            data-swatch-option-available="{{ value.available }}"
            data-swatch-variant-id="{{ value.variant.id }}"
            data-selected-swatch-variant-id="{{ swatch_option.selected_value.variant.id }}"
            data-option="{{ swatch_option.name }}"
            data-value="{{ value | escape | truncate: 22 }}"
            data-media-id="{{ value.variant.featured_media.id }}"
            class="swatch-items-{{ forloop.index }} swatch-element variant-swatch {% if is_color_swatch or is_category_swatch or show_variant_image %}color {% endif %}{{ value | handle }} {% if value.available %}available{% else %}soldout{% endif %}{% if swatch_option.selected_value == value %} active{% endif %}"
          >
            <input
              data-product-variant
              data-option-value-id="{{ value.id }}"
              data-is-combined-listing="{{ is_combined_listing }}"
              data-product-fetch-url="{{ item_fetch_url }}"
              data-product-url="{{ product_url }}"
              id="{{ input_id }}"
              class="visually-hidden"
              type="radio"
              name="option-{{ option_index | plus: 1 }}-{{ swatch_section_id }}"
              value="{{ value | escape }}"
              {% if swatch_option.selected_value == value %}
                checked
              {% endif %}
            >

            {% if is_color_swatch or is_category_swatch or show_variant_image %}
              {% liquid
                comment
                  Define the color value
                endcomment
                assign bg_color = value | camelize | downcase
                if value contains '#'
                  assign bg_color = value | downcase
                endif

                comment
                  Reassign the color value if the swatch has a category metafield color
                endcomment
                if value.swatch.color
                  assign bg_color = value.swatch.color
                endif

                comment
                  Define the image url
                endcomment
                assign bg_img_url = value | handle | append: '.' | append: file_extension | file_url
                unless show_variant_image
                  comment
                    Check if the swatch has a category metafield image
                  endcomment
                  if value.swatch.image
                    assign bg_img_url = value.swatch.image | image_url: width: 50
                  endif
                else
                  comment
                    Check if the variant has a featured media
                  endcomment
                  if value.variant.featured_image
                    assign bg_img_url = value.variant.featured_image | image_url: width: 50
                  endif
                endunless
              %}

              <label
                for="{{ input_id }}"
                style="{% if bg_img_url contains 'v=' %}background-image: url({{ bg_img_url }}); background-size: cover; background-position: center center;{% else %} background-color: {{ bg_color }};{% endif %}"
                aria-labelledby="{{ input_id }}"
              >
                <span class="sr-only">{{ value }}</span>
                <span class="product-swatch-sold-out product-swatch-sold-out-background"></span>
                <span class="product-swatch-sold-out product-swatch-sold-out-foreground"></span>
              </label>
            {% else %}
              <label for="{{ input_id }}" aria-labelledby="{{ input_id }}" class="bundle-style-swatch">
                <div class="bundle-label">{{ value }}</div>

                {% if value.variant.featured_image %}
                  <img class="bundle-swatch" src="{{ value.variant.featured_image | image_url }}" alt="{{ value }}">
                {% endif %}
              </label>

              {% comment %} Optional badge based on value or index {% endcomment %}
              {% if forloop.index == 2 %}
                <span class="bundle-badge" style="background-color: #eda774;">Best Value</span>
              {% elsif forloop.index == 3 %}
                <span class="bundle-badge" style="background-color: #e2ebed;">Best Seller</span>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}

        {% comment %} ============ VARIANT JSON ============ {% endcomment %}
        <script type="application/json" data-resource="{{ input_id }}">
          {{ value.variant | json }}
        </script>
      {% endfor %}
    </div>
  </product-swatch>
{% endif %}
