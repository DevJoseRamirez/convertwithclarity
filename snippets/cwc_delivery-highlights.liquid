{% style %}
  .delivery-highlights {
    display: flex;
    /* flex-wrap: wrap; */
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    padding: 1rem 0rem;
    margin-bottom: 1rem;
  }

  .delivery-highlight {
    background: #eaf1f1;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    align-items: center;
  }

  .highlight-text {
    font-size: 0.8rem;
  }

  .highlight-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .highlight-icon img {
    width: 28px;
    height: auto;
  }

  /* MOBILE ========= */
  @media screen and (max-width: 768px) {
    .delivery-highlights {
      margin: auto;
      max-width: 80%;
      margin-bottom: 1rem;
    }
    .delivery-highlight {
      background: #eaf1f1;
      border-radius: 6px;
      padding: 0.5rem 1rem;
      flex: 1;
      flex-direction: column;
    }
    .highlight-text {
      /* font-size: .7rem; */
      display: flex;
      flex-direction: column;
      text-align: center;
    }
    .highlight-icon img {
      width: 22px;
      height: auto;
    }
  }
{% endstyle %}

<div class="delivery-highlights" {{ block.shopify_attributes }}>
  <div class="delivery-highlight">
    <span class="highlight-icon">
      <img src="{{ block.settings.option_1_image | image_url }}" alt="{{ block.settings.option_1_image.alt }}">
    </span>
    <span class="highlight-text">
      {{ block.settings.highlight_1_text }}
      <span class="delivery-estimate" data-max-days="{{ block.settings.max_shipping_days }}"></span>
    </span>
  </div>

  <div class="delivery-highlight">
    <span class="highlight-icon">
      <img src="{{ block.settings.option_2_image | image_url }}" alt="{{ block.settings.option_2_image.alt }}">
    </span>
    <span class="highlight-text">
      {{ block.settings.highlight_2_text }}
    </span>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const estimateEl = document.querySelector('.delivery-estimate');
    if (!estimateEl) return;

    const maxDays = parseInt(estimateEl.dataset.maxDays, 10) || 5;

    const deliveryDate = new Date();
    deliveryDate.setDate(deliveryDate.getDate() + maxDays);

    const options = { weekday: 'short', month: 'short', day: 'numeric' };
    const formattedDate = deliveryDate.toLocaleDateString(undefined, options);

    estimateEl.textContent = formattedDate;
  });
</script>
