    "cwc_faq_PqgtL6": {
      "type": "CWC_faq",
      "blocks": {
        "faq_item_cWBrhX": {
          "type": "faq_item",
          "settings": {
            "question": "How long does a typical engagement take?",
            "answer": "<p>Most engagements run 4–8 weeks depending on scope. Smaller scopes (audit-only, single landing page) can wrap in 1–2 weeks. I'll give you a real timeline before we start — not a hopeful one.</p>"
          }
        },
        "faq_item_iRA66c": {
          "type": "faq_item",
          "settings": {
            "question": "How does pricing work?",
            "answer": "<p>Most engagements are fixed-fee — defined scope, defined timeline, defined deliverables. Ongoing CRO work and open-ended retainers can be hourly. I'll quote whichever makes more sense based on what you actually need.</p>"
          }
        },
        "faq_item_wbACph": {
          "type": "faq_item",
          "settings": {
            "question": "Do you only work through Upwork?",
            "answer": "<p>For new clients, yes. Upwork keeps payments, contracts, and reviews clean for both of us — and it's where my track record lives. Once we've worked together, we can move to direct contracts if that makes more sense.</p>"
          }
        },
        "faq_item_Lw7BP3": {
          "type": "faq_item",
          "settings": {
            "question": "What kind of Shopify access do you need?",
            "answer": "<p>Collaborator access with permissions for whatever scope we agree on — usually themes, apps, and sometimes orders/customers for advanced work. I never need your payment info or store owner login.</p>"
          }
        },
        "faq_item_gLrTYU": {
          "type": "faq_item",
          "settings": {
            "question": "What if my store isn't ready for CRO yet?",
            "answer": "<p>I'll tell you. If you don't have enough traffic to test, or the offer itself is the problem, throwing CRO work at it is wasted money. I'd rather lose a project than take on work that won't move your numbers.</p>"
          }
        },
        "faq_item_QdfDFt": {
          "type": "faq_item",
          "settings": {
            "question": "What if my project is smaller than a full engagement?",
            "answer": "<p>Most projects are full-scope, but the components are modular — audit, landing page, custom build, etc. If you're not sure what you need, message me and we'll figure out the right starting point. Sometimes the answer is \"start with the audit, expand from there.\"</p>"
          }
        },
        "faq_item_miMcTV": {
          "type": "faq_item",
          "settings": {
            "question": "Do you work with brands outside the US?",
            "answer": "<p>Yes. A lot of my clients are international. Communication is async-friendly, and Upwork handles the cross-border payment side.</p>"
          }
        }
      },
