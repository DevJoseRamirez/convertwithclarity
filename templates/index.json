    "cwc_who_this_is_for_pMqhGw": {
      "type": "CWC_who_this_is_for",
      "blocks": {
        "qualifier_8L7nCL": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We pull your analytics, traffic sources, and everything you've already tried, then map your full funnel end to end — so we start from data, not guesses.</p><p></p>"
          }
        },
        "qualifier_whTGPY": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We review every drop-off point — PDP, cart, checkout, navbar, post-purchase, and the landing pages your paid traffic hits — with heatmaps, session recordings, and funnel analysis. Every friction point gets documented.</p><p></p>"
          }
        },
        "qualifier_kPFBNY": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We turn the findings into a ranked roadmap, sorted by impact, effort, and speed to ship. You see exactly what we're fixing and why — no vague \"make it better.\"</p><p></p>"
          }
        },
        "qualifier_kXMMKN": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We write clean, custom code straight into your Shopify theme — sections, landing pages, funnel work, whatever the audit calls for. No third-party page builders, no app-bloat.</p><p></p>"
          }
        },
        "qualifier_bd6Chj": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We set up proper measurement and watch the metrics that matter — CR, AOV, RPV — so you know what actually worked, not just what looks busy.</p><p></p>"
          }
        },
        "qualifier_bQwFtJ": {
          "type": "qualifier",
          "settings": {
            "text": "<p>We double down on winners, cut losers, and move to the next bottleneck — cycle after cycle. Conversion compounds; we keep it compounding.</p>"
          }
        }
      },
